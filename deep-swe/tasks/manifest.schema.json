{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "schema_version",
    "dataset",
    "source_dataset",
    "task_count",
    "id_policy",
    "label_generation",
    "tasks"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "dataset": {
      "const": "deep-swe"
    },
    "source_dataset": {
      "const": "swe-bench-ultra"
    },
    "task_count": {
      "type": "integer",
      "minimum": 1
    },
    "id_policy": {
      "type": "object"
    },
    "label_generation": {
      "type": "object"
    },
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "ext_id",
          "task_id",
          "display_title",
          "display_description",
          "repo",
          "repository_url",
          "original_title",
          "category",
          "language"
        ],
        "properties": {
          "ext_id": {
            "type": "string",
            "pattern": "^kh[0-9a-z]+$"
          },
          "task_id": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
            "maxLength": 56
          },
          "display_title": {
            "type": "string",
            "minLength": 1,
            "maxLength": 120
          },
          "display_description": {
            "type": "string",
            "minLength": 1,
            "maxLength": 240
          },
          "repo": {
            "type": "string",
            "pattern": "^[^/]+/[^/]+$"
          },
          "repository_url": {
            "type": "string"
          },
          "original_title": {
            "type": "string"
          },
          "category": {
            "type": "string"
          },
          "language": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
